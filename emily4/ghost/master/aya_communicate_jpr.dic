//======================================================================================
JPRadish_挨拶
{
	SHIORI3FW.SetDelayEvent('OnGreetingFromOtherGhost',1,reference)
}

OnGreetingFromOtherGhost
{
	_type = -1
	if 'おはよ' _in_ reference[1] {
		_type = 0
	}
	elseif RE_SEARCH(reference[1],'こんにち[はわ]') {
		_type = 1
	}
	elseif RE_SEARCH(reference[1],'(こんばん[はわ]|ばわ[ー～])') {
		_type = 2
	}
	elseif RE_SEARCH(reference[1],'やっ?ほ[ー～]') {
		_type = 3
	}
	elseif RE_SEARCH(reference[1],'ど[ー～う]も[ー～]') {
		_type = 4
	}
	
	if _type >= 0 { //是问候
		if SHIORI3FW.LastSurface[0] == 40 { //烤焦中
			if SHIORI3FW.LastSurface[1] == 14 { //果然烤焦中
				"\u\s[14]\h\s[40]…\w5…\w5…\w5…\w5…咳嗯。\w9\w9\u咳、\w5咳嗯咳嗯。\w9\w9\h\n\n咳咳、\w5诶呜——、\w5咳嗯咳嗯。\w9\w9\u\n\n…\w5…\w5以、\w5以上、\w5算是问候了、\w5咳嗯。\e"
			}
			else {
				"\u\s[10]\h\s[40]…\w5…\w5…\w5…\w5…。\w9\w9\u\s[11]『现在正在香喷喷烤制中、\w5就请用意念在问候的我的心来原谅吧』\w5是这么说的。\w9\w9\h\n\n咳咳。\w5诶呜——。"
			}
		}
		else {
			_name = E.AddKeisyou(reference[0],'桑')
			
			switch _type {
				"\u\s[10]\h\s[5]早上好——、\w5%(_name)。\w9\w9\u早上好。\e"
				
				"\u\s[10]\h\s[5]你好、\w5%(_name)。\w9\w9\u你好。\e"
				
				"\u\s[10]\h\s[5]晚上好、\w5%(_name)。\w9\w9\u晚上好。\e"
				
				"\u\s[10]\h\s[5]呀嚯——、\w5%(_name)。\w9\w9\u%(GetGreeting)。\e"
				
				"\u\s[10]\h\s[5]%(GetGreeting)、\w5%(_name)。\w9\w9\u%(GetGreeting)。\e"
			}
		}
	}
	
	//MakeJPRadishReply('挨拶の返信')
}

//======================================================================================
JPRadish_広い場所が欲しい
{
	if displaysize[1] >= 768 {
		"\u\s[10]\h\s[27]我觉得这里没有那么窄啦。\w9\w9\u\_a[GHOST_所長たん]所长桑\_a所拥有的、\w5说是高度太低以至Temu桑会撞到头。\w9\w9\h\s[4]\n\n呜哇——。\w5那倒是\w5…\w5…\w9\w9\u\n\n嘛、\w5跟那个比的话是挺宽敞的呢。\e"
		
		MakeJPRadishReply('この程度でかまわない')
	}
	else {
		if displaysize[0] >= 1024 {
			"\u\s[10]\h\s[2]哇哇、\w5被说起来一看、\w5超级横长的。\w9\w9\u\s[11]这个是\w5…\w5…\w9\w9\h\s[5]\n\n跟\_a[GHOST_所長たん]shocho TAN\_a一样呢。\w9\w9\u\n\n那个又不是普通电脑。\e"
		}
		else {
			"\u\s[10]\h\s[4]确、\w5确实好窄啊。\w9\w9\u我们还算受得了、\w5但辛苦的人好像很多呢。\w9\w9\h\n\n%(username)——、\w5买更宽敞的啦——。\w9\w9\u\s[11]\n\n…\w5…\w5要是能简单变宽的话早就做了。\e"
		}
	}
}

