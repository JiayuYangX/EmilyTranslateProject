///////// 沟通辞书—萝卜
// Let's spaghetti! orz
// 注意：价格、数值等可能以全角传入

//-----商店调用----------------------------------------------------------
JPRadish_売り文句
{
	_ref = TOINT(E.ConvertToNum(_argv[1]))
	
	if ISFUNC("JPRadish_Shop_%(_argv[0])") {
		_scr = EVAL("JPRadish_Shop_%(_argv[0])(%(_ref))")
		if STRLEN(_scr) {
			_scr
			return
		}
	}
	
	JPRadish_Shop_None(_argv)
}

JPRadish_売却
{
	_ref = TOINT(E.ConvertToNum(_argv[1]))
	
	if ISFUNC("JPRadish_Buy_%(_argv[0])") {
		_scr = EVAL("JPRadish_Buy_%(_argv[0])(%(_ref))")
		if STRLEN(_scr) {
			_scr
			return
		}
	}
}

//****反应*******************************************************

JPRadish_Shop_None
{
	"\u\s[10]\h\s[8]抱歉、\w5%(_argv[0])现在不需要。\w9\w9\u下次再拜托哦。\e"
	
	MakeJPRadishReply('購入拒否',_argv[0],'不要')
}

JPRadish_Shop_蚊取り線香
{
	if 'エンバグ' _in_ reference[1] {
		"\u\s[10]\p2\s[200]\h\s[27]呼——嗯、\w5原来可以不那么容易产生Bug啊。\w9\n\_a[GHOST_所長たん]所长桑\_a也得推荐一下才行。\w9\w9\p2\s[204]…\w5…\w5那是什么蚊香啊、\w5那个。\w9\w9\u\s[10]嘛、\w5反正%(charname(0))是不需要啦。\w9\w9\h\s[8]\n\n抱歉啦——。"
		
		MakeJPRadishReply('購入拒否',_argv[0],'不要')
	}
}

JPRadish_Shop_健胃薬
{
	_num = EMGoodsQueryNum('健胃薬')
	if _num > 10 {
		"\u\s[10]\h\s[8]对不起、\w5现在够多了所以不需要。\w9\w9\u嘛、\w5有%(_num)个了嘛。\e"
		
		MakeJPRadishReply('購入拒否','健胃薬','在庫過多')
	}
	else {
		_money = _argv[0]
		
		"\u\s[10]\h\s[5]哇——。\w5是健胃药——。\w9\n这样红薯就能随便吃了！\w9\w9\u\s[11]…\w5…\w5体重、\w5会增加呢。\w9\w9\h\s[4]\n\n诶呜。\w9\w9\n…\w5…\w5\s[0]啊、\w5那、\w5就%(_money)日元买了。\w9\w9\u\n\n\s[11]…\w5…\w5这个月的零花钱。\w9\w9\h\s[4]\n\n诶呜。\e"
		MakeJPRadishReply('売り文句の返信','健胃薬',_money)
	}
}

JPRadish_Buy_健胃薬
{
	_money = TOINT(_argv[0])
	
	"\u\s[10]\h\s[5]那、\w5就%(_money)日元给我吧♪\w9\w9\u\s[11]真是的、\w5乱花钱\w5…\w5…\e"
	
	MakeJPRadishReply('売却の返信','健胃薬',_money)
	EMGoodsAdd('健胃薬',1)
	
	money_used += _money
}

