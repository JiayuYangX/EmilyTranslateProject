///////// 启动/结束/切换对话词典

//**** 首次启动 *************************************************************************

//---- OnFirstBoot事件 --------------------------------------------------------------
OnFirstBoot
{
	//---- 变量初始化
	if SHIORI3FW.Status != 'Run' {
		username         = "User桑"
	}
	mikireflag       = 0	// 越界处理用

	//---- 通过Vanish计数判断是否为真正首次启动……没必要（默认就是）
	"\t\u\s[10]\h\s[5]初次见面！\w9\w9\n\s[0]我、\w5叫%(charname(0))。\w9\n\s[6]还有、\w5旁边那个小个子的就是%(charname(1))哦。\w9\w9\n\s[5]介绍完毕！\w9\u\s[11]等一下啊那个。\w9\w9\h\s[4]\n\n诶——。\w9\w9\u\n\n我觉得也不用说小个子啦。\w9\n还有、\w5是不是忘了谁？\w9\w9\h\n\n…\w5…\p2\s[214]\h\w5…\w5…\w5\s[2]啊！\w9\w9\p2嘛、\w5算了\w5…\w5…\w9\w9\h\s[4]\n\n抱歉抱歉。\w9\n\s[0]这个中等个子的叫%(charname(2))。\w9\s[8]\n是个有点臭屁的我的弟弟。\w9\w9\p2\n\n…\w5…\w5自我介绍还是一样的烂呢。\w9\n算了。\w9\w9\w9\s[-1]\b[-1]\h\s[4]\n\n…\w5…\w5嗯——、\w5总之、\w5请多关照。\w9\w9\u\n\n\s[10]对了对了、\w5我们姑且算是SSP的向导。\w9\n…\w5…\w5\s[11]如你所见、\w5别说向导了怕是会拖着后腿掉进谷底吧。\w9\w9\h\n\n…\w5…\w5对不起。\w9\n\s[5]不过、\w5我们会加油的、\w5有不懂的地方就叫我们哦！\w9\w9\u\n\n\_a[GHOST_所長たん]SSP的开发者桑好像都作为人格来了\_a、\w5推荐去问问那边哦。\w9\w9\h\s[4]\n\n那块等一下。\w9\w9\w9\w9\w9\h\s[0]\n\n啊、\w5说起来\w5…\w5…\w9\n\s[6]可以的话、\w5请告诉我你的名字。\w9\![open,configurationdialog,setup]\e"
}

//**** 正常启动 ***********************************************************************

//---- OnBoot事件 -------------------------------------------------------------------
OnBoot
{
	if reference[6] == "halt" {
		OnBoot_Halt
	}
	else {
		_date = STRFORM("$02d$02d",GETTIME[1],GETTIME[2])
		_script = ""
		
		//日期对话特殊处理
		if ISVAR('lastboottalkarray') == 0 {
			lastboottalkarray = IARRAY
		}
		
		if lastbootdate_saved != _date {
			if userbirthday_date == _date {
				lastboottalkarray = (OnBoot_UserBirthday,IARRAY)
			}
			else {
				_bfunc = 'OnBoot_' + _date
				if ISFUNC(_bfunc) {
					lastboottalkarray = (EVAL(_bfunc),IARRAY)
				}
				else {
					lastboottalkarray = IARRAY
				}
			}
			lastbootdate_saved = _date
		}
		
		_n = ARRAYSIZE(lastboottalkarray)
		if _n {
			_rand = RAND(_n)
			_script = E.EvalEmbedValue(lastboottalkarray[_rand])
			lastboottalkarray[_rand] = IARRAY //删除
		}
		
		//新闻处理
		if STRLEN(_script) == 0 {
			_script = OnBoot_NewsNeta
		}
		
		//正常启动对话
		_timeslot = GetTimeSlot
		if STRLEN(_script) == 0 {
			_array = IARRAY
			
			if ISFUNC("OnBoot_%(_timeslot)") {
				_array ,= EVAL("OnBoot_%(_timeslot)")
			}
			if ISFUNC("BootRandomTalkSub_%(_timeslot)") {
				_array ,= EVAL("BootRandomTalkSub_%(_timeslot)")
			}
			
			if ARRAYSIZE(_array) {
				_script = E.EvalEmbedValue(_array[RAND(ARRAYSIZE(_array))])
			}
		}
		
		if STRLEN(_script) == 0 {
			_script = OnBoot_other
		}
		
		_script
	}
}

//=============== 崩溃 =======================================================
OnBoot_Halt
{
	//掉落了！！！
	if reference[7] == "Emily" {
		reference[7] = "ボクのせい"
	}
	
	"\u\s[10]\h\s[7]掉下来了！\w8\n因为%(reference[7])掉下来了！\w9\w9\s[4]\n\n…\w5…\w5对不起。\w9\w9\u\s[10]BUG报告拜托了。\e"
	
	{
		"\u\s[10]\h\s[7]之所以因为%(reference[7])掉下来、\w5"
		--
		"全都是小灰的杰作啦！"
		"全都是Resident of Sun的杰作啦！"
		"是诺斯特拉达姆斯预言了的啦！"
		--
		"\w9\w9\u…\w5…\w5怎么可能。\w9\w9\h\s[4]\n\n%(charname(1))好冷淡\w5…\w5…\w9\w9\u\n\n…\w5…\w5嗯——、\w5总之%(username)、\w5BUG报告拜托了哦。\w9\w9\h\n\n\s[3]添麻烦了对不起哦～。\e"
	}
}

//=============== 启动 =======================================================


//--------------- 用户生日 -------------------------------------------------------

OnBoot_UserBirthday
{
	"\u\s[10]\0\s[35]啊、%(username)！\w9\w9\1终于来了呢——。\w9\w9\p[2]\s[218]姐姐她啊、从刚才起就干劲十足…\w5…\w5\w9\w9\0\n\n那当然、今天可是%(username)的生日嘛。\w9\n我、可是拼命想了庆祝方案的哦！\w9\w9\1\s[11]\n\n难得闻到一股好闻的味道呢。\w9\w9\0\s[56]\n\n泰迪那份、%(username)好像可以吃掉哦？\w9\w9\1\s[12]\n\n哇——、骗你的对不起！\w9\w9\p[2]\s[208]\n\n…\w5…\w5啊哈哈。\w9\w9\0\s[55]\n\n来、那来做最后的收尾了！\w9\s[24]\n适度的表演和焦痕是美味料理的秘诀！\w9\w9\1\n\n哇——！！\w9\w9\p[2]\s[202]\n\n等、等等——！！\0\s[-1]\n\n\1\s[-1]\n\n\p[2]\s[-1]\n\n\0\s[40]\n\n\1\s[14]\n\n\p[2]\s[240]\n\n\w9\w9\0\n\n…\w5…\w5…\w5咳…\w5…\w5…\w5\w9\w9\1\n\n大、大致预料到了呢…\w5…\w5\w9\w9\p[2]\n\n笨蛋老姐——…\w5…\w5\w9\w9\0\n\n…\w5…\w5恭、恭喜、%(username)…\w5…\w5\w9\w9\1\n\n说了多少次拉炮和料理不能放一起…\w5…\w5\e"
}

//--------------- 新闻 -------------------------------------------------------
OnBoot_NewsNeta
{
	if RAND(2) != 0 { //概率1/3，否则立即返回
		''
		return
	}
	
	EMGetLatestNews
}

//(电视话题)
OnBoot_TVTalk_Before
{
	"\h\s[20]\i[%(_argv[1])]\p2\s[-1]\u\s[10]…\w5…\w5艾米莉和艾米利欧都%(_argv[0])\w5…\w5…。\w9\w9\n看电视算了。\w9\n（按）\w9\n…\w9…\w9…。\w9\n"
}

OnBoot_TVTalk_After
{
	"\w9\n遥、\w5遥控器！！\w9\n换其他台！\w5换其他台！！\w9\w9\h\s[4]\n\n…\w5…\w5被人看到自己看%(_argv[0])看入迷了有那么害羞吗？\e"
}

