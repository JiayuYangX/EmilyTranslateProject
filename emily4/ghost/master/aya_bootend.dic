OnBoot_earlymorning : array
{
	'\u\s[10]\h\s[5]早上了～。\w9\n早安～\w5%(username)～。\w9\w9\u希望今天也是美好的一天呢。\e'
	
	'\u\s[10]\h\s[5]早安，\w5给报纸。\w9\w9\u谢谢。\w9\n好、\w5看看世界局势——\w5…\w5…\w9\w9\h\s[4]\n\n每天早上读报的动物是怎样啊\w5…\w5…。\w9\w9\u\s[12]\n\n哦、\w5\_a[GHOST_所長たん]所长桑\_a在报上登广告了！\w9\w9\h\s[2]\n\n诶诶！\w9\w9\n\s[0]上面写的什么？\w9\w9\u\s[11]\n\n征集素材。\w9\n不限年龄、\w5不限经验。\w9\n高薪优待。\w9\w9\h\s[4]\n\n…\w5…\w5…。\e'
}

