ssp_falsename_p : nonoverlap
{
	'ぱんつ'
	'ぴんち'
	'ぽけっと'
	'ぽん'
}

ssp_falsename
{
	ssp_falsename_s + ssp_falsename_s + ssp_falsename_p
}

