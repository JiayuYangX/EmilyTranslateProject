OnGhostChangeCall_所長たん
{{START_CHANGE
	when EMS_GC_CALLING {
		"\u\s[10]\h\s[5]所长，\w5%(GetGreeting)。\w9\w9\u…\w5…\w5说起来，\w5你平时都在做什么工作呢。\w9\w9\h\s[27]\n\n嗯～，\w5%(GCC_Syotyo_Work_False)？\w9\w9\u\s[11]\n\n那不是工作啦。\e"
	}
	when EMS_GC_CALLCOMPLETE {
		if RAND(10) == 0 {
			SHIORI3FW.SetDelayEvent("OnDicCommunicate_所長たん1",10)
		}
	}
	when EMS_GC_CHANGING {
		"\p2\s[200]\u\s[10]\h\s[2]诶！？\w9换所长了！？\w9\w9\s[3]\n我的导航你不满意～？\w9\w9\u\p2\s[200]\_s[1,2]我觉得不满意。\_s\w9\w9\h\s[7]\n\n凭什么啊！！\w9\w9\u\s[11]\n\n还要问为什么\w5…\w5…\w5\w9\w9\p2\s[218]\n\n你说呢？\w9\w9\h\s[4]\n\n呜呜～。\w9所长～～～。\e"
		
		'\1\s[10]\0\s[5]debug debug run tatta～♪\w9\w9\1什么歌啊这是。\w9\w9\0\n\n所长工作的时候，\w5在背后唱这个很有趣。\w9\w9\1\n\n…\w5…\w5品味真差。\w9\w9\0\n\ndebug enbug des marchi～♪\w9\w9\1\n\n…\w5…\w5会挨骂的别唱了。\e'
		
		//Felis.Miacis san
		<<"
		艾27：C.Ponapalt的C到底是什么缩写呢。
		特10：……那里，请自行领会吧。
		艾　　：但还是会在意是什么缩写吧。
		特　　：你觉得是什么。
		艾01：难，难道是Command？
		特　　：为什么是Command。
		艾08：那，Control？
		特　　：控制来干嘛。
		">>

		//Felis.Miacis san
		<<"
		艾05：Tiro Finale。
		特11：……不知道什么意思就别乱说比较好哦。
		">>
	}
	when EMS_GC_CHANGED {
		if "ケーキを" _in_ change_plain_talk {
			"\u\s[10]\p2\s[200]\h\s[55]好～的。\w9我回来了～…\w5…\w5\w9\s[2]咚，\w5咚，\w9\w9\s[-1]哇！！\w9\n（哐啷）\w9\w9\u\s[11]…\w5…\w5又要从打工费里扣了吧。\w9\w9\p2\s[204]姐姐，\w5会影响我的零花钱的注意点啊。\w9\w9\h\s[8]\n\n啊～\w9哈哈哈～。\w9\w9\s[5]\n\n啊，\w5%(username)桑呀吼～。\w9\w9\u\s[10]\n\n一脸无语地看着呢。\w9\w9\p2\s[203]\n\n也难怪啦。\w9\w9\h\s[9]\n\n闭嘴。\e"
		}
	}
	when EMS_GC_CLOSED {
		"\u\s[10]\h\s[5]所长，\w5辛苦了～。\w9\w9\u\s[11]…\w5…\w5今天看起来也不怎么像在工作呢。\w9\w9\h\s[4]\n\n我觉得这话不能说啊。\e"
	}
}}END_CHANGE

