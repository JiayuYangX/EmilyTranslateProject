//-------------------------------------------------------------------------新2005.6.6/改----.--.--
OnGhostChangeCall_典子
{{START_CHANGE
	//同学
	//Emily>两人>Emilio。Emilio用桑Emily用酱。Teddy用「酱」
	when EMS_GC_CHANGING {
		"\u\s[10]\h\s[27]说是桌面实习呢。\w9\n会是什么样的呢。\w9\w9\u作为课程的一环，\w5是来体验人格的工作的吧。\w9\w9\h\s[5]\n\n原来如此～。\w9\n说不定将来还想成为出色的人格桑呢。\w9\w9\u\s[11]\n\n…\w5…\w5然后因为太没出息，\w5以后SSP导航员的工作就会被那两个抢走了吧。\w9\w9\h\s[2]\n\n喵啊啊啊啊啊！？"
	}
	when EMS_GC_CHANGED {
		if 'テディを飼いたいな' _in_ change_plain_talk {
			"\u\s[10]\h\s[5]彻底变成大人的%(charname(0))登场～。\w9\w9\u是照顾坚持说自己彻底变成大人的小孩，\w5结果彻底憔悴了的%(charname(1))。\w9\w9\h\s[7]\n\n你，\w5你什么意思啊！！\w9\w9\u\n\n去典子酱那里被养可能更幸福呢。\w9\w9\h\s[9]\n\n唔唔唔唔～～～～。\e"
		}
	}
	when EMS_GC_CALLING {
		"\u\s[10]\p2\s[200]\h\s[5]啊，\w5又来做实习了呢。\w9\n每次每次都辛苦了～。\w9\w9\u你们两个很努力呢。\w9\w9\p2\s[204]嗯～，\w5我倒觉得看起来只是在努力斗嘴而已。\w9\w9\h\s[4]\n\n%(charname(2))，\w5那个不能说啦。"
	}
	when EMS_GC_CALLED {
		if '公僕' _in_ change_plain_talk {
			"\u\s[10]\h\s[27]公仆\w5…\w5…？\w9\n那是什么啊。\w9\w9\u\s[11]不，\w5我是我但不是公仆。\w9\w9\h\n\n\s[3]嗯～\w5…\w5…。\w9\w9\n\s[55]总之请喝茶～。\w9\w9\u\n\n那里，\w5别想蒙混过去。\w9\w9\h\s[4]\n\n唔。"
		}
		else {
			"\u\s[10]\p2\s[200]\h\s[5]典子酱良太酱%(GetGreeting)～。\w9\w9\u实习中来打扰了。\w9\w9\p2\s[205]今天也精神地把实习扔一边在吵架吗？\w9\w9\h\s[4]\n\n…\w5…\w5我觉得并不是总在吵架哦。\e"
		}
	}
	when EMS_GC_CLOSED {
		"\u\s[10]\h\s[5]典子酱，\w5良太酱，\w5实习辛苦了～。\w9\w9\u今天也很要好呢。\w9\w9\h\s[8]\n\n呃，\w5嗯～。"
	}
}}END_CHANGE

//-------------------------------------------------------------------------新2005.6.8/改2005.11.2
OnGhostChangeCall_シホ
{{START_CHANGE
	//时江与志保
	//全员用「桑」。Emily有点微妙但有点向往
	when EMS_GC_CHANGING {
		"\u\s[10]\p2\s[200]\h\s[5]时江桑和志保桑好帅啊。\w9\w9\u和\_a[GHOST_舞子]舞子\_a不同，\w5好像不用担心Emilio被盯上了呢。\w9\w9\p2\s[204]…\w5…\w5不过取而代之的是感觉会被戏弄玩耍呢。"
	}
	when EMS_GC_CHANGED {
		"\u\s[10]\h\s[3]明明年龄没差多少，\w5时江桑和志保桑看起来却好成熟啊。\w9\n好羡慕啊。\w9\w9\u\s[11]…\w5…\w5不是她们两个成熟，\w5是%(charname(0))像小孩一样\w5…\w5…\w9\w9\h\s[9]\n\n你说什么～～～。"
	}
}}END_CHANGE

//-------------------------------------------------------------------------新2005.6.9/改2005.6.14
OnGhostChangeCall_ネリン
{{START_CHANGE
	//NCP ～Arabian喵～
	//对方也是喵。所以喵喵（谜
	when EMS_GC_CHANGING {
		"\u\s[10]\h\s[27]唔～～～。\w9\w9\u从刚才在烦恼什么？\w9\w9\h\n\n那个啊。\w9\n\s[5]我在想要不要对抗Nelin桑，\w5也自称红薯喵。\w9\w9\u\s[11]\n\n…\w5…\w5小心别因为吃太多红薯被说成胖嘟嘟～喵哦。\w9\w9\h\s[4]\n\n呃。"
		
		"\u\s[10]\h\s[5]听说Nelin桑，\w5从小修行就能用火焰魔法呢。\w9\w9\u\s[11]和某个从小就有能力却荒废着腌着不用的猫真是天差地别呢。\w9\w9\h\s[4]\n\n…\w5…\w5唔咕。\e"
	}
	when EMS_GC_CALLING {
		"\u\s[10]\p2\s[200]\h\s[5]会魔法的阿拉伯喵快来～～！\w9\n这样火焰猫组合就结成了～～～！\w9\w9\u\s[11]一边是经过正规训练的正统阿拉伯人。\w9\w9\p2\s[218]而另一边是整年暴走无法收拾的废柴老姐的话，\w5怎么想都是凹凸组合吧。\w9\w9\h\s[9]\n\n你，\w5你说什么～～～～。\e"
	}
}}END_CHANGE

