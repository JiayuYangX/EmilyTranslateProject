	}
}}END_CHANGE

//-------------------------------------------------------------------------新2005.6.13/改----.--.--
OnGhostChangeCall_ととたん
{{START_CHANGE
	//Little Witch Tototang
	//Emilio・Teddy用「Totol桑」，Emily用「Tototang」
	when EMS_GC_CHANGING {
		"\u\s[10]\h\s[0]\p2\s[218]接下来，\w5明明只是个魔法使见习生，\w5却比老姐还厉害的Totol桑登场了。\w9\w9\h\s[9]你什么意思啊～！！\w9\w9\u\s[11]…\w5…\w5无法否认这点才是最难受的呢。\w9\w9\h\s[4]\n\n呃～～～。"
		
		"\h\s[0]\u\s[10]Totol桑和%(charname(0))，\w5都会用魔法，\w5又都自称ボク，\w5还挺多共同点的呢。\w9\w9\h\s[5]什么时候有空了想和Tototang一起去玩呢。"
	}
	when EMS_GC_CHANGED,EMS_GC_CLOSED {
		//暂时临时措施，如果有反应再改
		"\u\s[10]\p2\s[200]\h\s[5]Tototang辛苦了～。\w9\w9\u来到陌生的世界还那么坚强地努力真让人佩服呢。\w9\n%(charname(0))也得学着点才行呢。\w9\w9\p2\s[218]老姐只要有红薯的世界哪里都没问题啦。\w9\w9\h\s[9]\n\n唔唔，\w5你什么意思啊。"
	}
	when EMS_GC_CALLING {
		"\h\s[0]\u\s[11]（盯\w5…\w5…）\w9\w9\h\s[8]诶，\w5那个，\w5把我和Tototang比来比去在干嘛呢。\w9\w9\u\n\n…\w5…\w5不管从哪看%(charname(0))都不像姐姐呢。\w9\w9\h\s[4]\n\n诶，\w5呃ー。"
	}
}}END_CHANGE

//-------------------------------------------------------------------------新2005.6.13/改2005.6.23
GCC_Tsukuha_Batu {
	'绑在筑波快线车挡上的刑罚'
	'Max咖啡100瓶一口气喝完的刑罚'
	'被纳豆黏糊糊的刑罚'
}

OnGhostChangeCall_つくは
{{START_CHANGE
	//全员用「桑」。つくは比较年长
	when EMS_GC_CHANGING {
		"\u\s[10]\h\s[5]茨\f[color,255,0,0]城\f[color,default]大使桑，\w5欢迎光临～。\w9\w9\u\s[17]茨・\w5城・\w5！\n\f[height,default]\f[bold,default]\w9\w9\n\s[10]不好好使用正确的名字的话，\w5可是要承受%(GCC_Tsukuha_Batu)的哦。\w9\w9\h\s[2]\n\n哇哇哇，\w5那种惩罚不要啊啊啊啊！"
	}
	when EMS_GC_CHANGED {
		if '干しいも' _in_ change_plain_talk {
			"\u\s[10]\h\s[5]哇～伊，\w5得到红薯干～！\w9\w9\n\s[6]（啊呜，\w5嚼嚼）\w9\w9\u\s[11]刚一拿到手就开始吃，\w5真不检点\w5…\w5…\w9\w9\h\s[9]\n\n（嚼，\w5嚼嚼嚼，\w5嚼嚼，\w5嚼）\w9\w9\u\s[10]\n\n…\w5…\w5怎么了？\w9\w9\h\s[4]\n\n嗯，\w5有点硬。\w9\w9\n…\w5…\w5\s[1]但是好吃，\w5感觉会上瘾。\w9\w9\u\s[11]\n\n啊，\w5这样啊\w5…\w5…"
		}
	}
	when EMS_GC_CLOSED {
		_name = 'つくはさん，\w5みずとさん'
		if RE_SEARCH(reference[1],"\\s\[60\d\d\]") { //6000番台＝霞模式 必须用ref1
			_name = 'つくはさん，\w5かすみさん'
		}
		"\u\s[10]\h\s[5]%(_name)，\w5辛苦了。\w9\w9\u我们所知道的茨城，\w5也就只有筑波而已。\w9\w9\h\s[4]\n\n对不起，\w5我连筑波在哪里也是在听到筑波桑的名字之前才知道的。\w9\w9\u\s[11]\n\n…\w5…\w5每天给我看日本地图。\w9\w9\h\s[4]\n\n呃。\e"
	}
}}END_CHANGE

//-------------------------------------------------------------------------新2005.6.13/改2005.6.27
OnGhostChangeCall_SERION
{{START_CHANGE
	//SERION的日常。
	when EMS_GC_CHANGING {
		"\u\s[10]\h\s[5]换SERION桑了～。\w9\w9\u12号桑和はにふ桑，\w5后面拜托了。\w9\w9\h\s[27]\n\nはにふ桑是什么耳朵呢。\w9\n猫耳\w5…\w5…\w5又太大了。\w9\w9\u\s[11]\n\n别为奇怪的事烦恼了。\e"

		"\u\s[10]\h\s[5]喂，\w5%(charname(1))，\w5我听到了个不得了的事。\w9\w9\u怎么了？\w9\w9\h\n\n据说12号桑的那个嘎吱嘎吱杠杆高速转动的话，\w5就能喷出火焰！\w9\n和我的火焰合起来就是最强了！\w9\w9\u\s[11]\n\n…\w5…\w5从哪听来的那种可疑的话。\e"
	}
	when EMS_GC_CALLING {
		"\u\s[10]\h\s[1]SERION桑\w5…\w5…\w5好大啊。\w9\w9\u什么。\w9\w9\h\n\n大到能夹红薯真让人羡慕啊。\w9\w9\u\s[11]\n\n…\w5…\w5不用夹啦。\e"
	}
	when EMS_GC_CLOSED {
		"\h\s[0]\u\s[10]SERION桑，\w512号桑，\w5はにふ桑辛苦了。\w9\w9\h\s[3]唔～。\w9我也好想要SERION桑的分一点。\w9\w9\u\s[11]\n\n…\w5…\w5什么分一点。\w9\w9\h\s[7]\n\n大家！\w5分给我胸部力量吧！\w9\w9\u\n\n…\w5…\w5\s[10]没有的东西就是没有。\w9\n干脆想开才是关键呢。\w9\w9\h\s[4]\n\n呃呜。\e"
	}
	when EMS_GC_CHANGED {
		if '炎' _in_ change_plain_talk {
			"\u\s[10]\h\s[5]火焰魔法秀！\w9\n第一名，\w5艾米莉出发～！\w9\w9\u\s[12]这又不是表演快停下！\w9\w9\h\s[24]\n\n唔唔唔唔唔\w5…\w5…\w9\n\s[24]呼唔唔唔！！\w9\w9\u\s[-1]\h\s[-1]\n\n（咚────！！！！）\_w[1500]\w9\w9\h\c\s[40]\u\c\s[14]结果又变成这样了呢。\w9\w9\h呃呜。\w5也许差不多快习惯了呢。\w9\w9\u\n\n拜托不要习惯啊。"
		}
	}
}}END_CHANGE

//-------------------------------------------------------------------------新2005.6.15/改----.--.--
OnGhostChangeCall_らんらん
{{START_CHANGE
	//月亮背面的兔子王国
	//酱？桑？需要讨论
	when EMS_GC_CHANGING {
		"\u\s[10]\h\s[0]接下来是兰兰桑和露露桑呢。\w9\w9\u有时候会站在%(username)的肩膀上呢。\w9\w9\h\s[5]\n\n可爱的小兔子二人组呢。\w9\w9\u\s[12]\n\n%(charname(0))！\w9\n口水，\w5口水！！\w9\w9\h\s[2]\n\n啊！？"
	}
	when EMS_GC_CHANGED {
		"\u\s[10]\p2\s[200]\h\s[4]好痛痛痛。\w9\w9\p2\s[204]为什么会被那么小的露露桑打得落花流水啊？\w9\w9\u…\w5…\w5真丢脸。"
	}
}}END_CHANGE

//-------------------------------------------------------------------------新2005.6.15/改----.--.--
OnGhostChangeCall_先生と生徒
{{START_CHANGE
	//老师和学生
	//因为容易和「学生」撞名所以用全名切换
	when EMS_GC_CHANGING {
		"\u\s[10]\h\s[27]闪闪发光的老师？\w9\w9\u不对啦。\w9\w9\h\s[2]\n\n那么是会飞的翻车鱼！？\w9\w9\u\n\n那个也不对啦。\w9\w9\h\s[27]\n\nGhost的「老师」，\w5为什么都是小个子的人呢？\w9\w9\u\s[11]\n\n…\w5…\w5人？"
	}
	when EMS_GC_CHANGED {
		"\u\s[10]\p2\s[-1]\h\s[4]…\w5…\w5…\w5…\w5…。\w9\w9\u啊～，\w5被影响到了呢。\w9\n想不习惯的事情会白头发的哦？\w9\w9\p2\s[205]老姐，\w5买了烤红薯回来了！\w9\w9\h\s[5]\n\n太好了～！\w9\w9\u\s[11]\n\n…\w5…\w5…。"
	}
}}END_CHANGE

//-------------------------------------------------------------------------新2005.6.16/改----.--.--
OnGhostChangeCall_あるみ
{{START_CHANGE
	//Alumi & 礼二郎
	//应该是「桑」吧。
	when EMS_GC_CHANGING {
		"\u\s[10]\h\s[5]好了～，\w5今天又在策划什么事件呢～？\w9\w9\u\s[11]喂，\w5别说那种听起来不好的话。"
	}
	when EMS_GC_CHANGED {
		"\u\s[10]\h\s[4]…\w5…\w5谈了很难的话题呢。\w9\w9\u是啊。\w9\w9\h\s[5]\n\n意外的很厉害呢。\w9\w9\u\s[11]喂，\w5别说「意外」这种失礼的话。"
	}
}}END_CHANGE

//-------------------------------------------------------------------------新2005.6.21/改2005.7.6
OnGhostChangeCall_スナ
{{START_CHANGE
	//屋敷或いは館ベニゾン
	//当然，相手さんのほうが目上です。「さん」
	when EMS_GC_CHANGING {
		"\u\s[10]\h\s[4]…\w5…\w5…\w5…\w5…。\w9\w9\u\s[11]怎么了，\w5突然垂头丧气的。\w9\w9\h\s[3]\n\n虽然有很多事，\w5但首先觉得，\w5能好好控制各种各样的魔术师好厉害啊，\w5然后\w5…\w5…\w9\w9\u\n\n\s[10]…\w5…\w5嘛，\w5像%(charname(0))那样，\w5「天然呆」\w5一切原因不明的谜之\w5「魔法」\w5也没法控制呢。\w9\w9\h\s[4]\n\n唔～。\e"
		
		"\u\s[10]\h\s[27]像砂奈桑那样正规的\w5「魔术」\w5暂且不提，\w5像我这种搞不清楚的东西有什么控制的诀窍吗？\w9\w9\u\s[11]我觉得只会被说别勉强了别再用了。\w9\w9\h\s[4]\n\n唔。\e"
		
		"\u\s[10]\h\s[27]…\w5…\w5那个假牙，\w5能戴上吗？\w9\w9\u\s[11]突然说这么没礼貌的话。\w9\w9\h\s[4]\n\n呃，\w5呃呜，\w5对不起。"
	}
	when EMS_GC_CHANGED {
		if '辛いことがあると大幅に伸びる' _in_ change_plain_talk {
			"\u\s[10]\p2\s[200]\h\s[3]嗯～，\w5魔力在经历痛苦时会大幅增长呢，\w5%(charname(1))。\w9\w9\u%(charname(0))的痛苦会是什么呢？\w9\w9\p2\s[205]比如一个月不能吃红薯相关食物之类的。\w9\w9\h\s[4]\n\n不，\w5不要啊啊啊～～～。\w9\w9\u\s[11]\n\n…\w5…\w5那种事能增长魔力的话谁都不会受苦了呢。"
		}
		elseif '食品表示義務違反' _in_ change_plain_talk {
			"\u\s[10]\p2\s[200]\h\s[8]啊，\w5啊哈哈\w5…\w5…\w9\w9\p2\s[208]嗯～，\w5我觉得跟名字一样很可爱哦？\w5%(charname(1))。\w9\n…\w5…\w5\s[218]只要不开口的话。\w9\w9\u\s[17]你什么意思！！\w9\w9\p2\n\n因为啊，\w5像大叔一样。\w9\w9\h\n\n确实，\w5喜欢下酒菜之类的，\w5感觉跟外表不符呢。\w9\w9\u\n\n…\w5…\w5你们两个，\w5明天开始不许吃布丁和红薯了。\w9\w9\p2\s[202]\h\s[2]\n\n喵啊啊啊啊啊！？"
		}
		elseif '魔法が安定しない' _in_ change_plain_talk {
			"\u\s[10]\h\s[0]\p2\s[205]原来如此，\w5老姐的魔法是赌博啊。\w9\w9\h\s[3]什，\w5什么意思～～～。\w9\w9\u嘛，\w5每次想用火就被卷入爆炸炎上的危机的话，\w5只能说是赌博了呢。\w9\w9\h\s[24]\n\n那是什么意思啊～～～！！\w9\w9\u\s[12]\p2\s[202]\_s[1,2]\n\n！！！！！\_s\_w[1000]\h\s[-1]\u\s[-1]\p2\s[-1]\_w[1500]\p2\s[240]\c\h\s[40]\c\u\s[14]\c…\w5…\w5你看吧。\w9\w9\h呃呜。\w9\w9\p2老姐\w5…\w5…"
		}
	}
	when EMS_GC_CALLING {
		//魔術師共通反応
		GhostCall_Magic('スナさん')
	}
}}END_CHANGE

//-------------------------------------------------------------------------新2005.6.23/改----.--.--
OnGhostChangeCall_カリン
{{START_CHANGE
	//猫娘与狼男
	//Emily用「酱」
	when EMS_GC_CHANGING {
		"\u\s[10]\h\s[5]喵喵喵，\w5喵喵，\w5喵。\w9\w9\u\s[11]…\w5…\w5突然干嘛，\w5真是罕见的猫叫声啊。\w9\w9\h\n\n\s[27]呃～，\w5我在尝试和花凛酱通信呢。\w9\w9\u\n\n两个都能说人话就别那么绕弯子了。\w9\w9\h\s[3]\n\n诶～，\w5可是啊。"
	}
	when EMS_GC_CALLING {
		"\u\s[10]\h\s[5]妖怪猫娘桑召唤～。\w9\w9\u%(charname(0))是猫，\w5花凛桑是妖怪。\w9\w9\n…\w5…\w5\s[11]但是不管怎么看都一模一样吧。\w9\w9\h\s[27]\n\n嗯～，\w5人格桑里有很多猫桑，\w5所以没问题吧。\w9\w9\u\n\n这么随便的结论也行吗？"
	}
	when EMS_GC_CLOSED {
		"\u\s[10]\h\s[5]花凛酱下次见～。\w9\w9\u不管是不是妖怪同样是猫，\w5没法置身事外呢。"
	}
	/*when EMS_GC_CHANGED { //暂时待机中
		
	}*/
}}END_CHANGE

//-------------------------------------------------------------------------新2005.6.23/改----.--.--
OnGhostChangeCall_幸美
{{START_CHANGE
	//幸美与海胆之介
	//用「桑」。
	when EMS_GC_CHANGING {
		"\u\s[10]\p2\s[200]\h\s[5]长野～。\w9\n想去看看呢～。\w9\w9\u多山风景好又凉爽的地方呢，\w5我记得。\w9\w9\p2\s[218]老姐的话，\w5去了也就是到处吃好吃的，\w5怕冷所以大概会在旅馆里蜷缩着吧。\w9\w9\h\s[9]\n\n你，\w5你说什么～。\e"
	}
	when EMS_GC_CALLING {
		"\u\s[10]\h\s[5]长野！\w5武士桑！\w9\n荞麦面！\w5面！\w5的人召唤！！\w9\w9\u\s[11]…\w5…\w5最后那个不是指幸美桑吧。\w9\w9\h\s[3]\n\n…\w5…\w5啊。"
	}
	when EMS_GC_CLOSED {
		"\u\s[10]\h\s[5]长野大使桑，\w5辛苦了～。\w9\w9\u\s[11]…\w5…\w5这样叫可以吗？"
	}
	when EMS_GC_CHANGED {
		if '見えないところが' _in_ change_plain_talk {
			"\u\s[10]\h\s[1]看不见的地方\w5…\w5…\w9\n一定，\w5胸部会变得圆滚滚的吧。\w9\w9\u\s[11]要是有那么好的事谁都不会烦恼了呢。\w9\w9\h\s[4]\n\n呃。"
			
			"\h\s[0]\p2\s[200]\u\s[10]看不见的地方变胖是哪里呢。\w9\w9\p2\s[205]一定是尾巴之类的。\w9\w9\h\s[7]那种地方才不会胖！\w5真是！！\w9\w9\u\n\n谁知道呢？\w9\n不知不觉变得很粗，\w5然后重得往后摔倒\w5…\w5…\w9\w9\h\s[2]\n\n不要啊啊啊！！！"
		}
	}
}}END_CHANGE

//-------------------------------------------------------------------------新2005.6.25/改2005.6.27
OnGhostChangeCall_アマモリ
{{START_CHANGE
	//赚钱计划take2
	when EMS_GC_CHANGING {
		"\u\s[10]\p2\s[205]\h\s[5]天守桑，\w5"
		--
		E.Parallel(0,'红薯',2,'布丁')
		--
		"\_s[0,2]便宜卖的店教教我\_s\h～\p2。\h。\w9\w9\u\s[11]…\w5…\w5你们两个，\w5想的事情都一样呢。\w9\w9\p2\s[214]\n\n…\w5…\w5无法否认。\w9\w9\h\s[4]\n\n唔。\w9\w9\u\s[10]\n\n嘛，\w5每次的伙食费都很厉害，\w5所以确实想问能不能在这方面想想办法。\w9\w9\h\n\n\s[27]是啊～。"
	}
	when EMS_GC_CHANGED {
		if '芋' _in_ change_plain_talk && '魔法は火' _in_ change_plain_talk {
			"\u\s[10]\h\s[0]\p2\s[214]确实是这样呢，\w5那个是问题呢。\w9\w9\u\s[11]作为待在旁边的人，\w5随时可能引火爆炸也不奇怪所以很可怕呢。\w9\w9\h\s[3]你，\w5你什么意思啊。"
		}
		elseif 'きつね' _in_ change_plain_talk {
			"\u\s[10]\h\s[4]是猫啦～～～。\w9\n不是狐狸啦～～～。\w9\w9\u别说是百遍了，\w5感觉遇到的人全都会这么说。\w9\w9\h\s[3]\n\n干脆就当自己是狐狸好了。\w9\w9\u\s[11]\n\n等一下。"
		}
	}
}}END_CHANGE

//-------------------------------------------------------------------------新2005.6.27/改2005.8.3
OnGhostChangeCall_零次
{{START_CHANGE
	//大小姐与虚假的侠客与愉快的仆人们
	when EMS_GC_CHANGING {
		"\u\s[10]\h\s[27]感觉是位什么都会的管家，\w5还有\w5…\w5…\w5好多人呢。\w9\w9\u\s[11]那位管家确实什么都会，\w5但在此之前%(charname(0))也太无能了吧。\w9\w9\h\s[4]\n\n呃。\w9\n好歹我也是SSP导航员得加油才行呢。"
	}
	when EMS_GC_CHANGED {
		if 'やきいも' _in_ change_plain_talk {
			"\u\s[10]\h\s[27]…\w5…\w5…\w5…\w5…？\w9\w9\u怎么了，\w5歪着头。\w9\w9\h\n\n明明没买，\w5不知什么时候烤红薯在这里。\w9\w9\u\n\n又是那位管家贴心带来的吧？\w9\w9\h\s[5]\n\n啊，\w5这样啊，\w5原来如此～。\w9\w9\n\s[6]改天得去道谢才行呢。\e"
		}
	}
	/*when EMS_GC_CALLING { //暂时无法判断所以抑制中
