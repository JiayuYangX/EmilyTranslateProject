		}
		elseif '中継お願い' _in_ change_plain_talk {
			"\p[2]\s[200]\u\s[10]\h\s[5]好～的，\w5现场的艾米莉是也～♪\w9\w9\u\s[11]…\w5…\w5艾米莉？\w9\w9\h\n\n这里，\w5在bugtora农场的红薯地里，\w5现在正在举办挖红薯大赛！\w9\w9\p[2]\s[204]…\w5…\w5老姐，\w5你接收到什么电波了？\w9\w9\h\s[4]\n\n…\w5…\w5搞不懂。\e"
		}
	}
	//when EMS_GC_CALLING {
