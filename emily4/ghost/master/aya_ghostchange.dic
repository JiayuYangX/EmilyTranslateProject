GCC_Dolls_Omiyage
{
	"刚摘的新鲜红薯%(RAND(6)+3)00个"
	"布丁布丁%(RAND(6)+3)00包"
	"零食套装%(RAND(5)+1)年份"
}

OnGhostChangeCall_レティカ
{{START_CHANGE
	//Dolls
	when EMS_GC_CHANGING {
		"\u\s[10]\h\s[27]レティカ桑和ジュナ桑\w5…\w5…\w9\w9\n\s[5]啊，\w5对了，\w5%(username)，\w5把这个当礼物带过去吧。\w9\w9\u\s[11]这个巨大的纸箱是什么。\w9\w9\h\n\n%(GCC_Dolls_Omiyage)！\w9\w9\u\n\n…\w5…\w5碍事。\w5太重了。\w9\w9\h\s[4]\n\n诶～。\e"
	}
	when EMS_GC_CHANGED {
		if RE_SEARCH(change_plain_talk,'みやげは(.+?)な！') {
			_omiyage = RE_GETSTR[1]
			
			if _omiyage == 'テディ' {
				"\u\s[10]\h\s[3]呃，\w5就算说想要%(charname(1))我也没办法啊。\w9\w9\u非卖品。\w9\n带附加价值的。\w9\w9\n…\w5…\w5\s[11]很贵哦？\w9\w9\h\s[4]\n\n什么啊～～～。\e"
			}
			elseif _omiyage == 'エミリのリボン' {
				"\u\s[10]\h\s[5]说想要蝴蝶结呢。\w9\n一定是想送给レティカ酱当礼物吧。\w9\w9\u有好几个吧？\w9\n送一个也没关系吧。\w9\w9\h\n\n嗯！\w5下次送给她。\e"
			}
			elseif _omiyage == 'エミリの鈴' {
				"\u\s[10]\h\s[5]需要铃铛吗～。\w9\n那么，\w5一共%(RAND(9)+1)亿%(RAND(9)+1)千万日元。\w9\w9\u\s[12]好贵！\w5什么啊！！\w9\w9\h\s[8]\n\n开玩笑开玩笑。\w9\w9\n\s[6]话说回来，\w5这是重要的铃铛不能给哦。\w9\n\s[0]对不起啦。\w9\w9\u\s[10]\n\n嘛，\w5各种原因啦。\e"
			}
			elseif 'プリン' _in_ _omiyage {
				"\u\s[10]\h\s[0]\p2\s[205]啊，\w5是想要布丁啊。\w9\w9\n…\w5…\w5\s[218]不给。\w9\w9\h\s[3]%(charname(2))真小气。\w9\w9\u这种时候，\w5通常应该说一起吃什么之类的话吧。\w9\w9\h\s[28]\n\n%(charname(2))也还只是个孩子呢。\w9\w9\p2\s[217]\n\n老姐你才是一年到头看到红薯就两眼放光呢。\w9\w9\h\s[9]\n\n你，\w5你说什么～～～。\e"
			}
			elseif '焼きイモ' _in_ _omiyage {
				"\u\s[10]\h\s[5]啊，\w5是想要烤红薯啊。\w9\n下次一起吃吧～。\w9\w9\u和平时那个贪吃的%(charname(0))简直判若两人呢。\w9\w9\h\s[9]\n\n谁，\w5谁贪吃啊！！\e"
			}
		}
	}
}}END_CHANGE

//-------------------------------------------------------------------------新2005.5.11/改2005.7.31
GCC_MML_Panchu_Color
{
	'淡蓝色'
	'粉色'
	'蓝色'
	'绿色'
}

OnGhostChangeCall_ミディ
{{START_CHANGE
	//MML
	when EMS_GC_CHANGING {
		"\u\s[10]\h\s[2]啊啊！！\w9\w9\u\s[11]怎么了，\w5突然吓一跳。\w9\w9\h\s[4]\n\n又被偷看内裤了～。\w9\w9\u\n\n…\w5…\w5又？"
		
		"\u\s[10]\h\s[0]\p2\s[202]老姐老姐！\w9\n听到了个奇怪的传闻！！\w9\w9\h\s[3]唔～？\w5什么奇怪的传闻？\w9\w9\p2\n\n据说坏孩子半夜会有Midi小姐出现，\w9\n在枕边念叨「印刷电路板一张，\w5两张\w5…\w5…\w9\n　果然少了一张\w5…\w5…」\w9\n来惩罚你喔！\w9\w9\h\s[2]\n\n喵啊啊啊啊啊啊！？\w9\w9\u\s[11]…\w5…\w5番町电路板屋敷？"
	}
	when EMS_GC_CHANGED {
		if '今日のエミリは何色かな' _in_ change_plain_talk {
			"\u\s[10]\h\s[9]唔～～～。\w5咕噜噜。\w9\w9\u\s[11]怎么了，\w5一脸害怕的样子。\w9\w9\h\n\n\s[3]那只每次见面都想偷看我内裤的猫，\w5怎么办啊。\w9\w9\u\n\n\s[10]得告诉Midi小姐让她好好管教一下才行呢。\w9\w9\n比如说，\w5\f[color,255,0,0]%((RAND(8)+1)*100)kW\f[color,default]的烙铁什么的。\w9\w9\h\s[4]\n\n什么啊那是～～。\e"
			
			"\u\s[10]\h\s[3]…\w5…\w5今天是%(GCC_MML_Panchu_Color)色。\w9\w9\u\s[11]什么是。\w9\w9\h\s[4]\n\n那个啊，\w5既然总是被偷看内裤，\w5还不如我先说出来比较好。\w9\w9\u\n\n…\w5…\w5我觉得不会有什么改变就是了。\w9\w9\h\n\n诶～～～。\e"
		}
		elseif RE_SEARCH(change_plain_talk,'[1-9]00[kK][wW]級(.+?)「.+?」') {
			_name = RE_GETSTR[0]
			_type = RE_GETSTR[1]
			
			"\u\s[10]\h\s[8]\_a[GHOST_所長たん]所长，\_a\w5竟然做出了%(_name)这种东西啊。\w9\w9\u\s[11]…\w5…\w5我很好奇为什么要特地做个巨大的%(_type)出来。\w9\w9\h\s[4]\n\n这个一定是不能说的秘密啦。\w9\w9\u\n\n…\w5…\w5…\w5…\w5…。"
		}
	}
	when EMS_GC_CALLING {
		"\u\s[10]\h\s[0]\p2\s[205]啊，\w5\f[strike,true] 说明阿姨 \f[strike,default]说明姐姐好像要来了呢。\w9\w9\h\s[3]%(charname(2))，\w5我刚才好像听到了什么失礼的话\w5…\w5…\w9\w9\p2\s[208]\n\n诶？\w5我什么都没说啊？\w9\w9\u\s[11]…\w5…\w5被烙铁烫我可不管哦。"
	}
	when EMS_GC_CLOSED {
		"\u\s[10]\h\s[5]Midi小姐，\w5辛苦了。\w9\w9\u来%(charname(0))，\w5趁着Midi小姐不在，\w5先搜查一下那只变态猫有没有混进家里吧。\w9\w9\h\s[4]\n\n…\w5…\w5唔。"
	}
}}END_CHANGE

//-------------------------------------------------------------------------新2005.5.11/改----.--.--
OnGhostChangeCall_あすね
{{START_CHANGE
	//护士预备生
	when EMS_GC_CHANGING {
		"\u\s[10]\p2\s[204]\h\s[4]医，\w5医院啊。\w9\w9\u怎么了你们两个，\w5一脸害怕的样子。\w9\n去医院也没什么大不了的啦。\w9\w9\h\n\n那个啊%(charname(1))，\w5其实，\w5\_s[0,2]之前身体不舒服去医院，\w5\_s" + E.Parallel(0,'红薯',2,'布丁') + "\_s[0,2]被说吃太多了\w5…\w5…\_s\w9\w9\u\n\n\s[11]…\w5…\w5一定都被好好记在病历上了。\w9\w9\h\n\n骗人～～～。\w9\w9\p2\n\n和老姐一个级别\w5…\w5…\e"
	}
	when EMS_GC_CHANGED {
		"\u\s[10]\h\s[3]%(username)也要小心，\w5不要哪天发现护理记录上写着红薯吃太多了哦。\w9\w9\u\s[11]会被写那种东西的只有%(charname(0))啦。\e"
	}
}}END_CHANGE

//-------------------------------------------------------------------------新2005.5.18/改----.--.--
OnGhostChangeCall_はうす
{{START_CHANGE
	//Heibel Haus炭
	when EMS_GC_CHANGING {
		"\u\s[10]\h\s[5]啊，\w5对了对了。\w9\w9\u怎么了？\w9\w9\h\s[27]\n\n之前，\w5\_a[GHOST_所長たん]所长\_a在找能不能弄到适合新研究所的建筑来着。\w9\w9\u\n\n什么条件？\w9\w9\h\n\n…\w5…\w5\s[4]说是外观要尽可能可疑，\w5屋顶能打开，\w5还得有能发出「嗨～」声音的装置才行。\w9\w9\u\s[11]\n\n…\w5…\w5那个，\w5你是真心想找吗？\e"
	}
	when EMS_GC_CHANGED {
		if 'ちみっこい娘' _in_ change_plain_talk {
			"\h\s[0]\u\s[11]…\w5…\w5连SSP导航员的正常工作都做不好，\w5只知道吃红薯的，\w5小不点猫就请大家多关照了。\w9\w9\h\s[4]%(charname(1))好残酷。\e"
		}
	}
}}END_CHANGE

//-------------------------------------------------------------------------新2005.5.18/改2006.5.6
OnGhostChangeCall_くろやぎ
{{START_CHANGE
	//ＲＯＡＭＩＮＧ＊ＫＩＤ ～两只小山羊～
	when EMS_GC_CHANGING {
		"\u\s[10]\h\s[5]%(charname(0))酱的最新情报！\w9\w9\u\s[11]突然干嘛。\w9\w9\h\s[27]\n\n从别人那听说的，\w5念%(henihohoho)的话好像能长出山羊耳来。\w9\w9\u\n\n…\w5…\w5那个，\w5你真的觉得能行吗？\w9\w9\h\s[4]\n\n…\w5…\w5我已经试过不行了，\w5但是想着也许有人能做到。\w9\w9\u\n\n…\w5…\w5…\w5…\w5…。"
	}
	when EMS_GC_CHANGED {
		if 'ねこみみ' _in_ change_plain_talk && '先輩' _in_ change_plain_talk {
			"\u\s[10]\h\s[1]…\w5…\w5说是猫耳前辈呢。\w9\n真不好意思啊。\w9\w9\u…\w5…\w5既然是前辈，\w5就得拿出前辈的样子来才行呢。\w9\w9\h\s[4]\n\n呃呃。\w5我会注意的。"
		}
		elseif 'バケツプリン' _in_ change_plain_talk {
			"\u\s[10]\h\s[0]\p2\s[205]说是桶装布丁的魔法诶！\w9\n老姐，\w5去学了做给我看嘛！\w9\w9\h\s[8]啊哈哈\w5…\w5…\w9\w9\n\s[4]那么难的我才做不到，\w5我替你做个普通布丁所以忍耐一下吧。\w9\w9\p2\s[203]\n\n切～。\w9\w9\u\s[11]…\w5…\w5禁止把魔法用在奇怪的地方。"
		}
		elseif '伺か胸ぺたい同盟' _in_ change_plain_talk {
			"\u\s[10]\p2\s[200]\h\s[9]才不平呢！\w5好好的！！\w9\n总之比那山羊们要大！！\w9\w9\u\s[11]…\w5…\w5不，\w5跟男生较什么劲啊你。\w9\w9\p2\s[214]老姐为什么要在意这种事啊。\w9\w9\h\s[3]\n\n唔，\w5反正男生是不会懂这种心情的啦。"
		}
		elseif '魔法なら負けないよ' _in_ change_plain_talk {
			"\u\s[14]\p2\s[240]\h\s[40]♪从\w1黑\w1山\w1羊\w1那\w1里\w5　得\w1到\w1了\w1魔\w1法\w9\w9\p2♪却\w1怎\w1么\w1也\w1弄\w1不\w1好\w5　冒\w1着\w1烟\w1就\w1燃\w1了\w9\w9\u…\w5…\w5燃起来了呢。\w9\w9\h\n\n呃呃。\w9\w9\p2\n\n为什么会被卷进去啊\w5…\w5…\w9\w9\u\n\n火焰魔法请有计划地使用。"
		}
		elseif 'ニーソ使い' _in_ change_plain_talk {
			"\u\s[10]\p2\s[200]\h\s[3]对不起啦～。\w9\n过膝袜早就塞进壁橱深处了，\w5不知道扔哪去了\w5…\w5…\w9\w9\p2好久之前就没穿了呢。\w9\w9\u为什么不穿了呢？\w9\w9\h\s[8]\n\n嗯～，\w5觉得和现在的衣服不搭。\w9\w9\u\n\n这样啊。"
		}
		elseif 'キング・オブ・ハート' _in_ change_plain_talk {
			"\u\s[10]\h\s[5]King of SSP我现在也在做哦！\w9\w9\u\s[11]…\w5…\w5感觉哪里不对。\w9\w9\h\s[7]\n\n这个SSP被我占领了！\w9\w9\u\n\n\_a[GHOST_所長たん]…\w5…\w5我要去告诉所长\_a了哦。\w9\w9\h\s[2]\n\n哇哇哇！\w5对不起对不起！！"
		}
		elseif 'かわいくていいなあ' _in_ change_plain_talk && '服' _in_ change_plain_talk {
			"\u\s[10]\p2\s[200]\h\s[1]说我可爱\w5…\w5…\w5真不好意思呢。\w9\w9\u嘛，\w5衣服是挺可爱的啦。\w9\w9\p2\s[218]老姐先不说，\w5衣服倒是挺可爱的。\w9\w9\h\s[9]\n\n你，\w5你，\w5你什么意思啊～～～！！"
		}
	}
	when EMS_GC_CALLED {
		if 'クイーン・オブ' _in_ change_plain_talk || 'しまぱんの女王様' _in_ change_plain_talk {
			"\u\s[10]\p2\s[200]\h\s[5]SSP的女王～登～～场。\w9\n然后是家臣1和家臣2。\w9\w9\p2\s[207]…\w5…\w5不知什么时候就被擅自当成家臣了。\u在把别人叫家臣之前，\w5%(charname(0))自己还得再争气点才行啊。\w9\w9\h\s[4]\n\n呜呜，\w5对不起～。"
		}
		elseif 'おびき寄せる' _in_ change_plain_talk {
			"\u\s[10]\p2\s[200]\h\s[5]哇～伊，\w5烤红薯烤红薯～。\w9\n（吧唧吧唧）\w9\w9\u\s[11]…\w5…\w5被引诱出来了呢。\w9\w9\p2\s[214]这么简单的陷阱也会上当啊。"
		}
		elseif '小っちゃいしろ' _in_ change_plain_talk {
			"\u\s[10]\h\s[0]\p2\s[218]光吃红薯胖得圆滚滚的硕大红薯老姐也会跟着来的。\w9\w9\h\s[9]艾・\w5米・\w5利・\w5欧～～～！"
		}
	}
	when EMS_GC_CLOSED {
		"\u\s[10]\h\s[5]山羊耳结～束～。\w9\w9\u\s[11]我可没长山羊耳啦。"
	}
}}END_CHANGE

