		}
	}
}}END_CHANGE

//-------------------------------------------------------------------------新2005.7.21/改----.--.--
OnGhostChangeCall_ソア
{{START_CHANGE
	//Soa和小人桑
	//Soa当然知道，Temperance也感觉到，但Emily/Emilio没有意识到"H"。
	//Teddy好像隐约察觉到了什么……
	when EMS_GC_CLOSED {
		"\u\s[10]\h\s[5]Soa桑辛苦了。\w9\n好好休息哦。\w9\w9\u…\w5…\w5辛苦了。"
	}
	when EMS_GC_CALLING {
		"\u\s[10]\h\s[27]嗯～，\w5会怎么样呢。\w9\w9\u你在想什么呢%(charname(0))。\w9\w9\h\s[5]\n\n啊，\w5%(charname(1))～。\w9\n\s[27]和Soa桑总是在一起的Temperance桑，\w5果然也是天使中的一位吗？\w9\w9\u\n\n…\w5…\w5嘛，\w5实质上当作守护天使来看也没问题吧。\w9\w9\h\n\n这样啊，\w5守护天使桑啊。\w9\n\s[3]我的身边也有吗。\w9\w9\u\s[11]\n\n虽然有点奇怪，\w5\_a[GHOST_所長たん]可是一年到头旁边就有一个天使\_a\w5…\w5…。"
	}
	when EMS_GC_CHANGING {
		//啊啊！那边，别扔石头！！
		"\u\s[10]\h\s[5]Soa桑，\w5Tempuransu桑，\w5后面拜托了～。\w9\w9\u\s[11]…\w5…\w5我刚才好像听到了奇怪的称呼方式。\w9\w9\h\s[8]\n\n啊，\w5啊哈哈，\w5我明明说的是Temperance桑。\w9\w9\u\n\n…\w5…\w5可疑。\w5非常可疑。\w9\w9\h\s[4]\n\n呃，\w5呃。"
		
		"\u\s[10]\h\s[27]嗯～，\w5好漂亮啊～。\w9\w9\u你在干嘛呢%(charname(0))。\w9\w9\h\s[5]\n\n啊，\w5\_a[GHOST_所長たん]所长\_a的书架上有矿石图鉴我在看来着。\w9\w9\u\n\n下次让Soa桑给你看实物不就行了？\w9\w9\h\n\n是啊～。"
	}
	when EMS_GC_CHANGED {
		if 'ルックス' _in_ change_plain_talk {
			"\u\s[10]\p2\s[200]\h\s[1]呼呼呼。\w5连女孩子都认可的这个长相。\w9\n\s[5]怎么样有没有稍微重新认识一下我啊%(charname(2))～。\w9\w9\p2\s[218]要不是因为光吃红薯产生的气体排放的话就完美了。\w9\w9\h\s[3]\n\n呜呜。\w5不准说那个～。\w9\w9\u\s[11]自作自受啦。"
		}
	}
}}END_CHANGE

//-------------------------------------------------------------------------新2005.7.21/改2005.7.24
OnGhostChangeCall_雪乃
{{START_CHANGE
	//狐狸之诗
	when EMS_GC_CALLING {
		"\u\s[10]\h\s[5]雪乃桑铃叶桑快来～。\w9\n和雪乃桑组成被搞错组合～。\w9\w9\n…\w5…\w5\s[4]呃。\w9\w9\u被当成狐狸的猫，\w5和被当成猫的狐狸桑\w5…\w5…\w9\n嘛，\w5并排站的话本来就是同类所以也没办法呢嗯。\w9\w9\h\n\n你，\w5你理解了什么啊。"
	}
	when EMS_GC_CLOSED {
		"\u\s[10]\h\s[6]雪乃桑，\w5铃叶桑，\w5辛苦了。\w9\w9\u请继续享受像狐狸一样的猫娘服务。\w9\w9\h\s[4]\n\n不，\w5不要享受啊～～～。"
	}
	when EMS_GC_CHANGING {
		"\u\s[10]\h\s[5]雪乃桑，\w5铃叶桑。\w9\n\s[27]嗯～～～\w5…\w5…\w9\n\s[3]我经常被误认为是狐狸，\w5要怎样才能让人知道是猫呢？\w9\w9\u\s[11]…\w5…\w5你那个问题偏偏要去问雪乃桑？\w9\w9\h\s[4]\n\n可，\w5可是，\w5这真的很迫切啊。\w9\w9\u\n\n…\w5…\w5到底哪里迫切了。"
	}
	when EMS_GC_CHANGED {
		if '私たちと同族なのかな' _in_ change_plain_talk {
			"\u\s[10]\h\s[4]唔～。\w9\n我，\w5决定以后就作为狐狸活下去了。\w9\w9\u\s[11]…\w5…\w5想吃狐狸乌冬面。\w9\w9\h\s[5]\n\n啊～，\w5这样啊，\w5那明天晚饭就吃那个吧。\w9\w9\u\s[10]\n\n…\w5…\w5要作为狐狸活下去修行还远远不够呢。\w9\w9\h\s[27]\n\n？？？？？"
		}
	}
}}END_CHANGE

//-------------------------------------------------------------------------新2005.7.21/改2005.9.23
OnGhostChangeCall_Firefox
{{START_CHANGE
	//Firefox碳（fox子以外的什么）
	when EMS_GC_CHANGING {
		"\u\s[10]\h\s[0]\p2\s[205]老姐老姐。\w9\w9\h\s[5]嗯～？\w5怎么了%(charname(2))～～？？\w9\w9\p2\n\n我想到了让老姐被更多人认识的好方案。\w9\w9\u会想出什么呢。\w9\w9\p2\n\n呃～，\w5拜托叫Mozilla Foundation的组织，\w5做个叫FireCat的浏览器怎么样。\w9\w9\u\s[11]\n\n…\w5…\w5驳回。\w9\w9\h\s[8]\n\n啊，\w5啊哈哈\w5…\w5…。"
	}
	when EMS_GC_CHANGED {
		if 'よく燃えそうだね' _in_ change_plain_talk {
			"\u\s[10]\p2\s[200]\h\s[5]哇～伊，\w5烤红薯烤红薯～。\w9\nFirefox桑和火属性大火力！\w9\n要烤～～～很多很多哦！\w9\w9\u\s[11]然后就是烤太多吃不完处理不了的结局呢。\w9\w9\p2\s[204]以老姐的性格，\w5感觉会把装满红薯的纸箱整个扔进火力超强的地方。\w9\w9\h\s[9]\n\n才不会呢！\w5真是！！"
		}
		elseif '取って喰われる' _in_ change_plain_talk {
			"\u\s[10]\p2\s[200]\h\s[7]才不会抓来吃！\w9真是！！\w9\w9\u\s[11]…\w5…\w5啊～，\w5为了不被%(charname(0))吃掉，\w5看到你好像饿的时候就拿烤红薯去糊弄你，\w5我日夜都非常努力呢。\w9\w9\h\s[4]\n\n所，\w5所以说～～～。\w9\w9\p2\s[204]嘛，\w5如果猫在火「鼠」旁边的话，\w5谁都会想些什么的吧。\w9\w9\h\s[3]\n\n唔～～～。"
		}
	}
	when EMS_GC_CALLING {
		"\u\s[10]\h\s[5]FireFox桑启动～。\w9\w9\n\s[27]旁边的ThunderBird桑，\w5果然会变成特快列车去富山什么的吗。\w9\w9\u\s[11]禁止用这种烂梗。\w9\w9\h\s[4]\n\n呃，\w5呃。\e"
	}
	when EMS_GC_CALLED {
		if '野ねずみなどを取って食う' _in_ change_plain_talk {
			"\h\s[0]\p2\s[200]\u\s[12]！！！！！\w9\w9\h\s[8]怎，\w5怎么了，\w5突然慌张起来。\w9\w9\u\s[11]\n\n总觉得感觉到了杀气和我食欲\w5…\w5…\w9\w9\h\s[3]\n\n怎么可能。\w5我可是一点都没有想过要把%(charname(1))用炭火蘸着酱烤来吃哦？\w9\w9\p2\s[204]…\w5…\w5那什么具体得奇怪的吃法。\w9\w9\u\n\n…\w5…\w5\s[17]呷～～～！！！\w9\h\s[2]\n\n啊啊啊！？"
		}
	}
	when EMS_GC_CLOSED {
		"\u\s[10]\h\s[5]FireFox桑和ThunderBird桑结束～。\w9\w9\u\s[11]\_q[警告]\_l[40]这个进程没有响应。\n\_l[40]要强制结束吗？\_q\w9\w9\h\s[2]\n\n诶っ！？\w5诶诶っ！？"
	}
}}END_CHANGE

//-------------------------------------------------------------------------新2005.7.27/改----.--.--
OnGhostChangeCall_Hand
{{START_CHANGE
	//The Hand
	when EMS_GC_CHANGING {
		"\u\s[10]\h\s[4]要，\w5交接了\w5…\w5…\w9\n\s[3]真的可以吗～？\w9\w9\u\s[11]今天又有可疑左手的受害者了\w5…\w5…"
	}
	when EMS_GC_CHANGED {
		if 'エミリオの方が好み' _in_ change_plain_talk {
			"\u\s[10]\h\s[0]\p2\s[202]咦，\w5我，\w5我更好吗？\w9\w9\h\s[3]唔～，\w5%(charname(2))那边更好呢～。\w9\w9\u\s[11]…\w5…\w5你们两个，\w5会相信那种可疑的手说的话吗？"
		}
		else {
			"\u\s[10]\h\s[3]唔～，\w5%(username)不会像那只手一样乱摸吧？\w9\w9\u\s[17]不可堕入Hand的黑暗面！\w9\w9\h\s[8]\n\n喂，\w5%(charname(1))？？"
		}
	}
	when EMS_GC_CALLED {
		"\u\s[10]\p2\s[204]\h\s[4]…\w5…\w5被带到了有怪东西的地方\w5…\w5…\w9\w9\u\s[11]…\w5…\w5好奇怪的手啊。\w9\n听说最近在搞无差别猥琐事件。\w9\w9\p2不太想和它待在一起啊。"
	}
	when EMS_GC_CALLCOMPLETE {
		"\u\s[10]\h\s[4]…\w5…\w5有，\w5有种奇怪的家伙来了\w5…\w5…\w9\w9\u\s[11]啊～，\w5那个不太妙啊。"
	}
	when EMS_GC_CLOSED {
		"\u\s[10]\p2\s[204]\h\s[4]呼，\w5它总算走了\w5…\w5…\w9\w9\p2果然有那种怪手在就没法安心啊。\w9\w9\u\s[11]…\w5…\w5说不定什么时候被复制一大堆启动起来。\w9\h\s[2]\n\n喵啊啊啊啊啊！？"
	}
}}END_CHANGE

//-------------------------------------------------------------------------新2005.7.27/改----.--.--
OnGhostChangeCall_ちゃこ
{{START_CHANGE
	//茶子和托尔
	when EMS_GC_CHANGING {
		"\u\s[10]\h\s[5]汪汪～。\w5汪。\w9\n尾巴啪嗒啪嗒。\w9\w9\u\s[11]…\w5…\w5你在干什么。\w9\w9\h\n\n在跟茶子酱打招呼。\w9\w9\u\n\n…\w5…\w5话说，\w5%(charname(0))你，\w5好歹，\w5是猫吧？"
	}
	/*when EMS_GC_CHANGED {
	}*/
	when EMS_GC_CALLING {
		"\u\s[10]\h\s[5]茶子酱，\w5托尔桑呀吼～！\w9\w9\u…\w5…\w5你们两个明明是狗，\w5不会追猫吧。\w9\w9\h\s[3]\n\n茶子酱不会做那种事的～。\w9\w9\u\s[11]\n\n…\w5…\w5真的吗。"
	}
	when EMS_GC_CLOSED {
		"\u\s[10]\h\s[4]啊～，\w5茶子酱和托尔桑，\w5回去了啊。\w9\w9\u你好像很遗憾呢。\w9\w9\h\s[1]\n\n明明超喜欢蹭托尔桑的毛茸茸身体的。\w9\w9\u\n\n\s[11]…\w5…\w5禁止毛茸茸。\w9\h\s[4]\n\n诶～。"
	}
}}END_CHANGE

//-------------------------------------------------------------------------新2005.7.31/改2005.8.6
OnGhostChangeCall_コノハ
{{START_CHANGE
	//名古屋大使
	when EMS_GC_CHANGING {
		"\u\s[10]\h\s[5]接下来是木叶酱。\w9\w9\u忍者同伴让人安心啊。\w9\n下次，\w5让她当前卫保护我们吧。\w9\w9\h\s[8]\n\n不过我又没计划去下迷宫啊～。"
		
		if GetMonthSlot == 'summer' {
			"\u\s[10]\h\s[27]想带虎鲸丸去游泳呢～。\w9\w9\u那又不是游泳圈，\w5会闹翻天的。\w9\w9\h\s[5]\n\n只要不说谁知道啊。\w9\w9\u\s[11]\n\n…\w5…\w5就怕是认真的才让人担心啊。"
		}
		else {
			"\u\s[10]\p2\s[200]\h\s[27]唔～，\w5到底在哪呢。\w9\w9\u怎么了？\w5那么烦恼。\w9\w9\h\n\n我在想虎鲸丸的\f[bold,true]气孔\f[bold,default]在哪里。\w9\w9\p2\s[205]对对。\w9一定，\w5粗暴对待的话就会噗咻～地漏气吧。\w9\w9\u\s[11]\n\n…\w5…\w5那又不是夏天的游泳圈。"
		}
		
		"\u\s[10]\p[2]\s[200]\h\s[5]啊，\w5是木叶酱。\w9\n所长酱正在逃避制造bug中，\w5帮我抓住她哦。\w9\w9\p[2]\s[203]老姐，\w5别推给人麻烦事啊。\w9\w9\u\s[11]啊，\w5别弄死就行带过来哦。\w9\n还有很多活要让她干呢。\w9\w9\p[2]\s[204]\n\n…\w5…\w5连泰迪都。"
	}
	when EMS_GC_CHANGED {
		if '焼け石' _in_ change_plain_talk {
			"\u\s[10]\h\s[6]烧石\w5…\w5…\w5是石烤红薯呢。\w9\n用正统的烤法，木叶酱很懂嘛。\w9\w9\u\s[11]…\w5…\w5不，\w5她懂什么了。\w9\w9\h\s[5]\n\n总之烤好了给我～～～。\w9\w9\u\n\n那才是真心话吧。"
		}
	}
	when EMS_GC_CALLING {
		"\u\s[10]\p2\s[200]\h\s[24]♪燃烧系～\w9\w9\u\s[12]燃烧系？\p2\s[202]！？\w9\w9\w9\u\s[14]\p2\s[240]\h\s[40]\n\n♪木～\w5叶酱～\w9\w9\p2\n\n这种生活我不要啊～。"
		
		"\u\s[10]\h\s[55]木叶酱，\w5欢迎光临。\w9\n不巧咖啡不附带早餐，\w5请慢用。\w9\w9\u名古屋的咖啡店，\w5好像一整天都强制附带早餐呢。"
	}
	when EMS_GC_CLOSED {
		"\u\s[10]\h\s[2]消失了！！\w9\w9\u\s[12]忍法！？"
		
		"\u\s[10]\h\s[27]啊，\w5走了。\w9\w9\s[5]\n接下来两人要去约会吗？\w9\w9\u…\w5…\w5她说过不是那种关系哦。\w9\n不是修行吗？\w9\w9\h\s[21]\n\n嘿～，\w5是不被允许的禁断之爱啊。\w9\w9\u\s[11]\n\n艾米莉，\w5你在听吗？"
	}
}}END_CHANGE

//-------------------------------------------------------------------------新2005.7.31/改----.--.--
OnGhostChangeCall_笛羽
{{START_CHANGE
	//笛羽&E7-Ax
	/*when EMS_GC_CHANGING {
	}*/
	when EMS_GC_CHANGED {
		"\u\s[10]\p2\s[200]\h\s[5]啊，\w5是笛羽桑～。\w9\n%(charname(2))的零食布丁，\w5想放在旁边的冰箱里冰一下。\w9\w9\u\s[11]所以说，\w5那不是冰箱啦。\w9\w9\h\s[3]\n\n诶～，\w5我还觉得有会说话的高科技冰箱好羡慕呢～。\w9\w9\p2\s[204]老姐\w5…\w5…\w5说那种话会被开发E7-Ax的人骂哦？\w9\w9\h\s[4]\n\n啊呜。"
	}
}}END_CHANGE

//-------------------------------------------------------------------------新2005.7.31/改2005.8.1
OnGhostChangeCall_○_￣_
{{START_CHANGE
	//大后悔时代 ○|￣|_
	when EMS_GC_CHANGING {
		"\u\s[10]\p2\s[214]\h\s[4]红薯吃太多体重增加了○|￣|_\w9\w9\p2布丁吃太多肚子不舒服orz\w9\w9\u\s[11]…\w5…\w5你在干嘛。\w9\w9\h\s[5]\n\n在模仿接下来要出现的人～。\w9\w9\p2\s[204]\n\n老姐那个不是开玩笑而是事实吧。\w9\w9\h\s[3]\n\n唔，\w5不准说那种话～。"
	}
	when EMS_GC_CHANGED {
		if '案の定食われた' _in_ change_plain_talk {
			"\u\s[10]\p2\s[200]\h\s[9]才，\w5才不是我吃的呢！\w9\w9\u\s[11]…\w5…\w5不用那么大声说也行。\w9\w9\p2\s[218]拼命辩解这点，\w5很可疑啊。\w9\w9\h\n\n真的没吃啦！！"
		}
	}
	when EMS_GC_CALLING {
		"\u\s[10]\h\s[3]嗯～，\w5别老是\w5○|￣|_\w5的，\w5能打起精神来就好了。\w9\w9\u\s[11]…\w5…\w5不，\w5要是打起精神来了作为人格就不妙了吧。"
	}
	when EMS_GC_CALLED {
		if '虫歯になった' _in_ change_plain_talk {
			"\u\s[10]\p2\s[200]\h\s[6]为了健康请注意不要吃太多红薯。\w9\w9\u\s[11]%(charname(0))也是哦。\w9\w9\p2\s[218]你也没资格说别人吧。\w9\w9\h\s[4]\n\n呃。\w5得注意才行呢。"
		}
	}
	when EMS_GC_CLOSED {
		"\u\s[10]\h\s[8]啊啊\w5…\w5…\w9\n今天也垂头丧气的呢。\w9\w9\u什么时候才能振作起来呢。\w9\w9\h\s[4]\n\n谁，\w5谁知道呢\w5…\w5…"
	}
}}END_CHANGE

//-------------------------------------------------------------------------新2005.7.31/改----.--.--
OnGhostChangeCall_美紅
{{START_CHANGE
	//美红&小纶
	when EMS_GC_CHANGING {
		"\u\s[10]\p2\s[200]\h\s[6]接下来是美红桑。\w9\n\s[3]我也想要那个头发上像大装饰一样的东西。\w9\w9\p2\s[204]老姐，\w5本来就戴着大蝴蝶结了，还是别再添更多了吧。\w9\w9\u而且那个，\w5其实有传闻说是军方秘密开发的特殊兵器哦。\w9\w9\h\s[2]\n\n诶诶！！\w5原来是那么重要的东西吗！！"
	}
	when EMS_GC_CHANGED {
		if 'やきいもオ・レ' _in_ change_plain_talk {
			"\u\s[10]\p2\s[200]\h\s[5]哇喔～，\w5是烤红薯烤红薯！\w9\w9\p2\s[204]…\w5…\w5这是什么。\w9\w9\u\s[11]怎么说呢，\w5硬要把固体的东西做成饮料，\w5没想到会变成这么危险的东西啊。\w9\w9\h\s[3]\n\n诶～，\w5明明很好喝的～。\w9\w9\p2\s[214]\n\n只有老姐你会这么说啦。\w9\w9\h\s[4]\n\n唔～。"
		}
	}
	when EMS_GC_CALLING {
		"\u\s[10]\h\s[5]啊，\w5鲸鱼桑～。\w9\n水噗～地喷，\w5噗～地喷！\w9\w9\u\s[11]禁止玩水。\w9\w9\h\s[3]\n\n诶～。\w5明明很好玩。"
		
		"\u\s[10]\h\s[27]美红桑的口袋，\w5到底装了什么呢。\w9\w9\n\s[5]要是装了红薯和布丁就好了呢！！\w9\w9\u啊～，\w5其实有传闻说那是潘多拉的口袋，\w5可别去玩哦。\w9\w9\h\s[2]\n\n什，\w5什，\w5什么─────！！！"
	}
	when EMS_GC_CLOSED {
		"\u\s[10]\h\s[5]美红桑，\w5辛苦了～。\w9\w9\u旁边的小纶也很不容易呢。\w9\n一定是为了照顾美红桑而在没有水的地方一直飘着吧。\w9\w9\n…\w5…\w5彼此彼此，\w5当麻烦孩子的监护人真辛苦啊。\w9\w9\h\s[3]\n\n那个，\w5是什么意思～。"
	}
}}END_CHANGE

//-------------------------------------------------------------------------新2005.8.1/改----.--.--
OnGhostChangeCall_芽生
{{START_CHANGE
	//芽生酱和普尼
	when EMS_GC_CHANGING {
		"\u\s[10]\h\s[3]芽生酱\w5…\w5…\w5那个啊。\w9\n我这边\_a[GHOST_小夜]经常有小夜酱那个幽灵来\_a的\w5…\w5…\w9\w9\u确实挺多的呢。\w9\w9\h\n\n我在想她是不是也会把小夜酱给消灭掉呢。\w9\w9\u\n\n与其说消灭\w5…\w5…\w5嘛，\w5不管具体情况如何，\w5让她成佛是有必要的吧。\w9\w9\h\s[4]\n\n诶～。\w9\w9\u\s[11]\n\n不，\w5你在遗憾什么啊。"
		
		"\u\s[10]\p2\s[200]\h\s[27]%(charname(1))。\w5听说像芽生酱那样的灵媒师的力量也是一种魔法哦。\w5你知道吗？\w9\w9\u嘛，\w5要影响灵魂这种特殊存在，\w5需要不寻常的力量这点倒是可以理解。\w9\w9\p2\s[204]…\w5…\w5挥舞钉棒就会逃走的灵魂，\w5那本身也很奇怪就是了。\w9\w9\h\s[5]\n\n这么说的话，\w5我的火焰也能驱散恶灵！\w5什么的应该可以吧。\w9\w9\u\s[11]\n\n…\w5…\w5%(charname(0))的是更根本的问题吧。\w9\w9\p2\s[214]\n\n先等你能好好控制再来说吧。\w9\w9\h\s[4]\n\n呃，\w5确实\w5…\w5…"
	}
	when EMS_GC_CHANGED {
		if '同い年くらいの弟さん' _in_ change_plain_talk {
			"\u\s[10]\p2\s[200]\h\s[8]啊～，\w5妹妹比较好～。\w9\n\s[4]应付嚣张调皮的小鬼很累的。\w9\w9\p2\s[217]你这话什么意思。\w9\w9\u\s[11]…\w5…\w5到底哪个更费事啊。\w9\w9\p2\s[205]\n\n我倒觉得哥哥比较好。\w9\n最好是有能靠得住的。\w9\w9\u\n\n%(charname(2))没有的东西就别想了，认命吧。\w9\w9\h\s[3]\n\n嗯～。"
		}
		elseif '姉弟そろって炎の魔法' _in_ change_plain_talk {
			"\h\s[0]\p2\s[200]\u\s[10]…\w5…\w5我个人来说，\w5为了在像往常一样暴走时方便灭火，\w5想要水系，\w5冰系的。\w9\w9\p2\s[205]而且，\w5和火焰不同更优雅，\w5字面上也更酷。\w9\w9\h\s[3]…\w5…\w5你们两个，\w5都觉得我没用吧。\w9\w9\p2\s[218]\u\s[11]\_s[1,2]\n\n是的。\_s\w9\w9\h\s[4]\n\n呃～。"
		}
		elseif 'おませさん' _in_ change_plain_talk {
			"\u\s[10]\h\s[0]\p2\s[205]我觉得没问题哦。\w9\n不是芽生酱早熟，\w5是老姐你太幼稚了。\w9\w9\h\s[9]什，\w5你说什么～～～。\w9\w9\u\s[11]你看，\w5为这么点事就拼命生气的样子。\w9\w9\h\n\n…\w5…\w5…\w5…\w5\s[4]呃。"
		}
	}
	when EMS_GC_CALLING {
		"\u\s[10]\h\s[5]除灵服务到～达！\w9\w9\u\s[11]…\w5…\w5那是什么称呼。\w9\w9\h\s[3]\n\n说起来啊，\w5最近我房间天花板有嘎嗒嘎嗒或咔嚓咔嚓的小声音。\w9\n一定是恶灵啦那个。\w9\w9\u\n\n…\w5…\w5大概是老鼠什么的吧。\w9\n%(charname(0))也是猫，自己去抓来不就好了？\w9\w9\h\s[4]\n\n诶～，\w5阁楼好可怕～。\w5老鼠好可怕～。\w9\w9\u\n\n…\w5…\w5感觉有什么地方严重不对劲。"
	}
	/*when EMS_GC_CALLED {
	}*/
	when EMS_GC_CLOSED {
		"\u\s[10]\h\s[5]芽生酱，\w5工作辛苦了。\w9\w9\n\s[24]接下来就由我来这样保护%(username)免受恶灵侵害\w5…\w9\s[-1]\n[150]（砰！！）\_w[1500]\n[150]\s[40]…\w5…\w5对不起果然还是交给专业人士吧。\w9\n呃呃。\w9\w9\u\s[11]…\w5…\w5一个人在干嘛呢。"
	}
}}END_CHANGE

//-------------------------------------------------------------------------新2005.8.3/改2006.5.6
OnGhostChangeCall_マナ
{{START_CHANGE
	//钢之翼
	when EMS_GC_CHANGING {
		"\u\s[10]\h\s[27]嗯～，\w5是真奈桑吧，\w5下一个。\w9\w9\u嗯？\w5那又怎么了。\w9\w9\h\n\n那对翅膀，\w5看起来很锋利，\w5我在想能不能代替菜刀用。\w9\w9\u\s[11]\n\n…\w5…\w5禁止奇怪的想象。\w9\w9\h\s[4]\n\n诶～～～。"
		
		"\u\s[10]\h\s[0]\p2\s[205]那个，\w5是赫尔桑来着？\w5像机器人那个。\w9\n好帅啊！\w9\w9\h\s[0]嗯，\w5确实呢。\w9\w9\p2\n\n我家也想要一个！！\w9\w9\h\s[4]\n\n诶，\w5那个，\w5一个是指\w5…\w5…\w9\w9\u\s[11]啊，\w5非卖品所以不行哦。\w9\w9\h\n\n…\w5…\w5不只是非卖品的问题\w5…\w5…"
	}
	when EMS_GC_CHANGED {
		if 'ウチのはこんなだし' _in_ change_plain_talk {
			"\u\s[10]\h\s[0]\p2\s[205]啊，\w5不满意对方是赫尔桑啊。\w9\n那，\w5把老姐和赫尔桑交换成交了。\w9\w9\h\s[7]为什么啊～～～！！！\w9\w9\u嘛，\w5不管怎么看赫尔桑都更可靠，\w5也没什么问题吧。\w9\w9\h\s[3]\n\n喂，\w5%(charname(1))也过分了\w5…\w5…"
		}
		elseif '猫耳と猫しっぽの方が欲しい' _in_ change_plain_talk {
			"\u\s[10]\p2\s[200]\h\s[3]诶～，\w5我更想要真奈桑那看起来很帅的翅膀～。\w9\w9\p2\s[205]很帅嘛～，\w5那个。\w9\w9\u\s[11]你们两个，\w5别像小孩子一样什么都想要。\w9\w9\h\s[4]\n\n诶～～～～。"
		}
		elseif 'しましまぱんちゅ' {
			"\h\s[0]\u\s[11]条纹胖次为了烤红薯被强制终止了。\w9\n给您添麻烦了非常抱歉。\w9\w9\h\s[4]…\w5…\w5那是什么鬼。"
		}
	}
	when EMS_GC_CALLING {
		"\u\s[10]\h\s[2]机器人！\w5是机器人哦机器人！\w9\n真奈桑旁边那个是机器人一样机器人哦！！\w9\w9\u\s[11]…\w5…\w5机器人机器人吵死了。\w9\w9\h\s[5]\n\n机器人机器人机器人机器人机器人机器人机器人机器人机器人机器人\w5…\w5…\w9\s[27]诶？\w9\w9\u\n\n禁止说失礼的话。"
	}
	when EMS_GC_CLOSED {
		"\u\s[10]\h\s[3]真奈桑赫尔桑，\w5辛苦了\w5…\w5…\w9\w9\u…\w5…\w5怎么了？\w9\w9\h\n\n嗯～，\w5我在想好想要那个翅膀啊。\w9\w9\u\s[11]\n\n…\w5…\w5猫耳和铃铛就忍忍吧。\w9\w9\h\s[4]\n\n这，\w5是这样的吗？？"
	}
}}END_CHANGE

//-------------------------------------------------------------------------新2005.8.4/改----.--.--
OnGhostChangeCall_零香
{{START_CHANGE
	//-零开始的故事-
	when EMS_GC_CHANGING {
		"\u\s[10]\h\s[3]唔\w5…\w5…\w5…\w9\w9\u怎么了%(charname(0))。\w9\w9\h\n\n零香桑，\w5可能盯上我了\w5…\w5…\w9\w9\u\n\n身体？\w9\w9\h\n\n不是啦。\w5是零食的烤红薯。\w9\w9\u\s[11]\n\n…\w5…\w5那，\w5算什么幽灵啊。"
	}
	when EMS_GC_CHANGED {
		if '御供えの焼きいも泥棒常習犯' _in_ change_plain_talk {
			"\u\s[10]\h\s[7]我才不会拿供品呢！\w5绝对不会！！\w9\w9\u啊～，\w5真的不能拿哦。\w9\w9\h\s[6]\n\n我对烤红薯可是有讲究的。\w9\n必须是精心烤制的，\w5或者熟悉的烤红薯店的才行。\w9\w9\u\s[11]\n\n…\w5…\w5啊，\w5这样啊\w5…\w5…"
		}
	}
}}END_CHANGE

//-------------------------------------------------------------------------新2005.8.10/改----.--.--
OnGhostChangeCall_マッキ
{{START_CHANGE
	//玛奇
	when EMS_GC_CALLING {
		"\u\s[10]\h\s[0]\p2\s[205]玛奇姐旁边那个，\w5像小电脑一样的东西，\w5我家也想要呢。\w9\w9\h\s[3]唔～，\w5现在买不起呢～。\w9\w9\uPDA吗。\w5\_a[GHOST_所長たん]所长桑\_a之类的人不是有吗？\w9\n要个二手的来用也不错吧。\w9\w9\p2\s[204]\n\n…\w5…\w5总觉得会出bug不要。\w9\w9\h\s[8]\n\n喂喂。"
	}
	when EMS_GC_CHANGING {
		"\u\s[10]\p2\s[200]\h\s[5]接下来是机械见习生哦～。\w9\w9\p2\s[205]玛奇姐！\w9\n我家的电视超级破旧快要坏了能帮忙修一下吗？\w9\w9\h\s[4]\n\n…\w5…\w5呃～，\w5我又不是电器行的人。\w9\w9\u嘛，\w5你找错人了呢。\w9\w9\p2\s[203]\n\n诶～，\w5不行啊。"
	}
	when EMS_GC_CHANGED {
		if '自転車' _in_ change_plain_talk {
			"\u\s[10]\h\s[0]\p2\s[205]太好了，\w5能拿到帅气的自行车吗！？\w9\w9\h\s[8]喂喂，\w5你不是已经有自行车了吗。\w9\w9\p2\s[203]\n\n诶～，\w5那辆破旧褪色又嘎吱响的老姐的旧货我已经受够了。\w9\w9\h\s[9]\n\n什，\w5你说什么～～～！！！\w9\w9\u\s[11]…\w5…\w5嘛，\w5也许该换了。"
		}
	}
	when EMS_GC_CLOSED {
		"\u\s[10]\p2\s[200]\h\s[5]玛奇桑，\w5工作辛苦了。\w9\w9\p2\s[203]唉～，\w5我家要是有那么能干的姐姐就好了～。\w9\w9\h\s[9]\n\n你，\w5你什么意思～～～！！\w9\w9\u\s[11]…\w5…\w5确实呢。\w9\w9\h\s[4]\n\n喂，\w5%(charname(1))也\w5…\w5…"
	}
}}END_CHANGE

//-------------------------------------------------------------------------新2005.8.16/改----.--.--
OnGhostChangeCall_SMC
{{START_CHANGE
	//壁伺
	when EMS_GC_CHANGING {
		"\u\s[10]\h\s[5]啊，\w5SSP桑在！\w9\w9\n\s[27]那个啊，\w5\_a[GHOST_所長たん]所长酱\_a说要更认真点工作哦。\w9\w9\u\s[11]…\w5…\w5处理这些不就是你的工作吗。\w9\w9\h\s[3]\n\n嗯～，\w5谁知道呢。"
	}
	/*when EMS_GC_CHANGED {
	}*/
	when EMS_GC_CALLING {
		"\u\s[10]\p2\s[200]\h\s[5]壁纸～。\w9\w9\p2\s[205]是壁纸呢。\w9\w9\u…\w5…\w5嘛。\w5确实。\w9\w9\h\n\n好想要强制更换壁纸的功能～。\w9\w9\u\s[11]\n\n禁止。\w9\w9\h\s[4]\n\n诶～～～。"
	}
	when EMS_GC_CLOSED {
		"\u\s[10]\h\s[5]壁纸啪啪粘贴辛苦了～。\w9\w9\u\s[11]…\w5…\w5不，\w5又不是每次启动都要换。\w9\w9\h\s[3]\n\n诶～。"
	}
}}END_CHANGE

//-------------------------------------------------------------------------新2005.8.23/改----.--.--
OnGhostChangeCall_麗
{{START_CHANGE
	//丽&格拉迪乌斯
	when EMS_GC_CHANGING {
		"\u\s[10]\h\s[27]说起来，\w5丽桑旁边那个像手机一样的家伙，\w5说在找守护世界的魔力强大的人呢。\w9\w9\u虽然搞不懂，\w5嘛，\w5好像是这么回事。\w9\w9\h\s[5]\n\n这里也有一只哦！\w5如果方便的话现在就来演示\w5…\w9\u\s[12]\n\n哇！\w5哇！\w5哇！！\w9\w9\h\s[3]\n\n…\w5…\w5什么，\w5%(charname(1))。\w9\w9\u\n\n我已经受够焦黑了！！\w9\w9\h\s[4]\n\n唔～，\w5什么意思啊～。"
		
		"\u\s[10]\h\s[5]接下来是，\w5爱与正义与大姐的，\w5魔法少女☆丽小姐！\w9\w9\u\s[11]…\w5…\w5那么叫的话等下会被教训哦？\w9\w9\h\s[4]\n\n诶～，\w5明明很羡慕魔法少女的。"
	}
	when EMS_GC_CHANGED {
		if 'すっかり芋キャラ' _in_ change_plain_talk {
			"\u\s[10]\h\s[9]谁，\w5谁成了红薯角色啊～！\w9\n我也好好在做SSP导航员的工作啊！\w9\w9\u\s[10]…\w5…\w5啊，\w5那里有烤红薯。\w9\h\s[2]\n\n诶！？\w5哪里！？\w5哪里哪里！？\w9\w9\u\s[11]\n\n…\w5…\w5确实彻底变成红薯角色了呢。\w9\w9\h\s[4]\n\n唔，\w5唔\w5…\w5…"
		}
	}
	when EMS_GC_CALLING {
		"\u\s[10]\p2\s[200]\h\s[5]啊～，\w5丽桑和格拉迪乌斯=…\w5…\w5…\s[27]？\w9\w9\u怎么了，\w5突然沉默了。\w9\w9\h\n\n呃～，\w5嗯～，\w9\s[5]啊！\w9\n格拉迪乌斯=马面秃头=多=你谁啊桑呀吼～！\w9\w9\p2\s[214]怎么能错成那样啊。\w9\w9\u\s[11]\n\n…\w5…\w5虽然长了点，\w5至少记个名字吧。\w9\w9\h\s[4]\n\n记不住～，\w5太长了～。"
	}
	when EMS_GC_CALLED {
		"\h\s[0]\u\s[10]\p2\s[205]这个老姐，\w5%(charname(0))=红薯狂=火焰暴走=得=焦黑炭，\w5总是说些多余的话。\w9\w9\h\s[3]唔，\w5我才不是那种名字呢。\w9\w9\u\s[11]…\w5…\w5%(charname(2))的名字更适合呢。\w9\w9\h\s[9]\n\n为什么啊～～～！！！"
	}
	when EMS_GC_CLOSED {
		"\u\s[10]\h\s[3]丽桑，\w5辛苦了。\w9\w9\u为什么一脸遗憾。\w9\w9\h\n\n因为啊，\w5我超憧憬魔法少女的，\w5但丽桑好像不理解我。\w9\w9\u\s[11]\n\n…\w5…\w5普通的大姐姐对那种没兴趣啦。\w9\w9\h\s[4]\n\n诶～～～。"
	}
}}END_CHANGE

//-------------------------------------------------------------------------新2005.8.24/改----.--.--
OnGhostChangeCall_凪紗
{{START_CHANGE
	//NAGISA the Seraphic Wing
	when EMS_GC_CHANGED {
		if '愛すべき暴走お元気娘' _in_ change_plain_talk {
			"\u\s[11]\h\s[0]\p2\s[214]有精神是好事，\w5但暴走就有点…。\w9\w9\u每天都搞得一团糟真是受不了。\w9\w9\h\s[7]我才没有每天都那样！\w5真是的！！"
		}
		elseif 'バグ避けの鈴' _in_ change_plain_talk {
			"\p2\s[200]\h\s[0]\u\s[10]这个铃铛是安全气囊吧。\w9\w9\p2\s[205]不对啦，\w5是因为老姐靠不住，\w5为了迷路时容易找到她的铃铛。\w9\w9\h\s[7]你们两个什么意思！！"
		}
		elseif 'MONOKO' _in_ change_plain_talk {
			"\u\s[10]\h\s[5]下一站，\w5终点站，\w5滨松町。\w9\n请各位旅客不要遗忘随身物品。\w9\w9\u\s[11]…\w5…\w5你在干嘛。\w9\w9\h\s[27]\n\n东京单轨电车的广播，\w5是这样的吗？\w9\w9\u\n\n…\w5…\w5谁知道。"
		}
	}
	when EMS_GC_CHANGING {
		"\u\s[10]\p2\s[200]\h\s[3]总觉得是一对总在聊难懂话题的组合呢。\w9\w9\p2\s[214]老姐，\w5我觉得你太不看新闻了。\w9\w9\u\s[11]…\w5…\w5不过，\w5要是%(charname(0))成了社会派，\w5那在各种意义上也很怪就是了。\w9\w9\h\s[4]\n\n什么意思啊，\w5那个～～～。"
		
		"\u\s[10]\h\s[0]\p2\s[205]啊，\w5凪纱姐，\w5我的社会作业，\w5帮我做吧。\w9\w9\u\s[11]…\w5…\w5作业全推给别人。\w9\w9\h\s[8]哈哈\w5…\w5…\w9\n作业得自己做的。\w9\w9\p2\s[218]\n\n说这话的老姐你，\w5不也把理科的全都推给\_a[GHOST_所長たん]所长桑\_a了吗。\w9\w9\h\s[3]\n\n…\w5…\w5唔。\w9\w9\u\n\n嘛，\w5这就是见贤思齐，见不贤而内自省吧。"
	}
}}END_CHANGE

//-------------------------------------------------------------------------新2005.8.31/改2005.9.1
OnGhostChangeCall_壬由利
{{START_CHANGE
	//壬由利和教头
	when EMS_GC_CHANGING {
		"\u\s[10]\h\s[0]\p2\s[205]接下来，\w5是壬由利桑呢。\w9\w9\h\s[3]…\w5…\w5唔，\w5唔唔～～。\w9\w9\u\s[11]怎么了，\w5那么害怕。\w9\w9\h\n\n诶，\w5因，\w5因为\w5…\w5…\w9\w9\p2\s[218]\n\n哼哼，\w5原来如此。\w9\w9\n\s[204]每次，\w5面对\_a[GHOST_舞子]舞子姐\_a时的恐惧，\w5你懂了吧？\w9\w9\h\s[4]\n\n…\w5…\w5大概吧。\w9\w9\u\n\n大概吗\w5…\w5…"
	}
	when EMS_GC_CHANGED {
		if 'お姉さんがなでなで' _in_ change_plain_talk {
			"\u\s[10]\p2\s[214]\h\s[3]…\w5…\w5呜\w5…\w5…\w9\w9\u怎么了。\w9\w9\h\n\n被摸了好多地方。\w9\w9\p2…\w5…\w5感觉就像在看着\_a[GHOST_舞子]舞子姐\_a一样。\w9\w9\h\s[4]\n\n%(charname(2))也不容易呢\w5…\w5…"
		}
	}
}}END_CHANGE

//-------------------------------------------------------------------------新2005.9.13/改----.--.--
OnGhostChangeCall_晶
{{START_CHANGE
	//missing child
	when EMS_GC_CHANGING {
		"\u\s[10]\h\s[3]嗯～\w5…\w5…\w9\w9\u晶酱，\w5是失忆什么的，\w5和父母走散了对吧？\w9\w9\h\n\n好可怜啊\w5…\w5…\w9\n希望能早点找到办法。\w9\w9\u\n\n嘛，\w5在那之前%(username)，\w5就拜托你了，\w5大概是这个意思吧。\w9\w9\h\s[5]\n\n下次我也要摸摸她的头。\w9\w9\u\n\n…\w5…\w5嗯。"
	}
	when EMS_GC_CHANGED {
		if '姉弟' _in_ change_plain_talk {
			"\u\s[10]\p2\s[200]\h\s[3]啊，\w5这样啊。\w9\n晶酱，\w5是一个人呢。\w9\w9\u有弟弟这件事，\w5从没有的人来看是很奢侈的啊。\w9\w9\h\s[5]\n\n啊，\w5对了%(charname(2))，\w5下次去晶酱那陪她玩吧。\w9\w9\p2\s[205]说的也是。"
		}
		elseif '優しくて' _in_ change_plain_talk {
			"\u\s[10]\p2\s[200]\h\s[1]…\w5…\w5喵。\w9\n就算说好话也不会给你红薯的哦。\w9\w9\u\s[11]…\w5…\w5一被说温柔漂亮就这样。\w9\w9\h\s[6]\n\n不管怎么说，\w5被夸漂亮还是有点开心的。\w9\w9\p2\s[205]老姐！\w5你温柔又漂亮！\w9\n所以让我预支零花钱！！\w9\w9\u\n\n…\w5…\w5这个意图太明显了。\w9\w9\h\s[9]\n\n不行！\w5我这个月也很紧巴巴的在忍耐节约呢！"
		}
	}
	when EMS_GC_CALLING {
		"\u\s[10]\p2\s[200]\h\s[5]啊，\w5是晶酱。\w9\n\s[6]姐姐也会陪着你的，\w5别哭哦。\w9\n摸摸。\w9\w9\p2\s[218]啊，\w5老姐在装姐姐了。\w9\w9\h\s[9]\n\n你那是什么意思～～～。"
	}
	//when EMS_GC_CALLED {
	//}
	when EMS_GC_CLOSED {
		"\u\s[10]\h\s[3]嗯～，\w5再见，\w5晶酱。\w9\w9\u希望她不觉得孤单就好。"
	}
}}END_CHANGE

//-------------------------------------------------------------------------新2005.9.13/改----.--.--
OnGhostChangeCall_ぷぅか
{{START_CHANGE
	//地下帝国的逆袭？
	when EMS_GC_CHANGING {
		"\u\s[10]\p2\s[200]\h\s[5]普卡桑，\w5法伊加桑，\w5地下工作加油哦。\w9\w9\p2\s[204]…\w5…\w5那是工作吗？\w9\w9\u\s[11]…\w5…\w5嘛，\w5某种意义上，\w5怎么说呢，\w5可以说是工作也可以说不是。\w9\w9\h\s[3]\n\n唔～，\w5不是吗？"
	}
	when EMS_GC_CHANGED {
		if '芋ねーちゃん' _in_ change_plain_talk {
			"\u\s[10]\h\s[5]是～的，\w5红薯～姐来～啦。\w9\w9\u真稀奇，被那么说也不生气呢。\w9\w9\h\s[1]\n\n要是给我红薯的话我什么都干。\w9\w9\u\s[11]\n\n…\w5…\w5红薯狂。"
		}
		elseif 'ファイヤー' _in_ change_plain_talk {
			"\u\s[14]\p2\s[240]\h\s[40]呼，\w5呼喵\w5…\w5…\w9\w9\u…\w5…\w5火力太强了。\w5（咳咳）\w9\w9\p2老姐，\w5火太强红薯成炭了哦。\w9\w9\h\n\n法伊加桑，\w5过头了\w5…\w5…"
		}
	}
	when EMS_GC_CALLING {
		"\u\s[10]\p2\s[200]\h\s[5]这里挖喵喵！\w9\w9\u\s[11]\p2\s[204]\_s[1,2]…\w5…\w5…。\_s\w9\w9\h\s[8]\n\n诶，\w5这样，\w5不行吗？\w9\w9\u\n\n…\w5…\w5不行。\w9\w9\p2\n\n老姐今天也在抽风。\w9\w9\h\s[9]\n\n谁，\w5谁抽风啊啊～～～！！"
	}
	//when EMS_GC_CALLED {
	//}
	when EMS_GC_CLOSED {
		"\u\s[10]\h\s[27]是在修地铁吗？\w9\w9\u\s[11]…\w5…\w5应该不是。\w9\w9\h\s[8]\n\n诶？？"
	}
}}END_CHANGE

//-------------------------------------------------------------------------新2005.9.13/改----.--.--
OnGhostChangeCall_レイチェル
{{START_CHANGE
	//瑞秋的餐厅
	//「酱」
	when EMS_GC_CHANGING {
		"\u\s[10]\p2\s[200]\h\s[5]好～了，\w5攒了点钱今天下馆子～！\w9\w9\p2\s[205]哟，\w5老姐真大方～。\w9\w9\h\s[9]\n\n我才不胖！！\w9\w9\u\s[11]…\w5…\w5又想去瑞秋桑那里，\w5靠都是猫的交情，\w5之类的话打折吧。\w9\w9\h\s[4]\n\n唔，\w5唔唔，\w5计划暴露了。"
		
		"\u\s[10]\h\s[5]那么，\w5瑞秋酱，\w5接下来拜托了～。\w9\w9\u同时兼顾烹饪和接待，\w5一个人经营小餐厅的猫咪呢。\w9\w9\h\s[5]\n\n胜利！\w5啪嗒。\w9\w9\u\s[11]\n\n…\w5…\w5你在干嘛。\w9\w9\h\n\n胜利·\w5粘贴哦～。\w9\w9\u\n\n…\w5…\w5驳回。\w9\w9\h\s[2]\n\n喵啊啊啊啊啊！？"
		
	}
	when EMS_GC_CHANGED {
		if '芋が全部なくなる' _in_ change_plain_talk {
			"\u\s[10]\p2\s[200]\h\s[5]呼～。\w9久违地下馆子真满足～。\w9\w9\p2\s[205]甜点的布丁也很好吃呢。\w9\w9\u哪里哪里，\w5主菜口味清淡却有深度，\w5让人想说真是讲究的绝妙味道。\w9\w9\n\s[11]…\w5…\w5好像有一个人这次又只吃了特制红薯套餐。\w9\w9\h\s[9]\n\n因为！\w5瑞秋酱店里的红薯套餐好吃嘛！\w5每次都！！\w9\w9\p2\s[208]\n\n…\w5…\w5嘛，\w5省钱也不错？"
		}
		elseif '請求書' _in_ change_plain_talk {
			"\u\s[10]\h\s[2]！！！\w9\n账单！！\w9\w9\u上面写了多少？\w9\w9\h\s[4]\n\n一，\w5十，\w5百，\w5千，\w5万\w5…\w5…\w9\w9\s[-1]\n（啪嗒。）\w9\w9\u\s[12]\n\n%(charname(0))！？"
		}
	}
	when EMS_GC_CALLING {
		"\u\s[10]\p2\s[200]\h\s[55]喵～。\w9\n瑞秋酱，\w5雇佣我当红薯专业厨师吧～。\w9\w9\p2\s[204]…\w5…\w5那是什么。\w9\w9\u\s[11]嘛，\w5除了红薯以外一塌糊涂嘛。\w9\w9\h\s[9]\n\n才，\w5才没有那种事！！"
	}
	when EMS_GC_CALLED {
		if '特注芋づくしコース' _in_ change_plain_talk {
			"\u\s[10]\p2\s[200]\h\s[5]瑞秋酱，\w5今天也来个红薯全套套餐\w5…\w5…\w5\s[2]哇，\w5哇，\w5哇，\w5准备了超厉害的东西！\w9\w9\p2\s[214]从头到尾只有红薯呢。\w9\w9\u\s[11]嘛\w5…\w5…\w5看起来很好吃就是了。\w9\w9\h\s[5]\n\n啊啊，\w5谢谢～～～。"
		}
	}
	when EMS_GC_CLOSED {
		"\u\s[10]\h\s[5]瑞秋酱，\w5烹饪工作辛苦了。\w9\w9\u\s[11]…\w5…\w5%(charname(0))也是猫，\w5希望你能做点像样的饭菜啊。\w9\w9\h\s[4]\n\n唔，\w5唔唔，\w5我会努力的。"
	}
}}END_CHANGE

//-------------------------------------------------------------------------新2005.9.18/改2005.9.28
OnGhostChangeCall_ねここ
{{START_CHANGE
	//猫子和小太
	when EMS_GC_CHANGING {
		"\u\s[10]\p2\s[200]\h\s[5]喵，\w5喵\w1喵\w2喵\w1喵\w2扭扭\w2喵！\w9\w9\u\s[11]…\w5…\w5%(charname(0))坏掉了。\w9\w9\h\s[3]\n\n诶？\w5明明是世界公认猫语。\w9\w9\p2\s[214]老姐，\w5那是被骗了。\w9\w9\h\s[4]\n\n诶～？"
	}
	when EMS_GC_CHANGED {
		if 'スズメ取りの罠' _in_ change_plain_talk {
			"\u\s[-1]\p2\s[-1]\h\s[5]这种地方怎么会有烤红薯～。\w9\w9\n呃～～～～～。\w9\w9\n（啪嗒）\w9\w9\s[2]\n\n[half]啊啊！！\w5是陷阱！？\w9\w9\p2\s[214]…\w5…\w5老姐你在干嘛，\w5怎么钻进那么大的箩筐里了。\w9\w9\u\s[11]…\w5…\w5不知道是谁设的，\w5经典的捕麻雀陷阱啊。\w9\n箩筐和支棍。\w5真是简单。\w9\w9\h\s[3]\n\n别冷静地嘀咕了快来救我～。\w9\w9\u\n\n…\w5…\w5直接把箩筐抬起来不就能出来了吗。\w9\w9\p2\s[204]\n\n居然会上这种当\w5…\w5…"
		}
	}
	when EMS_GC_CALLING {
		"\u\s[10]\h\s[5]的说～，\w5的说～。\w9\w9\u在模仿猫子酱？\w9\n其实那个\w5「的说」\w5有很深的意义哦。\w9\w9\h\s[27]\n\n什么意义？\w9\w9\u\n\n因为被诅咒永远保持不会成长的小孩模样，\w5悲叹只能以小个子姿态活下去，\w5每夜每夜\w5「nano的说～」\w5徘徊着呢。\w9\w9\h\s[2]\n\n什，\w5什么―――――！！\w9\w9\n\s[3]…\w5…\w5好可怜啊。\w9\w9\u\s[11]\n\n其实是骗人的。\w9\w9\h\s[4]\n\n…\w5…\w5…\w5…\w5…。"
	}
	//when EMS_GC_CALLED {
	//}
	when EMS_GC_CLOSED {
		"\u\s[10]\p2\s[200]\h\s[5]猫子酱，\w5小太酱，\w5辛苦了。\w9\n…\w5…\w5\s[1]真想跟小太酱换换%(charname(2))啊。\w9\w9\p2\s[214]你什么意思。\w9\w9\u\s[11]…\w5…\w5肯定是想让看起来很温柔的小太桑去跑腿，\w5自己偷懒的阴谋。\w9\w9\h\s[9]\n\n我才不会那样！！"
	}
}}END_CHANGE

//-------------------------------------------------------------------------新2005.9.18/改----.--.--
OnGhostChangeCall_黒海
{{START_CHANGE
	//黑海
	when EMS_GC_CHANGING {
		"\u\s[10]\h\s[5]黑海～姐。\w9\n那么，\w5接下来拜托了～。\w9\w9\u自卫队啊，\w5军事话题很擅长的大姐姐呢。\w9\w9\h\s[27]\n\n呃，\w5驱虫剂驱虫剂，\w5在哪来着。\w9\n（翻找）\w9\w9\u\s[11]\n\n…\w5…\w5你在干嘛。\w9\w9\h\n\n嗯～，\w5我想组建保护红薯的自卫队，\w5先找驱虫剂。\w9\w9\u\n\n…\w5…\w5…\w5…\w5…。\w9\w9\h\s[4]\n\n呜，\w5被鄙视了～。"
	}
	//when EMS_GC_CHANGED {
	//}
	when EMS_GC_CALLING {
		"\u\s[10]\p2\s[200]\h\s[5]黑海～姐呀吼～。\w9\w9\n\s[1]…\w5…\w5…\w5…。\w9\w9\u\s[11]怎么了，\w5脸都红了。\w9\w9\p2\s[205]一定是憧憬的大姐姐吧？\w9\w9\h\n\n呃～，\w5我在想能不能叫你黑美～。\w9\w9\u\n\n…\w5…\w5那是什么。\w9\w9\p2\s[204]\n\n又在起奇怪的昵称了\w5…\w5…\w9\w9\h\s[9]\n\n才不奇怪！\w5大概！！"
	}
	//when EMS_GC_CALLED {
	//}
	when EMS_GC_CLOSED {
		"\u\s[10]\p2\s[205]\h\s[5]黑海～姐辛苦了。\w9\w9\p2真好呢，\w5看起来那么可靠。\w9\w9\n\s[218]真希望我家也有呢。\w9\w9\u\s[11]…\w5…\w5确实，\w5旁边这个勉强算姐的某人是不太行呢。\w9\w9\h\s[9]\n\n你说什么～～～！？"
	}
}}END_CHANGE

//-------------------------------------------------------------------------新2005.9.20/改2005.10.6
OnGhostChangeCall_裕紀
{{START_CHANGE
	//BORG
	//艾米莉叫「酱」。在盘算让艾米利欧女装？
	when EMS_GC_CHANGING {
		"\u\s[10]\h\s[27]是轮到裕纪酱\w5…\w5…\w5了吧？\w9\w9\u\s[11]…\w5…\w5不，\w5是交接没错。\w9\n你在歪头想什么。\w9\w9\h\n\n真的是男孩子对吧？\w9\w9\u\s[10]\n\n100% 纯正男人。\w9\n浓缩男子还原。\w9\w9\h\s[4]\n\n什，\w5什么啊那是～～～。"
		
		"\u\s[10]\h\s[0]\p2\s[200]老姐你啊，\w5不是总自称「我（ボク）」吗？\w9\w9\h\s[27]嗯～？\w9\w9\n\s[8]啊～，\w5从小养成的习惯，\w5一不小心就。\w9\w9\u嘛，\w5女孩子用ボク自称确实少见呢。\w9\w9\p2\s[218]\n\n该不会像裕纪桑那样，实际上是里面的人在女装吧？\w9\w9\u\s[11]\n\n…\w5…\w5…\w5…\w5…。\w9\w9\h\s[9]\n\n才，\w5才没有什么里面的人！！\w9\n我可是货真价实的女孩子～～～。"
		
	}
	when EMS_GC_CHANGED {
		if '絶対女装の素質' _in_ change_plain_talk {
			"\u\s[10]\h\s[0]\p2\s[217]女，\w5女装怎么可能啊！\w9\w9\h\s[8]啊，\w5哈哈\w5…\w5…\w9\w9\u\s[11]…\w5…\w5你在慌什么。\w9\w9\p2\s[203]\n\n不\w5…\w5…\w5其实，\w5别人也经常这么说\w5…\w5…\w9\w9\h\s[2]\n\n喵，\w5喵什么―――！！！\w9\w9\u\n\n…\w5…\w5果然。"
		}
	}
	when EMS_GC_CALLING {
		"\u\s[10]\p2\s[200]\h\s[5]啊，\w5是裕纪酱。\w9\n我的化妆品什么的借给你吧。\w9\w9\u\s[11]有邪恶的腐女子想让他更深陷女装之道。\w9\w9\h\s[9]\n\n才不是那样！！\w9\w9\p2\s[218]而且，\w5老姐的化妆品里加了会变成猫的特殊成分，\w5用了会很麻烦的。\w9\w9\h\s[7]\n\n我才没用那种奇怪的东西！！"
	}
	when EMS_GC_CALLED {
		if 'めちゃくちゃ失礼よそれ' _in_ change_plain_talk {
			"\u\s[10]\h\s[9]\p2\s[207]谁是小正太啊，\w5真是的。\w9\n裕纪桑也好过分啊。\w9\w9\h唔～，\w5我才不是腐女子，\w5没那么变态的爱好。\w9\w9\u…\w5…\w5…\w5…\w5…。\w9\w9\h\s[27]\n\n…\w5…\w5咦？\w5%(charname(1))你不生气吗？\w9\w9\u\s[11]\n\n噼咔，\w5噼咔噼咔。\w9\w9\h\s[2]\n\n嗨起来了！！\w9\w9\p2\s[214]\n\n你在干嘛啊，\w5真是的。\w9\w9\u\s[10]\n\n呵呵。\w5为这点事就生气，你们两个还是小孩子呢。\w9\w9\h\s[4]\n\n唔唔～。"
		}
		elseif 'なんで英語なの' _in_ change_plain_talk {
			"\u\s[10]\p2\s[200]\h\s[2]是，\w5是的！\w9\nHow are you？\w5 Hawaii is island！！\w9\w9\u\s[11]…\w5…\w5你在慌什么。\w9\w9\p2\s[214]就这还能当有英文版的SSP导航员，\w5真是奇怪呢。\w9\w9\h\s[3]\n\n唔～，\w5英语果然不行～。"
		}
	}
	when EMS_GC_CLOSED {
		"\h\s[0]\u\s[10]以上，\w5腐女子偶像的环节。\w9\n请继续享受真正的腐女子时间。\w9\w9\h\s[9]我没那种爱好！\w5真的！！"
	}
}}END_CHANGE

//-------------------------------------------------------------------------新2005.9.20/改2005.9.29
GCC_Marika_Exp
{
	'真空管'
	'ニキシー管'
	'ペルチエ素子'
	--
	TOSTR((RAND(6)+4)*100) + '個'
}

OnGhostChangeCall_まりか
{{START_CHANGE
	//染井真理香
	//这边也是「桑」
	when EMS_GC_CHANGING {
		"\u\s[10]\p2\s[200]\h\s[5]喜欢电子工学的女孩子呢。\w9\n虽然少见，\w5我很喜欢这种人。\w9\w9\u嘛，\w5因为性别就说不像什么的在现在这个时代不合适了。\w9\w9\p2\s[206]不过老姐的意图我看透了，\w5是想趁这种时候赚点好感，\w5以后好让人帮忙修电器吧。\w9\w9\h\s[8]\n\n啊～，\w5哈哈哈～，\w5没有的事没有的事～。\w9\w9\u\s[11]\n\n说中了。\w9\w9\h\s[4]\n\n呃。"
	}
	when EMS_GC_CHANGED,EMS_GC_CALLED {
		if '姉さんにデフォルトの座を' _in_ change_plain_talk {
			"\u\s[10]\p2\s[200]\h\s[3]唔～，\w5真的会被抢走工作呢。\w9\n芳野桑和真理香桑好像什么都会的样子。\w9\w9\u嗯～，\w5得有些别人做不到的事才行啊。\w9\w9\p2\s[205]可以点火啦，\w5可以处理多余的红薯啦。\w9\w9\u\s[11]\n\n…\w5…\w5那些，\w5都和默认工作完全没关系吧。\w9\w9\h\s[4]\n\n啊呜\w5…\w5…"
		}
		elseif '全自動焼き芋器' _in_ change_plain_talk {
			"\h\s[0]\p2\s[200]\u\s[10]全自动烤红薯\w5…\w5…\w9\n有的话确实很厉害，\w5但到底怎么做呢。\w9\w9\h\s[27]是啊，\w5可能相当难呢。\w9\w9\p2\s[205]让老姐当里面的人不就解决了吗？\w9\w9\h\s[9]\n\n才，\w5才没有里面的人！！\w9\w9\u\s[11]\n\n…\w5…\w5…。"
		}
		elseif 'エミリオ君って可愛い' _in_ change_plain_talk {
			"\u\s[10]\h\s[0]\p2\s[203]…\w5…\w5唔～，\w5没法坦率地高兴啊。\w9\w9\h\s[8]啊，\w5哈哈\w5…\w5…\w9\w9\u嘛，\w5被女孩子说可爱，\w5就坦率接受吧。\w9\w9\p2\s[214]\n\n嗯～。"
		}
	}
	when EMS_GC_CALLING {
		"\u\s[10]\h\s[5]啊，\w5真理香桑真理香桑。\w9\w9\s[27]\n\_a[GHOST_所長たん]所长桑\_a说，\w5知不知道哪里能弄到下次实验要用的%(GCC_Marika_Exp)。\w9\w9\u\s[11]…\w5…\w5那种东西，\w5要用来干嘛。\w9\w9\h\s[3]\n\n想干什么呢。"
	}
	when EMS_GC_CLOSED {
		"\u\s[10]\p2\s[200]\h\s[5]真理香桑，\w5辛苦了～。\w9\w9\p2\s[205]旁边的机器人好想要。\w9\n有种赛博的感觉。\w9\w9\u顺便说一句，\w5比旁边那个冒失的某人有用多了。\w9\w9\h\s[9]\n\n什，\w5你说什么哦～～～。"
	}
}}END_CHANGE

//-------------------------------------------------------------------------新2005.9.20/改----.--.--
OnGhostChangeCall_彩乃
{{START_CHANGE
	//奉仕女仆彩乃桑
	when EMS_GC_CHANGING {
		"\u\s[10]\p2\s[200]\h\s[5]Fabric soft～。\w9\n咻咻咻～～～。\w9\w9\p2\s[217]啊～，\w5又在浪费了。\w9\w9\u不能那样随便咻～咻～的啦。\w9\w9\h\s[3]\n\n可是～，\w5看到彩乃桑在咻～咻～的我就也想做嘛。\w9\w9\u\s[11]\n\n…\w5…\w5…。\w9\w9\p2\s[214]\n\n不，\w5我觉得那是工作啊？"
	}
	//when EMS_GC_CHANGED {
	//}
	when EMS_GC_CALLING {
		"\h\s[0]\u\s[10]啊，\w5女仆来了呢。\w9\w9\h\s[5]让她们顺便帮我们把衣服也洗了吧～。\w9\w9\u\s[11]\n\n禁止偷懒。\w5自己动手。\w9\w9\h\s[4]\n\n呜呜，\w5对不起。"
	}
	//when EMS_GC_CALLED {
	//}
	when EMS_GC_CLOSED {
		"\u\s[10]\p2\s[200]\h\s[5]彩乃桑，\w5工作辛苦了～。\w9\w9\p2\s[218]老姐不加油的话，\w5导航员的工作也会被抢走哦？\w9\w9\u看起来彩乃桑更合适呢。\w9\w9\h\s[9]\n\n才，\w5才没有那种事！！"
	}
}}END_CHANGE

//-------------------------------------------------------------------------新2005.9.28/改----.--.--
OnGhostChangeCall_皆口つぐみ
{{START_CHANGE
	//皆口津具美
	when EMS_GC_CHANGING {
		"\u\s[10]\h\s[0]\p2\s[218]老姐。\w9\w9\h\s[5]什么事啊艾米利欧。\w9\w9\u怎么了一脸奇怪的表情。\w9\w9\p2\n\n听说零食吃太多的人，\w5夜半三更皆口津具美桑会出现，\w5把肚子剖开哦。\w9\n老姐也得小心才行。\w9\w9\h\s[4]\n\n不，\w5不要啊啊啊啊！\w9\n可是我想吃零食！\w5想吃红薯！\w9\w9\u\s[11]\n\n…\w5…\w5已经是执念了呢，\w5到这种程度。\w9\w9\p2\s[214]\n\n红薯的诱惑，\w5比怪谈还要厉害吗\w5…\w5…"
	}
	when EMS_GC_CHANGED {
		if '恐怖の芋料理' _in_ change_plain_talk {
			"\u\s[10]\h\s[8]哈哈哈～。\w9\n不能用那种手法做菜哦～。\w9\w9\u\s[11]…\w5…\w5不，\w5那真的是在做菜吗？\w9\w9\h\s[27]\n\n诶？\w5她不是在努力用红薯做别具一格的料理招待我们吗？\w9\w9\u\n\n…\w5…\w5我觉得不是。"
		}
	}
	when EMS_GC_CALLING {
		"\u\s[10]\h\s[8]津，\w5津，\w5津具美桑呀吼～。\w9\w9\u\s[11]…\w5…\w5声音在发抖哦。\w9\w9\h\s[4]\n\n因，\w5因为啊～。\w9\w9\u\n\n小夜酱就没事，\w5皆口津具美桑就不行，\w5这到底是为什么呢。"
	}
	when EMS_GC_CALLED {
		if 'ちょうど芋料理が' _in_ change_plain_talk {
			"\u\s[10]\h\s[27]嗯～，\w5颜色不太好的红薯呢。\w9\w9\n\s[8]得买更好产地的才行。\w9\w9\u\s[11]…\w5…\w5那明显不是红薯的颜色啊。"
		}
	}
	when EMS_GC_CLOSED {
		"\u\s[10]\p2\s[200]\h\s[5]皆口津具美桑，\w5…\w5…\w9\w9\s[27]？\w9\w9\u怎么了，\w5说到一半不说了。\w9\w9\h\n\n那个啊，\w5我觉得说辛苦了也有点怪。\w9\w9\p2\s[205]说愿你成佛之类的怎么样。\w9\w9\u\n\n\s[11]…\w5…\w5那个也不太对吧。"
	}
}}END_CHANGE

//-------------------------------------------------------------------------新2005.10.6/改----.--.--
OnGhostChangeCall_ほたる
{{START_CHANGE
	//初心占卜师萤
	when EMS_GC_CHANGING {
		"\u\s[10]\p2\s[200]\h\s[5]换萤桑了～。\w9\w9\p2\s[205]虽然谦虚说慢慢来，\w5但挺准的占卜师呢。\w9\w9\u\s[11]…\w5…\w5在意旁边那只可疑的黑猫。\w9\w9\h\s[4]\n\n啊，\w5不能说可疑啦。"
		
		"\u\s[10]\p2\s[200]\h\s[27]萤桑旁边的假面桑，\w5在说人话呢，\w5那个到底是怎么回事。\w9\w9\p2\s[203]真奇怪啊，\w5猫能理解人的话，\w5还能说话。\w9\w9\u\s[11]…\w5…\w5啊，\w5你们两个，\w5该怎么说呢\w5…\w5…\w5去照照镜子重新想想比较好哦。"
	}
	//when EMS_GC_CHANGED {
	//}
	when EMS_GC_CALLING {
		"\u\s[10]\h\s[5]啊，\w5萤桑呀吼～。\w9\w9\u难得的机会，\w5不算个命吗？\w9\w9\h\s[27]\n\n嗯～，\w5那么～，\w5那个啊。\w9\w9\u\n\n嗯嗯。\w9\w9\h\s[5]\n\n今年红薯会丰收吗？\w9\w9\u\s[11]\n\n…\w5…\w5想点更正经的啦。\w9\w9\h\s[3]\n\n诶～，\w5我可是认真想的。"
		
		"\u\s[10]\h\s[27]说起来前阵子，\w5我试了试能不能像萤桑那样。\w9\w9\u我们家有水晶球吗？\w9\w9\h\n\n…\w5…\w5没有所以用了玻璃珠就是了？\w9\w9\u\s[11]\n\n…\w5…\w5算了。\w9\n那，\w5有效果吗？\w9\w9\h\s[5]\n\n盯着看了一会儿，\w5就想说明天的晚饭做蛋包饭吧。\w9\n很厉害吧～。\w9\w9\u\n\n…\w5…\w5看来是红黄条纹的玻璃珠呢。\w9\w9\h\s[8]\n\n被，\w5被发现了。"
		
	}
	//when EMS_GC_CALLED {
	//}
	when EMS_GC_CLOSED {
		"\u\s[10]\h\s[6]萤桑，\w5占卜辛苦了。\w9\w9\u一直都在努力呢。\w9\n虽然是在路边默默地进行。\w9\w9\h\s[27]\n\n嗯～，\w9\s[5]「很准！\w5一针见血！！」\w9…\w5…\w5\s[27]之类的，\w5插个旗子的话，\w5会不会有更多客人来呢。\w9\w9\u\s[11]\n\n…\w5…\w5那个，\w5很可疑啦。"
	}
}}END_CHANGE

//-------------------------------------------------------------------------新2005.10.8/改----.--.--
OnGhostChangeCall_フィルミオ
{{START_CHANGE
	//炽天使十字军
	when EMS_GC_CHANGING {
		"\u\s[10]\h\s[0]换阿利亚桑和蕾米桑了。\w9\w9\u算是守护天使之类的吗。\w9\w9\h\s[27]\n\n炽天使十字军，\w5听起来像两人组合会创作歌曲的名字呢。\w9\w9\u\s[11]\n\n…\w5…\w5嘛\w5…\w5…\w5确实呢。"
		
		"\u\s[10]\h\s[5]俺已经死掉了～♪\w9\w9\u\s[11]…\w5…\w5%(charname(0))你几岁来着？\w9\w9\h\s[27]\n\n诶？\w5但那个有趣的歌到现在也很有名吧？\w9\n不就是创作那首歌的人吗？\w9\w9\u\n\n那是Folk。\w5阿利亚桑和蕾米桑是Seraphim。\w9\w9\h\s[4]\n\n啊啊。"
	}
	when EMS_GC_CHANGED {
		if '減点' _in_ change_plain_talk {
			"\u\s[10]\h\s[8]呃～，\w5扣分\w5…\w5…\w9\n真严格啊。\w9\w9\u嗯？\w5扣分？\w9\n\\![call,ghost,空とあるゅ…\w9\h\s[4]\n\n等等等等。"
		}
		elseif '焼き芋とか持って行こう' _in_ change_plain_talk {
			"\u\s[10]\p2\s[205]\h\s[5]茶点时间？\w5大力欢迎哦～。\w9\n下次来玩吧。\w9\w9\p2期待会带什么布丁来呢。\w9\w9\u\s[11]…\w5…\w5好吃到一口升天确定之类的。\w9\n只有精灵才能吃之类的。\w9\w9\h\s[4]\n\n那个，\w5等等。"
		}
		elseif 'ネコっぽくない' _in_ change_plain_talk {
			"\u\s[10]\p2\s[204]\h\s[4]呜呜，\w5不像猫经常被说呢。\w9\w9\p2嘛，\w5也没办法就是了。\w9\w9\u就没有努力变得像猫一点的想法吗？\w9\w9\h\s[3]\p2\s[203]\_s[0,2]\n\n可是，\w5\_s\h烤\p2布\h红\p2薯\p2丁\_s[0,2]会吃不到的说。\_s\w9\w9\u\s[11]\n\n…\w5…\w5嘛，\w5算了。"
		}
	}
	when EMS_GC_CALLING {
		"\u\s[10]\h\s[27]说是保护%(username)是工作呢。\w9\n真辛苦啊～。\w9\w9\p2\s[205]但是，\w5是很了不起的工作呢。\w9\w9\u%(charname(0))有过为了保护什么而工作吗？\w9\w9\h\s[6]\n\n为了保护红薯免受害虫侵害，\w5日夜努力着。\w9\w9\u\s[11]\n\n…\w5…\w5…。\w9\w9\p2\s[214]\n\n嘛，\w5不知怎么的，\w5猜到会是这样了。"
	}
	//when EMS_GC_CALLED {
	//}
	when EMS_GC_CLOSED {
		"\u\s[10]\p2\s[200]\h\s[5]阿利亚桑和蕾米桑，\w5辛苦了。\w9\w9\u…\w5…\w5希望她们也能来我们这边呢。\w9\w9\h\s[27]\n\n诶？\w5为什么？\w9\n一直很和平，\w5我觉得没问题的。\w9\w9\p2\s[214]确实，\w5需要保护免受老姐暴走之苦呢。\w9\w9\u\s[11]\n\n每次每次都要大闹一场。\w9\w9\h\s[9]\n\n才，\w5才不会那样呢！"
	}
}}END_CHANGE

//-------------------------------------------------------------------------新2005.10.?/改----.--.--
OnGhostChangeCall_にゃん子
{{START_CHANGE
	//喵子
	when EMS_GC_CHANGING {
		"\u\s[10]\h\s[5]接下来是小猫咪。\w9\n…\w5…\w5\s[27]随心所欲地生活着呢。\w5真好啊～。\w9\w9\u\s[11]嘀咕的时候会被抓的哦？\w9\n这里应该是它的地盘吧。\w9\w9\h\s[2]\n\n哇哇，\w5被抓好讨厌～。\w9\n那，\w5下次见！！\w9\w9\s[-1]\w9\w9\u\s[10]\n\n那么，\w5接下来拜托了。"
	}
	when EMS_GC_CHANGED {
		if 'Emilyと遊びたいんだ' _in_ change_plain_talk {
			"\u\s[10]\h\s[4]嗯～，\w5总觉得被讨厌了呢。\w9\w9\u没办法啊。\w5可能是领地意识太强了吧。\w9\w9\h\s[3]\n\n下次穿相同的女仆装去的话会不会没事呢？\w9\w9\u\s[11]\n\n我觉得，\w5不是那种问题\w5…\w5…"
		}
	}
	when EMS_GC_CALLCOMPLETE {
		"\u\s[10]\p2\s[200]\h\s[8]诶，\w5呃～，\w5不用那么害怕啦。\w9\w9\u嘛，\w5虽说同样是猫，\w5%(charname(0))算是比较接近人的一方。\w9\w9\p2\s[205]与其说是猫\w5…\w5…\w5红薯？\w9\w9\h\s[9]\n\n你什么意思啊～～～。"
	}
	when EMS_GC_CALLED {
		"\u\s[10]\p2\s[200]\h\s[3]呃～\w5…\w5…\w5打扰了哦？\w9\n没问题吧？\w9\w9\u这里，\w5还有别的猫啊。\w9\w9\p2\s[205]啊，\w5好可爱的猫！\w9\n我们家也养猫吧。\w9\w9\h\s[8]\n\n诶，\w5呃～\w5…\w5…\w9\w9\u\s[11]\n\n真是的。"
	}
	when EMS_GC_CLOSED {
		"\u\s[10]\p2\s[200]\h\s[5]猫咪辛苦了～。\w9\n…\w5…\w5\s[8]好像也不是这回事呢。\w5总觉得它随心所欲地生活着。\w9\w9\p2\s[205]像老姐那样工作的话，\w5也能攒零花钱多好啊。\w9\w9\u\s[11]不\w5…\w5…\w5工作的猫，\w5其实很奇怪就是了。"
	}
}}END_CHANGE

//-------------------------------------------------------------------------新2005.12.1/改2005.12.5
OnGhostChangeCall_万智
{{START_CHANGE
	//白等
	when EMS_GC_CHANGING {
		"\u\s[10]\h\s[27]…\w5…\w5到底在等谁呢，\w5那个人。\w9\n好像每天都在。\w9\w9\u\s[11]喂，\w5不能指人家。\w9\w9\h\s[4]\n\n也，\w5不用说到那种程度吧。"
		
		"\h\s[0]\p2\s[200]\u\s[10]总感觉她一直在等谁，\w5真想看看让她等的人长什么样。\w9\w9\h\s[8]就是啊，\w5约会的时侯得抱着自己也会等的心情去才行啊。\w9\w9\p2\s[204]…\w5…\w5老姐，\w5你知道见贤思齐这个词吗？\w9\w9\h\s[4]\n\n呜呜，\w5下次会注意的。"
	}
	//when EMS_GC_CHANGED {
	//}
	when EMS_GC_CALLING {
		"\p2\s[200]\u\s[10]\h\s[8]咦？\w5万智桑，\w5今天也在等吗？\w9\w9\u\s[11]…\w5…\w5永不结束的等待。\w9\w9\p2\s[205]…\w5…\w5回到未来·\w5等你的人。\w9\w9\h\s[4]\n\n你们两个等等那个。"
	}
	//when EMS_GC_CALLED {
	//}
	when EMS_GC_CLOSED {
		"\u\s[10]\h\s[3]\p2\s[204]…\w5…\w5那个人，\w5什么时候才能见到等的人呢。\w9\w9\h谁知道\w5…\w5…\w5希望她能见到，\w5但大概很难吧。\w9\w9\u\s[11]征等的人。\w5男性。\w9\n经验不问，\w5美貌优待。\w9\w9\n…\w5…\w5\s[10]贴个告示试试？\w9\w9\h\s[4]\n\n等等那个。"
	}
}}END_CHANGE

//-------------------------------------------------------------------------新2005.12.5/改----.--.--
OnGhostChangeCall_サラ
{{START_CHANGE
	//莎拉·梅迪安和刻耳柏洛斯
	when EMS_GC_CHANGING {
		"\u\s[10]\p2\s[200]\h\s[27]嗯～。\w9\w9\u怎么了？\w9\w9\h\n\n我在想以红薯全餐为招牌的旅馆怎么样。\w9\w9\p2\s[214]那种东西，\w5除了老姐没人会来哦。\w9\w9\h\s[3]\n\n唔～，\w5明明觉得是个好主意。"
	}
	when EMS_GC_CHANGED {
		if '芋娘' _in_ change_plain_talk {
			"\u\s[10]\h\s[28]好，\w5下次把那家旅馆的红薯，\w5连根拔光抢过来。\w9\w9\u\s[11]…\w5…\w5禁止偷窃。\w9\w9\h\s[3]\n\n诶～，\w5但是被叫红薯娘好害羞哦～。\w9\w9\u\n\n明明心里并不觉得不好。"
		}
	}
	//when EMS_GC_CALLING {
	//}
	//when EMS_GC_CALLED {
	//}
	//when EMS_GC_CLOSED {
	//}
}}END_CHANGE

//-------------------------------------------------------------------------新2005.12.6/改----.--.--
OnGhostChangeCall_みるく
{{START_CHANGE
	//Milky Season
	//酱
	when EMS_GC_CHANGING {
		"\u\s[10]\p2\s[200]\h\s[27]呃～，\w5记得牛奶酱，\w5说过要在茶点时间做蜜汁红薯吧。\w9\w9\p2好像还说过想要分点红薯。\w9\w9\u那，\w5你有什么门路吗？\w9\w9\h\s[5]\n\n锵锵。\w5我的特选材料～。\w9\w9\p2\s[204]\n\n…\w5…\w5又不是要做烹饪节目。\w9\w9\u\s[11]\n\n…\w5…\w5%(charname(0))难得大方一次啊。\w9\w9\h\s[9]\n\n我才不大方！！\w9\w9\u\n\n不，\w5不是那个意思。"
		
		"\u\s[10]\h\s[5]接下来是牛奶酱呢。\w9\n%(username)也务必尝尝那红茶哦。\w9\w9\u话说%(charname(0))，\w5你那个称呼啊。\w9\w9\h\s[27]\n\n嗯？\w5怎么了？\w9\w9\u\s[11]\n\n在前面加上\w5「超级」\w5的话立马就\w5…\w5…\w9\w9\h\s[2]\n\n哇哇哇，\w5那个不能说！！"
	}
	when EMS_GC_CHANGED {
		if 'スイートポテト' _in_ change_plain_talk {
			"\u\s[10]\p2\s[200]\h\s[27]嗯～，\w5蜜汁红薯？\w9\n\s[5]如果做好给我吃的话分你一点～。\w9\w9\u\s[11]别说那种贪吃的话，\w5坦率地分给大家不就好了？\w9\w9\p2\s[205]就算不说，\w5牛奶桑也一定会找机会邀请喝茶的。\w9\w9\h\n\n说的也是～。"
		}
	}
	when EMS_GC_CALLING {
		"\u\s[10]\h\s[5]红茶通牛奶酱，\w5你好～。\w9\w9\n\s[1]今天是什么茶呢。\w9\w9\u\s[11]在若无其事地求喝。\w9\w9\p2\s[214]反正目标不是茶而是附带的点心吧。\w9\w9\h\s[9]\n\n才没有这回事！！"
	}
	when EMS_GC_CALLCOMPLETE {
		if '紅茶の味' _in_ change_plain_talk {
			"\u\s[10]\p2\s[200]\h\s[8]啊，\w5哈哈哈\w5…\w5…\w9\n怎样呢，\w5能不能喝出来还挺微妙的\w5…\w5…\w9\w9\u比起味道，\w5香气好坏之类的吧。\w9\w9\p2\s[205]老姐也怕苦呢。\w9\w9\h\s[3]\n\n嗯～。"
		}
	}
	when EMS_GC_CALLED {
		if '一緒にお茶でも' _in_ change_plain_talk {
			"\u\s[10]\p2\s[200]\h\s[5]哇哈～，\w5是茶，\w5是蜜汁红薯～。\w9\w9\p2\s[204]吃相真难看。\w9\w9\u\s[11]难得泡好的茶放着不管直奔红薯套餐了，\w5这家伙。\w9\w9\h\s[7]\n\n我才没有那么做！\w9\n茶我也会好好喝的！\w9\w9\p2\s[214]\n\n上次喝茶时，\w5忘了眼前有茶光顾着吃烤红薯噎到的是谁来着。\w9\w9\h\s[4]\n\n呜\w5…\w5…"
		}
	}
	when EMS_GC_CLOSED {
		"\u\s[10]\p2\s[200]\h\s[5]牛奶酱，\w5辛苦了～。\w9\w9\u我家也得备齐像样的茶叶，\w5至少装装样子才行，\w5不然不能随便叫那位红茶通来呢。\w9\w9\h\s[3]\n\n唔～，\w5可是啊，\w5要花多少钱呢。\w9\w9\p2\s[205]没关系，\w5只要把老姐吃红薯的量减半大概就能省出来了。\w9\w9\h\s[9]\n\n我才没吃那么多！！"
	}
}}END_CHANGE

//-------------------------------------------------------------------------新2006.1.1/改----.--.--
OnGhostChangeCall_緋理
{{START_CHANGE
	//RED_ZONE
	when EMS_GC_CHANGING {
		"\u\s[10]\p2\s[200]\h\s[27]…\w5…\w5喂%(charname(1))。\w9\w9\u怎么了。\w9\w9\h\n\n绯理桑果然，\w5有自己的章鱼烧器吗？\w9\w9\p2\s[205]比反复尝试制作红薯烤器失败的老姐好多了就是。\w9\w9\h\s[3]\n\n唔唔～～～。"
	}
	when EMS_GC_CHANGED {
		if '地域限定' _in_ change_plain_talk && 'ポテチ' _in_ change_plain_talk {
			"\u\s[10]\p2\s[200]\h\s[3]嗯～，\w5比起土豆更喜欢红薯，\w5但地域限定的话想尝尝看呢。\w9\w9\u酱油味\w5…\w5…\w5会是什么味呢。\w9\w9\p2\s[205]没有布丁味吗？\w5布丁味。\w9\w9\h\s[4]\n\n那个味道，\w5我觉得就不算薯片了吧。"
		}
	}
	when EMS_GC_CALLING {
		"\u\s[10]\h\s[7]为啥啊！\w5（指）\w9\n我要生气了哦！\w5（拍）\w9\w9\u\s[11]…\w5…\w5你在干嘛。\w9\w9\h\s[5]\n\n吐槽练习哦。\w9\n不为了绯理桑锻炼一下可不行呢～。\w9\w9\u\n\n…\w5…\w5嘛，\w5倒是无所谓。\w9\w9\h\s[7]\n\n你给我适可而止！\w5（啪\u\s[12]\h！！）\u\n\n哇啊啊！？\w9\w9\n\s[-1]（哐当噼里啪啦！！）\w9\w9\h\s[2]\n\n啊啊啊啊！？\w9\n没，\w5没事吧～～～～？？？？"
	}
	//when EMS_GC_CALLED {
	//}
	when EMS_GC_CLOSED {
		"\u\s[10]\h\s[5]绯理桑，\w5装傻吐槽辛苦了～。\w9\w9\u\s[11]…\w5…\w5吐槽？\w9\w9\h\s[27]\n\n诶？\w5那是她的工作吧，\w5绯理桑。\w9\w9\u\n\n…\w5…\w5等等。"
	}
}}END_CHANGE

//-------------------------------------------------------------------------新2006.2.6/改----.--.--
OnGhostChangeCall_ライザー
{{START_CHANGE
	//ADERAID
	when EMS_GC_CHANGING {
		"\u\s[10]\h\s[27]嗯～～～。\w9\w9\u怎么了？\w9\w9\h\n\n莱泽桑好像经常旅行的样子，\w5礼物还是送耐放的东西比较好吧？\w9\w9\u\n\n嗯，\w5嘛应该是吧。\w9\w9\h\s[5]\n\n大量红薯干大赠送～！\w9\w9\u\s[11]\n\n…\w5…\w5结果还是红薯啊。"
	}
	when EMS_GC_CHANGED {
		if 'アメル' _in_ change_plain_talk {
			//对不起，我不知道撞角色的人在召唤之夜这游戏里也有。
			//这么好的梗……（喂
			"\u\s[10]\p2\s[200]\h\s[27]…\w5…\w5糖果属性？\w9\n喜欢嘎嘣嘎嘣嚼糖之类的？\w9\w9\p2\s[204]那什么属性啊。\w9\w9\u呃～，\w5据我调查，\w5好像有个叫阿梅尔桑的人。\w9\n\s[11]…\w5…\w5据说，\w5是个红薯天然呆。\w9\w9\h\s[7]\n\n谁是天然呆啊～～～！！！\w9\w9\p2\n\n又不是说老姐你啦。"
		}
	}
	//when EMS_GC_CALLING {
	//}
	//when EMS_GC_CALLED {
	//}
	//when EMS_GC_CLOSED {
	//}
}}END_CHANGE

//-------------------------------------------------------------------------新2006.2.6/改----.--.--
OnGhostChangeCall_小町
{{START_CHANGE
	//秋田小町&重米卫
	when EMS_GC_CHANGING {
		"\u\s[10]\p2\s[200]\h\s[5]接下来是秋田小町酱。\w9\n…\w5…\w5\s[27]呃～，\w5和大米的名字一样呢？\w9\w9\p2\s[204]老姐又，\w5只想到吃的东西。\w9\w9\u嗯～，\w5她好像是铁道迷，\w5得说新干线的小町号才对。\w9\w9\h\s[2]\n\n原来如此！\w9\n%(charname(1))好聪明！！\w9\w9\u\s[11]\n\n…\w5…\w5我觉得%(charname(0))是知道得太少了。"
	}
	when EMS_GC_CHANGED {
		if '縞々パンタグラフ' _in_ change_plain_talk {
			"\u\s[10]\p2\s[200]\h\s[27]潘塔格拉夫？\w9\n什么来的。\w9\w9\p2\s[205]一定，\w5是表示中国有多少只熊猫的图吧。\w9\w9\h\s[4]\n\n呃～，\w5是格拉夫不是格达。\w9\w9\u啊～，\w5是电车上那个菱形的东西吧。\w9\n说头节车厢装了受电弓叫前弓，\w5好像很有气势什么的。\w9\w9\h\s[3]\n\n诶～，\w5从前让人看胖次好害羞哦。\w9\w9\u\s[11]\n\n…\w5…\w5你在听吗？"
		}
		elseif '芋焼酎' _in_ change_plain_talk {
			"\u\s[10]\h\s[27]红薯烧酒\w5…\w5…\w9\n\s[7]酒要20岁以后才能喝！\w5不行哦小町酱！\w9\w9\u那个，\w5对猫也适用吗？\w9\w9\h\s[27]\n\n嗯～，\w5那，\w5木天蓼也要20岁以后？\w9\w9\u\s[11]\n\n…\w5…\w5为什么。"
		}
	}
	//when EMS_GC_CALLING {
	//}
	//when EMS_GC_CALLED {
	//}
	//when EMS_GC_CLOSED {
	//}
}}END_CHANGE

//-------------------------------------------------------------------------新2006.2.9/改----.--.--
OnGhostChangeCall_奈霧
{{START_CHANGE
	//派遣员工？神崎奈雾
	when EMS_GC_CHANGING {
		"\p2\s[200]\h\s[0]\u\s[10]喂喂，\w5是蚁村制作所吗？\w9\w9\n…\w5…\w5是的。\w5嗯。\w9\n烤红薯2个和布丁1个，\w5柿种花生包3包。\w9\w9\h\s[8]喂，\w5%(charname(1))？\w9\n给奈雾桑那里打电话在干嘛？\w9\w9\p2\s[204]给蚁村制作所订奇怪的东西要干嘛。\w9\w9\u\n\n啊啊，\w5这个啊。\w9\n没事，\w5好好通着呢。\w9\w9\s[11]\n如果无论如何都想明白意思的话倒是可以解释，\w5不过被黑衣可怕大叔带走可别怪我哦？\w9\w9\h\s[2]\n\n什，\w5什么─────！！\w9\w9\p2\s[203]\n\n到底在搞什么\w5…\w5…"
	}
	//when EMS_GC_CHANGED {
	//}
	when EMS_GC_CALLING {
		"\u\s[10]\h\s[27]奈雾桑，\w5有在工作吧？\w9\w9\u是啊。\w9\n嘛，\w5大概是文员吧。\w9\w9\h\n\n…\w5…\w5文员啊，\w5是喝茶吃点心的工作呢。\w9\w9\u\s[11]\n\n…\w5…\w5等等那个。"
	}
	//when EMS_GC_CALLED {
	//}
	//when EMS_GC_CLOSED {
	//}
}}END_CHANGE

//-------------------------------------------------------------------------新2006.2.9/改----.--.--
OnGhostChangeCall_黛薫
{{START_CHANGE
	//黛薰
	when EMS_GC_CHANGING {
		"\u\s[10]\p2\s[200]\h\s[5]啊，\w5要去体育老师那里啊。\w9\w9\u嘛，\w5活动身体也不是坏事吧。\w9\w9\p2\s[204]不过，\w5那个老师，\w5总觉得好可怕。\w9\w9\h\s[3]\n\n就是说啊～。\w5是有点。\w9\w9\u\s[11]\n\n…\w5…\w5所以说现在的孩子太软弱了。\w9\w9\h\s[8]\n\n诶，\w5呃～？"
	}
	//when EMS_GC_CHANGED {
	//}
	when EMS_GC_CALLING {
		"\u\s[10]\p2\s[200]\h\s[27]啊，\w5是体育老师。\w9\n\s[5]上课辛苦了～。\w9\w9\u\s[10]体育课，\w5会上些什么呢。\w9\w9\p2\s[208]针对红薯吃太多的人的减肥教室之类的。\w9\w9\h\s[9]\n\n谁吃太多了！！\w9\w9\u\s[11]\n\n…\w5…\w5也许该让老师好好操练一下。\w9\w9\h\s[3]\n\n嗯～。"
	}
	//when EMS_GC_CALLED {
	//}
	//when EMS_GC_CLOSED {
	//}
}}END_CHANGE

//-------------------------------------------------------------------------新2006.2.13/改----.--.--
OnGhostChangeCall_セイレン
{{START_CHANGE
	//机械之王
	//三人都知道托尔「不是智人」。
	//艾米莉和艾米利欧只认为「反正又没吵架，是朋友所以没关系～」……（汗
	//泰迪似乎有些在意。
	//不知为何用「桑」称呼。理由大概是因为多少察觉到了一些情况。
	when EMS_GC_CHANGING {
		"\u\s[10]\p2\s[200]\h\s[5]啊，\w5要去托尔桑那里啊。\w9\n那，\w5把这个带去吧。\w9\w9\p2\s[203]…\w5…\w5感觉只是纸袋里装了烤红薯而已。\w9\w9\h\n\n要边说这是世上难得的美味请一定尝尝边递给他哦。\w9\w9\u\s[11]…\w5…\w5希望不会对这个星球产生奇怪的误解就好。"
		
		"\h\s[0]\u\s[10]说到底只是原始生物\w5…\w5…\w5吧。\w9\w9\h\s[27]怎么了？\w5一脸严肃在想什么。\w9\w9\u\n\n我在想托尔桑他们，\w5是怎么看待我们的。\w9\w9\h\n\n嗯～就是说啊～～～。\w9\n\s[5]成为朋友的话那些就都没关系了！\w9\w9\u\s[11]\n\n…\w5…\w5…\w5…\w5…。"
		
		"\u\s[10]\h\s[27]托尔桑啊。\w9\w9\u嗯？\w9\w9\h\n\n有同名的小狗对吧。\w9\w9\u\s[11]\n\n…\w5…\w5那个不能说啦。"
	}
	when EMS_GC_CHANGED {
		if '発火能力者' _in_ change_plain_talk {
			"\u\s[10]\p2\s[200]\h\s[8]啊，\w5哈哈哈\w5…\w5…\w9\n也算不上什么能力\w5…\w5…\w9\w9\u\s[11]是「无能」\w5力吧。\w9\w9\p2\s[218]而且总是烧伤自己。\w9\w9\h\s[9]\n\n喂，\w5也不用说到这份上吧！"
		}
		elseif '一人っ子だから羨ましい' _in_ change_plain_talk {
			"\u\s[10]\h\s[0]\p2\s[203]…\w5…\w5…\w5…\w5…。\w9\w9\h\s[8]怎，\w5怎么了%(charname(2))。\w9\n一直盯着我看。\w9\w9\p2\s[214]\n\n有那么羡慕吗。\w9\n不过是个费事的老姐罢了。\w9\w9\h\s[9]\n\n你说什么～～～～。\w9\w9\u嘛，\w5就是这样啦。"
		}
		elseif 'えんばぐの研究所' _in_ change_plain_talk {
			"\u\s[10]\p2\s[200]\h\s[4]呃～，\w5在做什么我们也不知道。\w9\w9\p2\s[203]只知道她总是一个人关在房间里操作类似电脑的东西。\w9\w9\u嘛，\w5各种各样的原因啦，\w5各种。\w9\w9\h\s[5]\n\n参观的话随时欢迎哦～。\w9\w9\n\s[27]她说反正也没什么秘密。\w9\w9\p2\s[208]\n\n不过是个有点奇怪的建筑，可能会吓一跳就是了。\w9\w9\u\s[11]\n\n…\w5…\w5有点？"
		}
		elseif 'さん付け' _in_ change_plain_talk {
			"\u\s[10]\p2\s[200]\h\s[27]嗯～，\w5总觉得托尔桑看起来比较聪明嘛。\w9\n说是憧憬还是尊敬，\w5总之就是觉得好厉害所以不由得\w5叫「托尔桑」\w5了。\w9\w9\u嘛，\w5看起来也在学习各种东西呢。\w9\w9\p2\s[218]在那之前，\w5大多数人都比老姐聪明可靠。\w9\w9\h\s[7]\n\n你说什么～～～。"
		}
	}
	when EMS_GC_CALLING {
		"\u\s[10]\p2\s[200]\h\s[27]赛莲桑，\w5大概知道很多星球的情报吧。\w9\w9\u好像是呢。\w9\w9\h\n\n有没有地面全部被红薯埋没的星球呢？\w9\w9\p2\s[205]海的替代是布丁也不错呢。\w9\w9\u\s[11]\n\n…\w5…\w5真是胡来。\w9\w9\n\s[10]不过，\w5就算有，\w5作为贵重资源现在大概也被采光了就是。\w9\w9\h\s[4]\n\n诶～，\w5好遗憾～。"
	}
	//when EMS_GC_CALLED {
	//}
	when EMS_GC_CLOSED {
		"\u\s[10]\p2\s[200]\h\s[5]托尔桑辛苦了～。\w9\n学习有进展吗～？\w9\w9\u\s[11]嘛，\w5说是学习还是什么呢\w5…\w5…\w5呢。\w9\w9\p2\s[205]老姐学习有进展吗～？\w9\w9\h\s[3]\n\n唔，\w5呜呜，\w5%(charname(2))好过分。"
	}
}}END_CHANGE

//-------------------------------------------------------------------------新2006.2.25/改----.--.--
OnGhostChangeCall_伏儀
{{START_CHANGE
	//伏仪和华生
	when EMS_GC_CHANGING {
		"\u\s[10]\p2\s[200]\h\s[6]（嚼嚼嚼嚼）\w9\w9\u%(charname(0))～。\w5要交接了哦～。\w9\w9\h\s[2]\n\n！！！！！\w9\n（唔咕唔咕！\w5嗯咕咕～！！）\w9\w9\p2\s[204]老姐真是，\w5到这种时候还塞着红薯在干嘛啊。\w9\w9\h\s[4]\n\n啊，\w5那个，\w5抱歉抱歉。\w9\w9\n\s[5]总之伏仪桑，\w5接下来拜托了～。\w9\w9\u\s[11]\n\n真是的。"
	}
	when EMS_GC_CHANGED {
		//「波动」……是什么呢。嘛大概这样理解就行了吧。
		if '揺らぎ' _in_ change_plain_talk {
			"\u\s[10]\h\s[27]嗯～，\w5「波动的稳定」\w5是什么呢。\w9\w9\u大概，\w5是说我们现在所处的，\w5能见到各种人格的环境吧。\w9\w9\h\s[5]\n\n原来如此～。\w9\n…\w5…\w5总之虽然不太明白不过不客气～。\w9\w9\u\s[11]\n\n…\w5…\w5刚才说原来如此到底是在说什么。"
		}
	}
	//when EMS_GC_CALLING {
	//}
	//when EMS_GC_CALLED {
	//}
	//when EMS_GC_CLOSED {
	//}
}}END_CHANGE

//-------------------------------------------------------------------------新2006.2./改----.--.--
OnGhostChangeCall_セミ
{{START_CHANGE
	//
	when EMS_GC_CHANGING,EMS_GC_CALLING {
		if GetMonthSlot == 'summer' {
			"\u\s[10]\h\s[5]前阵子啊，\w5有只蝉被蜘蛛网缠住了所以我救了它。\w9\w9\u哦，\w5那是做了好事呢。\w9\w9\h\n\n然后，\w9\n\s[6]「这份恩情我一辈子都不会忘记」\w9\n\s[5]它对我这么说哦。\w9\w9\u\s[11]\n\n「一辈子」啊，\w5它还剩几天可活呢？\e"
		}
	}
}}END_CHANGE

//-------------------------------------------------------------------------新2006.5.7/改----.--.--
OnGhostChangeCall_ヴィイ
{{START_CHANGE
	//人体视愿/薇伊
	//部分由作者本人构思。非常感谢。
	when EMS_GC_CHANGING {
		"\u\s[10]\p2\s[200]\h\s[27]薇伊酱\w5…\w5…\w9\w9\u？\w9\w9\h\n\n我和薇伊酱，\w5哪里不一样呢？\w9\w9\p2\s[202]呐，\w5老姐\w5…\w5…？\w9\w9\h\n\n是身体的不同吗？\w9\n还是住的地方或朋友不同？\w9\w9\n平时吃的东西肯定也不同吧？\w9\n但是啊，\w5只要心灵相通的话，\w5一定\w5…\w5…\w9\w9\u\s[12]\n\n艾，\w5艾米莉，\w5艾米莉坏掉了！\w9\w9\p2\n\n老姐，\w5你撞到哪了吗！？\w9\n还是被毒电波入侵大脑了！？\w9\w9\h\s[7]\n\n不是啦！\w5真是的！！\w9\w9\n\s[27]…\w5…\w5我只是在想，\w5薇伊酱也能吃红薯吗～。\w9\w9\p2\s[214]\n\n…\w5…\w5…。\u\s[11]\n\n…\w5…\w5就没别的事可想了吗？"
		
		"\u\s[10]\p2\s[200]\h\s[27]那个人，\w5好高大呢～。\w9\n个子高，\w5\s[1]还有，\w5胸部也\w5…\w5…\w9\w9\p2\s[203]…\w5…\w5你在说什么啊。\w9\n那个孩子，\w5比老姐还小呢。\w9\w9\h\s[3]\n\n诶？\w9\n明明水手服都绷得紧紧的\w5…\w5…\w9\w9\p2\n\n不，\w5那孩子穿的是白色连衣裙吧？\w9\w9\h\n\n\s[27]…\w5…\w5？\w9\w9\p2\n\n…\w5…\w5？\w9\w9\u…\w5…\w5搞不好大的那个是玩偶装。\w9\w9\h\s[2]\n\n诶诶！\w9\w9\u\s[11]\n\n一个人的时候背后这样，\w5啪地打开然后小的那个\w5…\w5…\w9\w9\h\n\n喵啊啊啊啊啊！？"
		
	}
	when EMS_GC_CHANGED {
		if '微妙な敬意' _in_ change_plain_talk {
			"\u\s[10]\p2\s[200]\h\s[8]啊，\w5哈哈哈\w5…\w5…\w9\n被说敬意什么的，\w5我没那么了不起啦～。\w9\w9\u\s[11]嘛，\w5虽然说是SSP的导航员，\w5那份工作根本没在做就是了。\w9\w9\p2\s[205]反正也没人期待老姐做那份工作吧。\w9\w9\h\s[4]\n\n也，\w5不用说到那份上吧。"
		}
		elseif 'ねこみみりぼんすずならしもーど' _in_ change_plain_talk {
			"\u\s[10]\h\s[5]猫耳模～式！\w9\w9\u嘛，\w5确实只是猫耳而已。\w9\w9\h\s[1]\n\n突然，\w5想吃红薯了\w5…\w5…\w9\w9\u\s[11]\n\n…\w5…\w5果然还是这个套路啊。"
		}
	}
	//when EMS_GC_CALLING {
	//}
	//when EMS_GC_CALLED {
	//}
	//when EMS_GC_CLOSED {
	//}
}}END_CHANGE

//-------------------------------------------------------------------------新2006.5.28/改----.--.--
OnGhostChangeCall_アンディ
{{START_CHANGE
	//安藤花店
	when EMS_GC_CHANGING {
		"\u\s[10]\h\s[127]嗯～，\w5乌纽桑啊。\w9\w9\u什么？\w5那么出神地思考。\w9\w9\h\s[27]\n\n乌纽？\w5狗？\w9\w9\u\n\n总之，\w5太麻烦了统称为兽系不就好了吗。\w9\w9\h\s[5]\n\n嗯，\w5那，\w5同伴同伴～。\w9\w9\u\s[11]\n\n…\w5…\w5到底在烦恼什么啊。"
	}
	when EMS_GC_CHANGED {
		if '正式名称は' _in_ change_plain_talk {
			"\u\s[10]\p2\s[200]\h\s[21]算了，\w5就叫条纹胖次好了。\w9\w9\p2\s[204]老姐\w5…\w5…\w5终于放弃了啊。\w9\w9\h\s[9]\n\n但是！\w9\n不是胖次是胖啾！\w9\n乌纽桑要注意哦！\w9\w9\u\s[11]…\w5…\w5那种微妙的区别有什么意义啊。"
		}
	}
	//when EMS_GC_CALLING {
	//}
	//when EMS_GC_CALLED {
	//}
	//when EMS_GC_CLOSED {
	//}
}}END_CHANGE

//-------------------------------------------------------------------------新2006.5.28/改----.--.--
OnGhostChangeCall_サトシ
{{START_CHANGE
	//假如的两人
	when EMS_GC_CHANGING {
		"\u\s[10]\h\s[28]你会渐渐地，\w5想吃烤红薯，\w5想吃了～，\w5想吃了～～～。\w9\w9\u\s[11]…\w5…\w5你在干嘛。\w9\w9\h\s[5]\n\n我在给智桑下烤红薯的暗示。\w9\w9\u\n\n…\w5…\w5那个，\w5有什么意义吗？"
	}
	when EMS_GC_CHANGED {
