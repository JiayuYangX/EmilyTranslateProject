//-------------------------------------------------------------------------新2006.5.28/改----.--.--
OnGhostChangeCall_ガブリエ
{{START_CHANGE
	//苍之骑士们
	when EMS_GC_CHANGING {
		"\u\s[10]\p2\s[200]\h\s[27]嗯～，\w5我们叫做【亚人族】呢。\w9\w9\p2%(charname(1))姑且不论，\w5我们好像是的。\w9\w9\u\s[11]嘛，\w5喜欢烤红薯和布丁这点就不像正常的猫了。\w9\w9\h\s[7]\p2\s[207]\_s[0,2]\n\n什么意思\_s\h啊\p2\h！\p2！"
	}
	when EMS_GC_CHANGED {
		if '懐かれたければ' _in_ change_plain_talk {
			"\p2\s[200]\h\s[0]\u\s[10]这里有一只世上罕见的伪猫，\w5然后取出的是烤红薯和布丁。\w9\w9\n各位看官。\w5两种食物摆在眼前的话\w5…\w5…\w9\w9\h\s[5]\p2\s[205]\_s[0,2]喵～～～。\_s\w9\w9\u\n\n好的就是这样，\w5很简单就能驯服。\w9\w9\h\s[7]\p2\s[207]\_s[0,2]\n\n喂，\w5你让\_s\h我\p2干\h什\p2么\h啊\p2！！\w9\w9\u\n\n呼呼。"
		}
		elseif '男の子の方' _in_ change_plain_talk {
			"\u\s[10]\p2\s[200]\h\s[5]%(charname(2))～。\w9\n说你喜欢米迦勒桑哦。\w9\w9\p2\s[208]还，\w5还好吧。\w9\n被那么漂亮的大姐姐那么说倒也不坏。\w9\w9\u%(charname(2))难得这么老实呢。\w9\n平时被说喜欢的话就会生气好像要被追着跑似的。\w9\w9\h\s[28]\n\n难不成，\w5你觉得能拿到布丁吧？\w5这才是目的吧。\w9\w9\p2\s[217]\n\n我才不会像老姐那样想！"
		}
	}
	//when EMS_GC_CALLING {
	//}
	//when EMS_GC_CALLED {
	//}
	//when EMS_GC_CLOSED {
	//}
}}END_CHANGE

//-------------------------------------------------------------------------新2006.5.28/改----.--.--
OnGhostChangeCall_ベル
{{START_CHANGE
	//贝尔和梅尔
	when EMS_GC_CHANGING {
		"\u\s[10]\h\s[5]啊，\w5有和%(charname(1))有一样翅膀的人～。\w9\w9\u是妖精呢。\w9\n和我的翅膀似是而非就是了。\w9\w9\h\s[27]\n\n嘿～。\w5有什么不同？\w9\w9\u\n\n我的是PET，\w5梅尔桑的是丙烯制的。\w9\w9\h\s[4]\n\n…\w5…\w5纸板糊的？\w9\w9\u\n\n骗你的。\w9\w9\h\n\n…\w5…\w5什么啊那是～～～。"
	}
	/*when EMS_GC_CHANGED {
