OnGhostChangeCall_ヒトラ氏
{{START_CHANGE
	//Hitra氏&兵unyuu
	//是NETA对不起（殴
	when EMS_GC_CHANGING {
		"\u\s[10]\h\s[27]那个那个，\w5下一个人，\w5大概是德国的大人物。\w9\w9\u\s[11]大概，\w5是什么意思\w5…\w5…。\w9\w9\h\s[4]\n\n可是～，\w5不管怎么看都觉得Irumu桑更聪明嘛～～～。\w9\w9\u\n\n…\w5…\w5…\w5…\w5…。"
	}
	when EMS_GC_CALLING {
		"\u\s[10]\p2\s[200]\h\s[5]德国的大人物们快来～～～。\w9\w9\u\s[11]用这么随便的称呼的话，\w5小心被送进集中营\w5…\w5…\w9\w9\h\s[2]\n\n诶？\w5诶？\w5诶诶诶？？\w9\w9\u\n\n…\w5…\w5有去掉红薯的严厉惩罚等着你哦。\w9\w9\h\s[4]\n\n呜呜，\w5那太残忍了～～～。\w9\w9\p2\s[214]被骗了，\w5被骗了哦老姐。"
	}
	when EMS_GC_CLOSED {
		if RE_SEARCH(reference[1],'\\s\[1\d\d\]') { //宣传部长 必须用ref1
			"\u\s[10]\h\s[5]宣传部长桑和兵unyuu桑辛苦了～。\w9\w9\u"
		}
		else { //那家伙
			"\u\s[10]\h\s[5]德国的大人物和兵unyuu桑辛苦了～。\w9\w9\u"
		}
		--
		"兵unyuu桑，\w5有个难搞的上司辛苦了。\w9\w9\h\s[4]\n\n嗯\w5…\w5…"
		"兵unyuu桑，\w5感觉总有一天会忍不下去跳槽的。\w9\w9\h\s[3]\n\n或许吧\w5…\w5…"
	}
	when EMS_GC_CHANGED {
		if RE_SEARCH(reference[1],'\\s\[1\d\d\]') { //宣传部长 必须用ref1
			"\h\s[0]\u\s[10]…\w5…\w5以上，\w5因为上司太电波终于崩坏了的宣传部长桑。\w9\w9\h\s[4]…\w5…\w5嗯～。"
		}
		else { //那家伙
			"\h\s[0]\u\s[10]…\w5…\w5以上，\w9\n「%(GCC_Hitlar_FalseNews)」\w9\n为您播报。\w9\w9\h\s[4]什么节目啊那是～～～。"
		}
	}
}}END_CHANGE

//-------------------------------------------------------------------------新2005.6.30/改2005.7.6
GCC_Ako_AngelModeClose
{
	"\u\s[10]\h\s[8]呃～，\w5怎么说好呢，\w5天使桑辛苦了。\w9\w9\u好像有什么深层的原因呢。\w9\w9\h\s[27]\n\n去问\_a[GHOST_所長たん]所长\_a的话会知道些什么吗？\w9\w9\u\s[11]\n\n…\w5…\w5我觉得会被说「脑子里enbug忘记了」然后结束。\w9\w9\h\s[3]\n\n诶～～～。\w9\w9\u\s[10]\n\n（不过，\w5虽然其实应该知道些什么，\w5但大概会被随便糊弄过去吧。）\w9\w9\h\s[27]\n\n%(charname(1))？\w5你说了什么？\w9\w9\u\s[12]\n\n啊，\w5啊，\w5啊啊，\w9\w9\s[10]…没什么。"
}

OnGhostChangeCall_アコ
{{START_CHANGE
	//Ako与同伴们
	//Emily知道天使状态的存在。毕竟旁边就有天使（=所长碳）在嘛。
	//虽然并不会就此展开什么深入话题……
	
	when EMS_GC_CHANGING { //不知道对方是不是天使模式所以得找调查方法才行……
		"\u\s[10]\h\s[5]接下来是活泼三人组\w5…\w5…\w5应该是吧。\w9\w9\u\s[11]应该，\w5突然说啥。\w9\w9\h\s[8]\n\n啊，\w5呃，\w5细节别在意。\w9\w9\u\s[10]\n\n嗯～。"
		
		"\u\s[10]\h\s[27]Ako桑，\w5要不把翅膀换成猫耳试试？\w9\w9\u\s[11]…\w5…\w5不，\w5换上干嘛。\w9\w9\h\s[1]\n\n对男性的吸引力绝对没问题。\w9\w9\u\n\n…\w5…\w5到底哪里没问题了。"
		
		"\u\s[10]\p2\s[200]\h\s[27]Ako桑，\w5要不把翅膀换成猫耳试试？\w9\w9\u\s[11]…\w5…\w5把%(charname(0))的揪下来吧。\w9\w9\p2\s[205]从%(charname(0))那揪下来的耳朵，\w5给你便宜点哦～。\w9\w9\h\s[2]\n\n哇哇哇哇，\w5不行不行，\w5这个揪不下来的啦！！"
	}
	when EMS_GC_CHANGED {
		if RE_SEARCH(reference[1],'\\s\[10\d\]') { //Angel Mode 必须用ref1
			GCC_Ako_AngelModeClose
		}
		else {
			if 'ぬこみみ元気っ子' _in_ change_plain_talk {
				"\u\s[11]\p2\s[204]\h\s[5]猫耳元气小子的%(charname(0))登场～！\w9\w9\u永远是个小孩的麻烦猫的监护人。\w9\w9\p2然后受害者一号在这里。\w9\w9\h\s[9]\n\n你，\w5你，\w5你说什么～～～！！"
			}
			else {
				"\u\s[10]\p2\s[200]\h\s[5]喵～喵～咕～咕～，\w5喵～喵～咕～咕～，\w5升天～～～！！！\w9\w9\p2\s[204]老姐，\w5那什么谜之音波啊。\w9\w9\u那么吵闹会打扰到邻居的。\w9\w9\h\s[3]\n\n唔～～～。\w9\n本想学Ako桑她们精神一点过日子的说。\w9\w9\u\s[11]\n\n我说啊。"
			}
		}
	}
	when EMS_GC_CLOSED {
		if RE_SEARCH(reference[1],'\\s\[10\d\]') { //Angel Mode 必须用ref1
			GCC_Ako_AngelModeClose
		}
		else {
			"\u\s[10]\h\s[5]Ako桑，\w5白玉桑，\w5小玉桑，\w5辛苦了～。\w9\w9\u接下来由Emily代替你们跑来跑去。\w9\w9\h\s[9]\n\n不要跑来跑去！\w5好好的！"
		}
	}
}}END_CHANGE

