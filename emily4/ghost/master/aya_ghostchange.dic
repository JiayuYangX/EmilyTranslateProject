//-------------------------------------------------------------------------新????.??.??/改2005.8.1
OnGhostChangeCall_よしの
{{START_CHANGE
	//よしの
	//Emily总是被欺负的角色所以用「桑」
	when EMS_GC_CHANGING {
		"\u\s[10]\h\s[0]\p2\s[205]啊，\w5よしの姐。\w9\n一起调侃老姐吧。\w9\w9\h\s[7]艾\w5米\w5利\w5欧\w5～～！！\e"
	}
	when EMS_GC_CHANGED {
		if 'えらく萌える' _in_ change_plain_talk {
			"\u\s[10]\h\s[1]果然身为SSP导航员，\w5对男性的吸引力也不可或缺呢。\w9\w9\u\s[11]…\w5…\w5嘛，\w5不是直球式的吸引，\w5说起来算得上是所谓的\w5「冒失娘」\w5吧。\w9\w9\h\s[9]\n\n什，\w5什么～～～！！！"
		}
		elseif '債務不履行' _in_ change_plain_talk {
			"\u\s[10]\p2\s[200]\h\s[7]债务不履行这个梗已经过时了！！\w9\w9\p2\s[218]每次老姐犯傻，\w5都会被%(charname(1))用那个梗唠叨呢。\w9\w9\h\s[3]\n\n唔唔～～～。\w9\w9\u\s[11]…\w5…\w5明明说得最多的就是%(charname(2))。"
		}
	}
	when EMS_GC_CALLING {
		"\u\s[10]\h\s[5]出来吧！\w5よしの桑！！\w9\w9\u\s[11]…\w5…\w5用那么嚣张的语气的话，\w5之后会被做很讨厌的事哦？\w9\w9\h\s[2]\n\n啊啊！！\w5刚才的不算不算不算！！！"
	}
	when EMS_GC_CALLED {
		if 'パシらせようかと' _in_ change_plain_talk {
			"\u\s[10]\h\s[55]好～的，\w5我回来了～～～。\w9\w9\u\s[11]…\w5…\w5你在干嘛。\w9\w9\h\s[3]\n\n诶～，\w5不听よしの桑的话，\w5之后会可怕的。\w9\w9\u\n\n…\w5…\w5什么呢，\w5这种窝囊的气氛。"
		}
	}
	when EMS_GC_CLOSED {
		"\u\s[10]\h\s[3]\p2\s[217]切～。\w5接下来正是调侃老姐的好戏呢。\w9\w9\h…\w5…\w5已经\w5…\w5…\w9\w9\u\s[11]啊～，\w5好歹也是姐姐，\w5至少表面上要像样点才行哦%(charname(2))也是。\w9\w9\h\s[4]\n\n连%(charname(1))都\w5…\w5…"
	}
}}END_CHANGE

