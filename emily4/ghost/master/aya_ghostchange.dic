		}
	}
	//when EMS_GC_CALLING {
	//}
	//when EMS_GC_CALLED {
	//}
	//when EMS_GC_CLOSED {
	//}
}}END_CHANGE

//-------------------------------------------------------------------------新2006.5.28/改----.--.--
OnGhostChangeCall_エミット
{{START_CHANGE
	//EFK
	when EMS_GC_CHANGING {
		"\u\s[10]\h\s[9]下次再说条纹胖次，\w5就没收你的烤红薯！\w9\n绝～～～对不能说哦！\w9\w9\u\s[11]…\w5…\w5没收烤红薯什么的，\w5除了%(charname(0))以外没人会在意吧。"
