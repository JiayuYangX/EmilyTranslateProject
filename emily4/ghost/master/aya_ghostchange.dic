OnGhostChangeCall_このみ
{{START_CHANGE
	//K3R
	when EMS_GC_CHANGING {
		"\u\s[10]\h\s[5]博士～。\w9\n下次想请您做%(GCC_K3R_Make)。\w9\w9\u\s[11]…\w5…\w5那个，\w5怎么想都不可能吧。\w9\w9\h\s[3]\n\n唔～，\w5是吗。\w9\w9\u\s[10]\n\n就算是博士也做不出无视物理法则的东西啊。"
	}
	when EMS_GC_CHANGED {
		if 'あるから持っていきや' _in_ change_plain_talk {
			"\u\s[10]\h\s[5]哇～～～伊，\w5博士谢谢～～～。\w9\w9\u\s[11]…\w5…\w5又想带什么可疑的东西回去？"
		}
	}
	when EMS_GC_CALLING {
		"\u\s[10]\h\s[5]元气的助手小姐和\w5…\w5…\w5\s[8]连自己都当作实验台，现在变成了可疑罐头装的博士呀吼～。\w9\w9\u\s[11]…\w5…\w5那个样子，\w5搞不好会被当成奇怪妖怪给退治掉呢。\w9\w9\h\s[4]\n\n确，\w5确实很有可能\w5…\w5…"
	}
	when EMS_GC_CALLED {
		if 'かわいかったら問題あらへん' _in_ change_plain_talk {
			"\u\s[10]\h\s[5]就是啊！\w9\n把像我这样可爱的猫说得那么怪才不对吧！！\w9\w9\u\s[11]…\w5…\w5不，\w5嘛，\w5猫不猫人不人的半吊子存在这点，\w5就已经是谜之生物了。\w9\w9\h\s[3]\n\n诶～～～。"
		}
	}
	when EMS_GC_CLOSED {
		"\u\s[10]\h\s[5]两位研究辛苦了。\w9\w9\u现在在查什么呢。\w9\w9\h\s[27]\n\n一定是，\w5之前拜托的%(GCC_K3R_Make)的做法吧。\w9\w9\u\s[11]\n\n…\w5…\w5那个从根本上就离谱的东西到底是什么。"
	}
}}END_CHANGE

//-------------------------------------------------------------------------新????.??.??/改2005.10.6
OnGhostChangeCall_舞子
{{START_CHANGE
	//舞子和うにゅ丸
	//只有艾米莉用「酱」
	when EMS_GC_CHANGING {
		"\u\s[10]\h\s[0]艾米利欧，\w5舞子酱说换班前想见你。\w9\w9\p2\s[217]不要啦。\w9\n那姐姐，\w5有点可怕。\w9\w9\h\s[7]\n\n艾\w5米\w5利\w5欧\w5～～！！\e"
		
		"\u\s[10]\p2\s[200]\h\s[5]那，\w5和舞子酱换班呢。\w9\w9\p2\s[203]其实啊，\w5今天早上梦到舞子姐姐了。\w9\w9\u也不算坏事吧。\w9\w9\p2\s[204]\n\n结果\w5…\w5…\w9\n梦到うにゅ丸被改造成我的样子，\w5还抱着它诡异地笑。\w9\w9\h\s[2]\n\n什，\w5什么─────！！\w9\w9\u\s[11]\n\n…\w5…\w5那真是个可怕的梦啊。"
	}
	when EMS_GC_CHANGED {
		if RE_SEARCH(reference[1],"\\s\[6\d\]") { //夜 = 60-69 必须用ref1
			"\u\s[10]\h\s[0]\p2\s[205]站着居然能这么开心还是头一回。\w9\w9\h\s[4]…\w5…\w5再多陪陪她嘛。\w9\w9\p2\s[217]\n\n才不要。\w9\w9\u\s[11]哎呀呀。\e"
		}
		elseif '\s[29]' _in_ reference[1] { //睡觉中 29
			"\u\s[10]\p2\s[200]\h\s[8]哈哈\w5…\w5…\w9\n舞子酱，\w5睡着了呢。\w9\w9\p2\s[206]好安静真不错。\w9\w9\h\s[4]\n\n嗯，\w5唔～。"
		}
		else { //白天
			"\u\s[10]\p2\s[200]\h\s[5]艾米利欧要打包带走是吧？\w9\n一共%(RAND(100) + 100)日元。\w9\w9\n要不要一起来份%(charname(1))？\w9\w9\u\s[17]\p2\s[207]\_s[1,2]太便宜了别卖！！\_s\e"
		}
	}
	when EMS_GC_CALLING {
		"\p2\s[200]\u\s[10]\h\s[5]喂，\w5艾米利欧。\w9叫叫她嘛。\w9\w9\p2\s[202]诶。\w9\w9\s[217]我～～？\w9\w9\h\s[8]\n\n那样她最开心啦～。\w9\w9\p2\s[214]\n\n真是的，\w5为什么我…\w5…\w5\w9\w9\s[203]舞子姐～。\e"
	}
	when EMS_GC_CALLCOMPLETE {
		"\u\s[10]\h\s[0]\p2\s[205]那，\w5我有事先走了。\w9\s[-1]\w9\w9\h\s[2]啊，\w5逃跑了～。\e"
	}
	when EMS_GC_CALLED {
		if RE_SEARCH(reference[1],"\\s\[6\d\]") { //夜 = 60-69 必须用ref1
			"\u\s[10]\h\s[0]\p2\s[222]唔～，\w5困死了。\w9\w9\h\s[8]哈哈，\w5果然困了吗～。\w9\w9\u熬夜太多明天会没精神哦？\w9\w9\p2\s[203]\n\n嗯～，\w5不过，\w5总觉得好像被谁叫了。\w9\w9\h\n\n诶？\w9\w9\u\s[11]\n\n一定是\_a[GHOST_舞子]舞子酱\_a那边发来了电波吧。\w9\w9\h\s[3]\n\n什，\w5什么啊那是。"
		}
		else {
			"\u\s[10]\h\s[0]\p2\s[203]唔～，\w5又被舞子小姐叫了。\w9\w9\h\s[3]真好啊～，\w5我也好想被叫啊～。\w5想要茶和点心啊～。\w9\w9\u\s[11]…\w5…\w5这世上终究没那么顺遂呢。\w9\w9\h\s[8]\n\n喂，\w5%(charname(1))？"
		}
	}
	when EMS_GC_CLOSED {
		"\u\s[10]\h\s[0]\p2\s[205]舞子姐，\w5辛苦了。\w9\w9\h\s[3]唔，\w5%(charname(2))好像很开心。\w9\w9\p2\n\n嗯，\w5总算暂时不用被黏着蹭来蹭去了。\w9\w9\h\s[4]\n\n…\w5…\w5哇啊。\w5不能说那种话啦。\e"
	}
}}END_CHANGE

