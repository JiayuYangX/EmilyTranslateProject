//-------------------------------------------------------------------------新????.??.??/改2005.5.12
OnGhostChangeCall_晶子
{{START_CHANGE
	//对方是长辈……但因为争抢艾米利欧所以微妙（笑）
	when EMS_GC_CHANGING {
		"\p2\s[203]\u\s[-1]\h\s[3]唔。\w9\w9\p2怎么了，\w5姐姐。\w9\w9\h\n\n每次去晶子老师那都能吃到蜜汁红薯什么的所以很开心。\w9\w9\p2\s[205]\n\n那就不用担心了嘛。\w9\w9\h\n\n但是，\w5总觉得%(charname(2))会被抢走。\w9\w9\p2\s[204]\n\n…\w5…\w5什么跟什么啊。\e"
	}
	when EMS_GC_CHANGED {
		if '腐女子' _in_ change_plain_talk {
			"\p2\s[204]\u\s[10]\h\s[7]不行！\w5艾米利欧是我的，\w5才不会让给所长呢！\w9\w9\p2…\w5…\w5那是什么意思啊。\w9\w9\n\s[205]啊，\w5不过偶尔～，\w5也会觉得有点帅呢～。\w9\h\s[7]\n\n艾米利欧！！\e"
		}
	}
	when EMS_GC_CALLED {
		if 'お茶会よ' _in_ change_plain_talk {
			"\u\s[10]\p2\s[205]\h\s[5]哇哈～伊，\w5茶会～。\w9\w9\p2%(GetGreeting)，\w5晶子老师。\w9\w9\u承蒙照顾了。\e"
		}
	}
	when EMS_GC_CALLING {
		"\u\s[-1]\p2\s[-1]\h\s[55]%(charname(2))～。\w5%(charname(1))～。\w9\n茶泡好了哦～。\w9\w9\u\s[10]唔，\w5下午茶时间了。\w9\w9\p2\s[205]难得的机会，\w5把一直收人家东西的晶子老师也叫来吧。\w9\w9\u\n\n好主意。\w9\w9\h\s[3]\n\n（没问题吧\w5…\w5…）\e"
	}
	when EMS_GC_CALLCOMPLETE {
		if 'お茶会へのお呼び' _in_ change_plain_talk {
			"\u\s[10]\h\s[0]\p2\s[205]姐姐，\w5带来了哦。\w9\w9\h\s[55]欢迎光临～。\w9\n请慢用哦。\w9\w9\u\s[11]…\w5…\w5没有在茶里下毒吧。\w9\w9\h\s[9]\n\n才不会做那种事！\w5真是的！！\e"
		}
	}
	when EMS_GC_CLOSED {
		"\u\s[10]\h\s[5]晶子老师，\w5辛苦了。\w9\w9\u\s[11]…\w5…\w5一定又想让みたぺん桑代班自己偷懒吧。\w9\w9\h\s[4]\n\n怎么会。\e"
	}
}}END_CHANGE

