		"\u\s[10]\h\s[27]澪桑的魔剑，\w5是魔力块呢。\w9\w9\u嗯？\w5那又怎么了？\w9\w9\h\n\n我想如果用那股魔力来放火的话，\w5能烤多少红薯呢。\w9\w9\u\s[11]\n\n…\w5…\w5大概0.01秒就能把成堆的红薯变成炭吧。\w9\w9\h\s[3]\n\n呜哇，\w5好浪费。\w9\w9\u\n\n在这之前禁止想无聊的事情。\w9\w9\h\s[4]\n\n呃。"
	}
	/*when EMS_GC_CHANGED {
	}*/
	when EMS_GC_CALLING {
		"\u\s[10]\h\s[5]魔剑少女和谜之物体快过来！\w9\w9\u\s[11]…\w5…\w5谜之物体是什么。\w9\w9\h\s[8]\n\n啊，\w5啊哈哈\w5…\w5…\w9\n不知道该怎么称呼Kanchi桑才好。\w9\w9\u\n\nMac OS 8和9的标志\w5…\w5…\w9\w9\h\s[4]\n\n那，\w5那个是\w5…\w5…"
	}
	when EMS_GC_CLOSED {
		"\u\s[10]\h\s[5]澪桑，\w5Kanchi桑，\w5辛苦了。\w9\w9\u感觉是两位有很多故事的组合呢。"
	}
}}END_CHANGE

//-------------------------------------------------------------------------新2005.7.6/改----.--.--
OnGhostChangeCall_マーレ
{{START_CHANGE
	//河豚灯笼
	when EMS_GC_CHANGING {
		"\u\s[10]\h\s[5]Mare桑，\w5海也好但山也好哦！\w9\n下次一起去吧～。\w9\w9\u%(charname(0))明明是猫，\w5会说这种话真少见呢。\w9\w9\h\s[3]\n\n诶？\w5为什么？\w9\w9\u\n\n不，\w5我以为你会喜欢鱼什么的。\w9\w9\h\s[4]\n\n…\w5…\w5你是想说我的脑袋每天只想着食物之类的东西吧？\w9\w9\u\n\n…\w5…\w5原来如此，\w5山里也有河鱼这招啊。\w9\w9\h\s[9]\n\n%(charname(1))！！"
		
		"\u\s[10]\h\s[5]Mare桑，\w5海也好但山也好哦！\w9\n下次一起去吧～。\w9\w9\u\s[11]是去名古屋吃杀伤性食物呢，\w5还是去大阪吃连哭闹的小孩都吓住的像巨塔一样的芭菲呢\w5…\w5…\w9\w9\h\s[7]\n\n不是那个山啦！！"
	}
	when EMS_GC_CALLING {
		"\u\s[10]\p2\s[200]\h\s[5]会说话的河豚桑和喜欢户外活动的Mare桑快来～。\w9\w9\u不，\w5那个真的是河豚吗。\w9\w9\p2\s[205]一定是Mare桑的应急食品。\w9\w9\h\s[4]\n\n禁止那种好像在哪儿听过的结尾～。"
	}
	when EMS_GC_CLOSED {
		"\u\s[10]\h\s[5]Mare桑，\w5Tecchi桑，\w5辛苦了。\w9\w9\u今天%(username)那里一定是河豚火锅吧。\w9\w9\h\s[3]\n\n唔，\w5不会吧。"
	}
	/*when EMS_GC_CHANGED {
	}*/
}}END_CHANGE

