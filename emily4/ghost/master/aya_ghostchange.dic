//-------------------------------------------------------------------------新2005.12.6/改----.--.--
OnGhostChangeCall_カレラ
{{START_CHANGE
	//Carrera☆ -TOKYO TOKYO-
	when EMS_GC_CHANGING {
		"\u\s[10]\h\s[5]呃～，\w5说是日语比英语擅长\w5…\w5…\w5\s[8]的，\w5Carrera桑。\w9\w9\u\s[11]嗯～，\w5说话方式还有点微妙，\w5好好教教她吧？\w9\w9\h\s[5]\n\nListen・\w5and・\w5follow me。\w9\w9\n「布丁」\w5「烤红薯」\w5「芝士鱼肠」\w9\w9\u\s[11]\n\n全是食物啊，\w5那些。"
	}
	/*when EMS_GC_CHANGED { //WAITING
	}*/
	when EMS_GC_CALLING {
		"\u\s[10]\p2\s[200]\h\s[5]哦，\w5Carrera桑～。\w9\n日本的名食物是烤红薯！\w9\n记住了哦～。\w9\w9\u\s[11]…\w5…\w5你在教什么谎话啊。\w9\n而且用词还很奇怪。\w9\w9\p2\s[208]…\w5…\w5嘛，\w5倒确实是名产没错啦。\w9\w9\h\s[3]\n\n唔～，\w5但还是烤红薯好～。"
	}
	/*when EMS_GC_CALLED {
	}*/
	when EMS_GC_CLOSED {
		"\u\s[10]\p2\s[200]\h\s[5]Carrera桑，\w5辛苦了。\w9\w9\u\s[11]…\w5…\w5旁边那个谜之精灵有点在意。\w9\w9\h\s[27]\n\n是茶壶吧。\w9\w9\p2\s[205]一定，\w5到了喝茶时间会自己倒茶什么的。\w9\w9\h\s[5]\n\n哇哦，\w5那可真方便～。\w9\w9\p2\s[218]\n\n…\w5…\w5下毒的话。\w9\w9\h\s[4]\n\n呜哇～～～～。"
	}
}}END_CHANGE

//-------------------------------------------------------------------------新2005.6.12/改----.--.--
OnGhostChangeCall_ありす
{{START_CHANGE
