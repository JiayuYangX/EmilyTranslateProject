//**** 切换 **********************************************************

//**** 共通处理 **********************************************************

//-----Ghost名称转换处理------------------------------------------------------------
GhostNameConvert
{
	_gname = _argv[0]
	
	//芹子
	if ASEARCH(_gname,'せりこXP','せりこDP') >= 0 {
		'せりこ'
		return
	}
	//樱
	if ASEARCH(_gname,'．さくら','偽補完さくら') >= 0 {
		'さくら'
		return
	}
	//地板樱
	if ASEARCH(_gname,'机さくら','椅子さくら','炬燵さくら') >= 0 {
		'床さくら'
		return
	}
	//艾米莉
	if _gname == 'えみりぃ' {
		'エミリ'
		return
	}
	//明显是德贝洛帕对话的人
	if ASEARCH(_gname,'みさき','さとー','おとーさん','ゆねね～','あれ','とじぇたん','アルフェイル','いおにゃん','夜霧たん') >= 0 {
		'でべろぱ'
		return
	}
	
	''
}

//-----给魔术师先生的调用------------------------------------------------------------
GhostCall_Magic
{
	"\u\s[10]\h\s[5]%(charname(0))，\w5对抗%(_argv[0])，\w5火焰魔法走你～！\w9\n\s[24]唔唔唔唔唔\w5…\w5…\w9\w9\u\s[12]%(charname(0))，\w5不是一直说别乱来嘛\w9\_s[0,1]\s[-1]\n\n（砰！）\_s\_w[1500]\h\s[40]\u\s[14]\n\n…\w5…\w5别乱来　\w9烂魔法　\w9会受伤的。\w9\w9\h\n\n诶呜～。\w5怎么老是这结局\w5…\w5…。"
}

//-----标准反应------------------------------------------------------------
OnGhostChangeCallNormal
{{START_CHANGE
	when EMS_GC_CLOSED {
		_name = E.AddKeisyou(reference[0],'さん')
		
		if RE_SEARCH(change_plain_talk,'えんい[ー～]') {
			"\u\s[10]\h\s[5]%(_name)，\w5炎衣～。\w9\w9\u那问候语，\w5感觉有点怪怪的。\w9\w9\h\s[27]\n\n诶？\w5我听说是人格们通用的问候啊。\w9\w9\u\n\n\s[11]…\w5…\w5嘛，\w5倒是没错啦。\e"
		}
		else {
			"\u\s[10]\h\s[5]%(_name)，\w5辛苦了～。\e"
		}
	}
}}END_CHANGE


//**** 个别处理 **********************************************************

//-------------------------------------------------------------------------新2005.7.1/改----.--.--
OnGhostChangeCall_でべろぱ
{{START_CHANGE
	//でべご先生们
	_name = E.AddKeisyou(reference[0],'さん')
	if reference[0] == 'おとーさん' {
		_name = '道化氏さん'
	}
	elseif reference[0] == 'ゆねね～' {
		_name = '夕音さん'
	}
	elseif reference[0] == 'とじぇたん' {
		_name = 'TJさん'
	}
	elseif reference[0] == 'いおにゃん' {
		_name = '－イオンさん'
	}
	elseif reference[0] == '夜霧たん' {
		_name = '夜霧さん'
	}
	
	when EMS_GC_CLOSED {
		"\u\s[10]\h\s[5]%(_name)，\w5开发辛苦了～。\w9\w9\u当人格时想报Bug的话，\w5\_a[GHOST_所長たん]所长\_a的代理%(charname(0))也受理，\w5请多关照。\w9\w9\h\s[4]\n\n诶，\w5什么情况\w5…\w5…\e"
	}
}}END_CHANGE

//-------------------------------------------------------------------------
OnGhostChangeCall_Emily
{{START_CHANGE
	//重载
	when EMS_GC_CHANGING {
		"\u\s[10]\h\s[5]重置～。\w9\w9\u出什么问题了吗？\e"
	}
	when EMS_GC_CHANGED {
		"\u\s[10]\h\s[5]重置结束～。\w9\w9\u怎么回事呢。\e"
	}
}}END_CHANGE

