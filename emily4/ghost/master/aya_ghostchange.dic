	}
}}END_CHANGE

//-------------------------------------------------------------------------新2005.7.11/改----.--.--
OnGhostChangeCall_小夜
{{START_CHANGE
	//背后灵（小夜＆幽幽）
	//虽然是幽灵Emily应该害怕……但因该算是熟人。
	when EMS_GC_CHANGING {
		"\u\s[10]\h\s[5]接下来是幽灵桑～。\w9\w9\n\s[27]说起来，\w5幽灵桑平时都住在哪里呢。\w9\w9\u\s[11]＊在破坏子里面！＊\w9\w9\h\s[4]\n\n不，\w5不会吧。"
	}
	/*when EMS_GC_CHANGED {
	}*/
	when EMS_GC_CALLING {
		"\u\s[10]\h\s[0]\p2\s[218]嗯～，\w5好无聊，\w5来讲鬼故事吧。\w9\w9\h\s[4]不，\w5不要啊啊～～。\w9\w9\u\s[11]%(charname(0))是胆小鬼呢。\w9\w9\p2\s[205]\n\n总之幽灵桑Come on！\w9\w9\h\s[8]\n\n…\w5…\w5哈哈哈，\w5再怎么想也不会这样就出来吧。"
	}
	when EMS_GC_CALLCOMPLETE {
		"\u\s[10]\p2\s[200]\h\s[2]呜哇，\w5真的来了！\w9\w9\p2\s[202]真，\w5真的！！\w9\w9\u\s[11]…\w5…\w5真是位配合的幽灵桑呢。\w9\w9\h\s[8]\n\n啊咧，\w5原来是小夜酱啊，\w5吓我一跳。\w9\w9\p2\s[204]\n\n…\w5…\w5认识幽灵是怎么回事呢。"
	}
	when EMS_GC_CLOSED {
		"\u\s[10]\h\s[3]啊啊，\w5走了。\w9\w9\u\s[11]为什么不能再被附身了还觉得遗憾啊。\w9\w9\h\s[21]\n\n因为，\w5想再多摸摸她嘛。\w9\w9\u\n\n…\w5…\w5反正都会穿透摸不到的吧？"
	}
	when EMS_GC_CALLED {
		"\u\s[10]\h\s[5]小夜酱，\w5过来过来～。\w9\w9\u\s[11]…\w5…\w5%(charname(0))不是胆小鬼吗？\w9\n那么想被幽灵附身吗？\w9\w9\h\s[8]\n\n啊，\w5啊哈哈\w5…\w5…\w9\n嘛，\w5也算是熟人了。\w9\w9\u\s[10]\n\n嘛，\w5倒也是。"
	}
}}END_CHANGE

//-------------------------------------------------------------------------新2005.7.15/改2005.8.29
OnGhostChangeCall_由加
{{START_CHANGE
	//#　由加+达奥牛　#
	//实际上由加更小。「酱」
	when EMS_GC_CHANGING {
		"\u\s[10]\h\s[0]\p[2]\s[205]由加姐。\w9\n有没有能三秒做出布丁的药？\w9\w9\h\s[8]那种东西怎么可能有。\w9\w9\s[27]\n啊，\w5不过，\w5有能让红薯收获量提升数倍的药吗？\w9\w9\u\s[11]你们只有食欲吗？"
	}
	when EMS_GC_CHANGED {
		if '捕獲してどうする' _in_ change_plain_talk {
			"\u\s[10]\h\s[5]啊，\w5这种地方有红薯。\w9\n那我就不客气啦～。\w9\w9\s[-1]\n（啪！）\w9\n（呀～～～，\w5这是什么～～～～！）\w9\w9\u\s[11]…\w5…\w5真没想到会中这么简单的陷阱。\w9\w9\h\n\n（别一脸无语快放我出去～～～！！）\w9\w9\u\n\n…\w5…\w5你还是反省一会儿比较好，\w5大概。"
		}
	}
	when EMS_GC_CALLING {
		"\u\s[10]\p2\s[200]\h\s[5]♪大蝴蝶结～　\w5大蝴蝶结～\w9\n　系了系了　\w5就收起来～♪\w9\w9\p2\s[204]又是奇怪的信号波。\w9\w9\u感觉迟早会因为噪音公害被告呢。\w9\w9\h\s[9]\n\n什，\w5什么嘛～～～。\w9\w9\p2\s[205]\n\n话说回来，\w5由加姐也系着大蝴蝶结呢。\w9\w9\h\s[5]\n\n系着比我还大的呢～。\w9\w9\n\s[27]下次要不要交换试试。\w9\w9\u\s[11]\n\n感觉会被因为沾上红薯味而拒绝。\w9\w9\h\s[4]\n\n为什么啦～。"
	}
	when EMS_GC_CALLED {
		if 'おいも買' _in_ change_plain_talk {
			"\u\s[10]\h\s[5]好全都给我～～～。\w9\w9\u\s[11]不，\w5你给我全都拿来。\e"
		}
	}
	when EMS_GC_CLOSED {
		"\u\s[10]\p2\s[200]\h\s[5]由加酱，\w5辛苦了～。\w9\w9\p2\s[205]下次，\w5要不要问问能不能做出把%(charname(1))恢复原样的药。\w9\w9\u\s[17]…\w5…\w5现在这样就正常。\w5又不是从什么东西变来的。\w9\w9\p2\s[203]\n\n诶～，\w5明明是个好机会。\w9\w9\h\s[8]\n\n啊，\w5啊哈哈\w5…\w5…"
	}
}}END_CHANGE

//-------------------------------------------------------------------------新2005.7.12/改----.--.--
OnGhostChangeCall_いおにゃん
{{START_CHANGE
	//萌え萌えいおにゃん
	/*when EMS_GC_CHANGING {
	}
