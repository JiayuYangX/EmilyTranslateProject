}}END_CHANGE

//-------------------------------------------------------------------------新2006.5.28/改----.--.--
OnGhostChangeCall_ユリ
{{START_CHANGE
	//water lily
	when EMS_GC_CHANGING {
		"\u\s[10]\p2\s[200]\h\s[5]哼哼哼～～～。\w9\w9\p2\s[204]老姐，\w5又在用红薯做什么了。\w9\w9\u喂，\w5别浑身红薯味了。\w9\n说要和百合桑和水波桑交接了。\w9\w9\h\s[2]\n\n啊，\w5完全忘了！\w9\w9\u\s[11]\n\n…\w5…\w5到底在干嘛。"
	}
	when EMS_GC_CHANGED {
		if 'ボク' _in_ change_plain_talk {
			"\h\s[0]\u\s[10]…\w5…\w5把bug\f[bold,true]扑灭\f[bold,default]。\w9\w9\h\s[8]喂，\w5%(charname(1))？？\w9\w9\u\n\n\f[bold,true]朴\f[bold,default]素的田园挤牛奶体验。\w9\w9\h\s[27]\n\n呃～，\w5是带有「仆」字的词吗？\w9\w9\u\n\n练书法时\f[bold,true]泼\f[bold,default]墨求购。\w9\w9\h\n\n全都带着仆字呢～。\w9\w9\u\n\n…\w5…\w5请将以上的片假名全部写成汉字（10分）\w9\w9\h\s[2]\n\n汉，\w5汉字练习！"
		}
	}
	//when EMS_GC_CALLING {
	//}
	//when EMS_GC_CALLED {
	//}
	//when EMS_GC_CLOSED {
	//}
}}END_CHANGE

//-------------------------------------------------------------------------新2006.5.28/改----.--.--
OnGhostChangeCall_シャープ
{{START_CHANGE
	//夏普和弗拉特
	when EMS_GC_CHANGING {
		"\u\s[10]\h\s[5]喂喂，\w5听说弗拉特桑会炼金术哦。\w9\w9\u不是以前那种做贵金属的故事，\w5是更广泛意义的呢。\w9\n…\w5…\w5那，\w5怎么了吗？\w9\w9\h\s[27]\n\n我在想有没有炼薯术之类的。\w9\w9\u\s[11]\n\n…\w5…\w5那一定是禁断的秘法。\w9\h\s[2]\n\n诶诶！？"
	}
	when EMS_GC_CHANGED {
		if 'てでえ' _in_ change_plain_talk {
			"\u\s[10]\h\s[7]艾米莉！\w5泰迪！\w9\n不好好发音的话！\w9\w9\u…\w5…\w5反正\w5「艾米莉」\w5也好\w5「泰迪」\w5也好都无所谓啦。\w9\w9\h\s[4]\n\n等等等等，\w5我姑且不论泰迪的话有点…。"
		}
	}
	//when EMS_GC_CALLING {
	//}
	//when EMS_GC_CALLED {
	//}
	//when EMS_GC_CLOSED {
	//}
}}END_CHANGE

//-------------------------------------------------------------------------新2006.7.2/改----.--.--
OnGhostChangeCall_レネット
{{START_CHANGE
	//真绿丸
	when EMS_GC_CHANGING {
		"\p2\s[-1]\u\s[11]\h\s[-1]（呜哇～！\w5吱喵～～～！！！）\w9\w9\u…\w5…\w5…\w5真是的。\w9\w9\p2\s[204]吵死了。\w9\n到底是什么事？\w9\w9\u\n\n蕾奈特桑，\w5说着要试试被强行塞蒸红薯进嘴里的新情境之类搞不懂的话过来了。\w9\w9\p2\s[214]\n\n搞什么啊\w5…\w5…\w9\w9\h\n\n（呜喵啊啊啊啊～～～！！！）"
	}
	when EMS_GC_CHANGED {
		if 'いじめてやる' _in_ change_plain_talk {
			"\h\s[40]\u\s[10]\p2\s[204]老姐，\w5那悲惨的样子是什么。\w9\w9\h呜～嗯，\w5被蕾奈特桑高速毛茸茸攻击了～。\w9\w9\u\s[11]…\w5…\w5到底从哪里怎么毛茸茸才会变成这种状况啊。\w9\w9\h\n\n我，\w5变成不干净的东西了呢\w5…\w5…\w9\w9\u\n\n禁止问题发言。"
		}
	}
	when EMS_GC_CALLING {
		"\u\s[10]\p2\s[200]\h\s[1]蕾奈特酱的色色时～间。\w9\w9\p2\s[204]老姐做出那种表情也没用啊。\w9\w9\u小孩子说色色的话，\w5反而会起反效果呢。\w9\n真看不出和蕾奈特桑同岁。\w9\w9\h\s[7]\n\n才，\w5谁是小孩子啊啊～～。"
	}
	when EMS_GC_CALLED {
		if 'しょうぶ' _in_ change_plain_talk {
			"\u\s[10]\h\s[2]诶诶！！\w9\n对决什么的！\w5不可能的～～～！\w9\w9\u到底是什么对决啊。"
		}
	}
	when EMS_GC_CLOSED {
		"\u\s[10]\p2\s[200]\h\s[1]色色时间结～束。\w9\w9\p2\s[205]以上，\w5是蕾奈特桑的稍稍大人的时间。\w9\w9\u请继续享受小孩子的时间。\w9\w9\h\s[4]\n\n诶诶～～～。"
	}
}}END_CHANGE

//-------------------------------------------------------------------------新2006.7.30/改----.--.--
OnGhostChangeCall_ジャスミン
{{START_CHANGE
	//NiGHtMArE
	when EMS_GC_CHANGING {
		"\u\s[10]\p2\s[200]\h\s[27]茉莉桑，\w5听说擅长火焰系魔法呢。\w9\w9\u嘛，\w5至少比%(charname(0))好多了吧。\w9\w9\p2\s[205]就是啊。\w5暴走然后轰隆一声，\w5应该不会每次都这样吧。\w9\w9\h\s[4]\n\n…\w5…\w5本来还想说和我一样的。"
	}
	when EMS_GC_CHANGED {
		if RE_SEARCH(change_plain_talk,'ん，(.+?)でも持っていこうかな') {
			_omiyage = RE_GETSTR[1]
			
