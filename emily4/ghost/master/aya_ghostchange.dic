//-------------------------------------------------------------------------新2007.6./改----.--.--
OnGhostChangeCall_クロツ
{{START_CHANGE
	//不可侵犯之黑
	when EMS_GC_CHANGING {
		"\u\s[10]\h\s[27]…\w5…\w5异次元也有红薯吗？\w9\w9\u嘛，\w5有的次元有，\w5大概就是这样的吧。\w9\n芽美桑那里大概会有吧。"
	}
	when EMS_GC_CHANGED {
		if '米を借りる' _in_ change_plain_talk {
			"\u\s[10]\p2\s[204]\h\s[5]哇～。\w9\n用红薯换的话米也好什么也好都给你～！\w9\w9\u\s[11]…\w5…\w5怎么说呢。\w9\w9\p2老姐，\w5米比较重要。\w9\n对老姐以外的人来说。"
		}
		elseif 'あなたのお望み' _in_ change_plain_talk {
			"\u\s[10]\h\s[5]是要给我想要的红薯对吧！\w9\n虽然搞不清楚但契约契约～。\w9\w9\u\s[11]…\w5…\w5你说「契约」\w5知道什么意思吗？\w9\w9\h\s[27]\n\n嗯～，\w5就是成为朋友的意思？\w9\w9\u\n\n…\w5…\w5这不行。"
		}
		elseif '同い年' _in_ change_plain_talk {
			"\u\s[10]\h\s[0]\p2\s[214]结果黑津桑和咱们同岁，\w5有点不敢相信呢。\w9\w9\u就算被怀疑是不是有人谎报了年龄也没办法。\w9\w9\h\s[7]什，\w5什么～～！！"
		}
		elseif '死人の壷' _in_ change_plain_talk {
			"\u\s[10]\h\s[0]\p2\s[218]对老姐来说，\w5比起那种东西，\w9\n「控制失败就会自动消灭红薯库存的谜之壶」\w9\n才更有效吧。\w9\w9\u还能减肥一举两得呢。\w9\w9\h\s[4]那，\w5那种东西不要啊啊啊啊\w5…\w5…"
		}
		elseif '炎の術' _in_ change_plain_talk {
			"\u\s[10]\p2\s[200]\h\s[5]那么，\w5要对抗海伦娜桑～！\w9\w9\s[24]\w9\w9\u\s[12]\p2\s[202]\_s[1,2]哇～，\w5快住手…\_s\w9\w9\u\s[-1]\p2\s[-1]\h\s[-1]\n\n[half]\f[height,24]\f[color,255,0,0]（砰！！！）\f[height,default]\f[color,default]\w9\w9\w9\w9\u\c\b[-1]\s[14]\p2\c\b[-1]\s[240]\h\c\s[40]…\w5…\w5…\w5…\w5…。\w9\w9\u我就说嘛\w5…\w5…"
		}
		elseif '毛玉吐く' _in_ change_plain_talk {
			"\u\s[10]\h\s[27]呼～嗯，\w5对吐毛球有用啊。\w9\n一定是肠道变好了吧。\w9\w9\u\s[11]…\w5…\w5艾米莉，\w5你真的是猫吗？\w9\w9\h\s[3]\n\n可是，\w5我一次都没吐过毛球\w5…\w5…"
		}
		elseif '火ねずみ' _in_ change_plain_talk {
			"\u\s[10]\h\s[2]不，\w5不能吃～！！\w9\w9\u\s[11]…\w5…\w5又不是普通的老鼠。\w9\n吃了也不好吃吧？\w9\w9\n顺便说比米娅桑还大哦。\w9\w9\h\s[8]\n\n这，\w5这么说也是呢。"
		}
		elseif 'そそっかしい弟子' _in_ change_plain_talk {
			"\t\1\s[10]\0\s[4]说，\w5说我冒冒失失…\w5…\w5好过分啊。\w9\w9\1但实际上不是吗。\w9\w9\0\s[3]\n\n只是稍微烤焦一点，\w5或弄焦一点，\w5或引发大火而已…\w5…\w5\w9\w9\1\s[11]\n\n那就叫冒冒失失啊。\e"
		}
		elseif '芋で火を' _in_ change_plain_talk {
			"\t\1\s[10]\0\s[8]确实，\w5红薯是俺的魔力来源。\w9\w9\1代替火，\w5经常放屁呢。\w9\w9\0\s[9]\n\n才没放！\w5好好！！\e"
		}
	}
	//when EMS_GC_CALLING {
	//}
	//when EMS_GC_CALLED {
	//}
	//when EMS_GC_CLOSED {
	//}
}}END_CHANGE

