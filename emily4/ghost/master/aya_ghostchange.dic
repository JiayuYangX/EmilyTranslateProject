//-------------------------------------------------------------------------新2005.4.28/改----.--.--
OnGhostChangeCall_栄子
{{START_CHANGE
	when EMS_GC_CALLING {
		"\u\s[10]\h\s[7]好～的！\w9栄子一等兵，\w5立正～！！\w9\w9\u\s[11]…\w5…\w5会被打的哦，\w5真的。\w9\w9\h\s[3]\n\n诶～，\w5难道不想哪怕一次说说看吗？\w5这种的。\w9\u\n\n\f[bold,true]不想。\f[bold,default]\w9\w9\h\s[4]\n\n诶呜。\e"
	}
	when EMS_GC_CALLCOMPLETE {
		if '最終階級中尉' _in_ change_plain_talk {
			"\u\s[10]\h\s[27]最～终～军～阶～中～尉\w5…\w5…\w9\w9\n\s[4]什么鬼。\w9\w9\u…\w5…\w5嘛，\w5至少比一等兵大是没错，\w5%(charname(0))的刑罚是红薯禁食一周吧。\w9\w9\h\s[2]\n\n喵啊啊啊啊！？"
		}
	}
	when EMS_GC_CLOSED {
		"\u\s[10]\h\s[7]栄子一等兵！\w5临阵脱逃可是枪毙哦～！\w9\w9\u\s[11]…\w5…\w5敌人是谁啊。\w9\w9\h\s[27]\n\n嗯～，\w5红薯的害虫？\w9\w9\u\n\n…\w5…\w5还有啊，\w5那位佣兵小姐。\w9\n用奇怪的军衔叫的话小心哪天被用铲子\w5…\w5…\w9\h\s[2]\n\n喵啊啊啊啊！？\e"
	}
	when EMS_GC_CALLED {
		if 'エミリはんが四人前食う' _in_ change_plain_talk {
			"\u\s[10]\h\s[0]\p2\s[205]啊，\w5零食。\w9\w9\h\s[5]没问题！\w5别说四人份，\w5七人份全部都能吃掉哦～！\w9\w9\u\s[11]…\w5…\w5明明人家特意说一起吃却禁止。\w9\w9\h\s[4]\n\n对，\w5对不起。\w9\w9\p2\s[204]\n\n姐姐\w5…\w5…"
		}
	}
	when EMS_GC_CHANGING {
		"\u\s[10]\h\s[5]铲子姐姐呀吼～。\w9\w9\u\s[11]…\w5…\w5我觉得那个叫法不太妙。\w9\w9\h\s[8]\n\n听说那一把铲子，\w5就能毁灭世界什么的。\w9\w9\u\n\n你从哪儿听来的那种话。\e"
	}
	when EMS_GC_CHANGED {
		if '器物損壊' _in_ change_plain_talk {
			"\u\s[10]\h\s[4]唔。\w9\n无话可说。\w9\w9\u因为平时确实老弄坏东西嘛。\w9\w9\h\n\n总之，\w5我会尽量注意的。"
		}
		elseif '火遊びお嬢ちゃん' _in_ change_plain_talk {
			"\u\s[10]\h\s[5]%(charname(1))。\w9\n栄子桑发邮件来了哦～。\w9\w9\u写了什么？\w9\w9\h\s[27]\n\n嗯～，\w5下次大家一起开烟花大会怎么样，\w5这样写的。\w9\u\s[12]\n\n危险啊───────！！！"
		}
		elseif '太るで' _in_ change_plain_talk {
			"\u\s[10]\p2\s[218]\h\s[4]唔。\w9\n被说中了在意的事。\w9\w9\p2看吧。\w9\n平时总说不听结果连别人都这么说你了。\w9\w9\u…\w5…\w5嘛，\w5适当节制才行啊。\w9\w9\h\s[3]\n\n唔～。\e"
		}
		elseif '弟がいる' _in_ change_plain_talk {
			"\u\s[10]\p2\s[208]\h\s[8]那个啊。\w9\w9\n\_s[0,2]费事的\_s"
			--
			E.Parallel(0,'有弟弟很麻烦嘛～。',2,'有姐姐才麻烦呢。')
			--
			"\w9\w9\_s[0,2]\n\n…\w5…\w5…\w5…\w5…。\_s\w9\w9\h\s[9]\n\n什么意思！\w9\w9\p2\s[207]\n\n明明是你才。\e"
		}
		elseif 'ＳＳＰって何の略やっけ' _in_ change_plain_talk {
			if 'の略です' _in_ change_plain_talk {
				"\p2\s[205]\u\s[10]\h\s[9]别乱加奇怪的缩写！\w9\w9\n\s[6]准确来说是，\w5"
				--
				E.Parallel(0,'Sakura ',1,'Special ',2,'条纹 ')
				--
				E.Parallel(0,'Script ',1,'Silver ',2,'条纹 ')
				--
				E.Parallel(0,'Player！',1,'胖次。',2,'胖次。')
				--
				"\w9\w9\_s[0,1,2]\n\n…\w5…\w5…\w5…\w5…。\_s\w9\w9\h\n\n\s[24]%(charname(2))！%(charname(1))！！\w9\u\s[12]\p2\s[202]\_s[1,2]\n\n！！！！！\_s\w9\w9\u\s[-1]\p2\s[-1]\e"
			}
			else {
				"\u\s[10]\h\s[5]也不是什么缩写啦，\w5现在就叫SSP就行了\_a[GHOST_所長たん]所长\_a说的。\w9\w9\u至少，\w5注意别说成胖次什么的哦。\w9\w9\h\s[4]\n\n%(charname(1))别说多余的话。\e"
			}
		}
	}
}}END_CHANGE

//-------------------------------------------------------------------------新2005.5.7/改2005.7.24
OnGhostChangeCall_床さくら
{{START_CHANGE
	when EMS_GC_CHANGED {
		"\u\s[10]\h\s[6]（…\w5…\w5点头）\w9\w9\u%(charname(0))～。\w9\n在叫你哦～。\w9\w9\h\n\n（…\w5…\w5点头）\w9\w9\u\n\n不起来可不行哦～。\w9\w9\h\n\n（…\w5…\w5点头）\w9\w9\u\s[11]\n\n…\w5…\w5…\w5…\w5…。\_w[1500]\c\s[17]\f[height,56]没收红薯！\f[height,default]\h\s[2]\n\n喵啊啊啊啊啊！？\_w[1000]\u\s[10]\_q\c\f[bold,true]没收红薯！\f[bold,default]\n\n\_q被地板樱酱传染跟着睡着了。\w9\w9\h\s[4]\n\n唔～。\w9\n不会温柔点叫醒我哦。\w9\w9\u\s[11]\n\n真是的。\e"
	}
	when EMS_GC_CHANGING {
		"\h\s[0]\u\s[10]从淘气包%(charname(0))，\w5换成总是安静睡觉的人了呢。\w9\w9\h\s[7]什么意思啊！！"
		
		"\u\s[10]\h\s[3]…\w5…\w5我也，\w5好想像会被说成地板艾米莉那样睡得香啊。\w9\w9\u\s[11]…\w5…\w5正常睡。\w5正常地。\w9\w9\h\s[4]\n\n诶～。\w5明明看起来超舒服的。"
	}
	when EMS_GC_CALLING {
		"\u\s[10]\h\s[5]晚安～。\w9\w9\u\s[11]…\w5…\w5%(charname(0))，\w5不能睡哦。\w9\w9\h\s[3]\n\n本来是想跟地板樱酱打招呼的。\w9\w9\u\n\n…\w5…\w5又是，\w5好厉害的招呼啊。\e"
	}
	when EMS_GC_CALLED {
		if '誰' _in_ change_plain_talk {
			"\u\s[10]\h\s[8]呃～，\w5被问是谁\w5…\w5…\w9\w9\u\s[11]红薯吃太多长出了猫耳，\w5谜之怪兽，\w5%(charname(0))是也。\w9\w9\h\s[7]\n\n本来就是猫！\w5真是的！！"
		}
	}
	when EMS_GC_CLOSED {
		"\u\s[10]\h\s[3]睡得真香呢\w5…\w5…\w9\n好羡慕啊。\w9\w9\u\s[11]光睡可是会胖的哦？\w9\w9\h\s[4]\n\n啊呜。\w5那就加油。\e"
	}
}}END_CHANGE

//-------------------------------------------------------------------------新2005.5.9/改----.--.--
OnGhostChangeCall_リル
{{START_CHANGE
	when EMS_GC_CHANGED {
		if '口からバズーカ' _in_ change_plain_talk {
			"\u\s[10]\h\s[3]唔～，\w5抱歉啦，\w5我只会挠人而已\w5…\w5…\w9\w9\u\s[11]没关系，\w5超级破坏兵器\w5「料理」在呢\w9\h\s[7]\n\nTeddy～～～！！！\e"
		}
	}
	when EMS_GC_CHANGING {
		"\u\s[10]\h\s[5]接下来换リル桑哦。\w9\w9\u那位看我的时候，\w5总是用像艾米莉看食物一样的眼神盯着我。\w9\w9\h\s[8]\n\n小心别被烤来吃了哦。\w9\w9\u\s[11]\n\n别说可怕的话啦。\e"
		
		"\u\s[10]\h\s[5]接下来换リル桑哦。\w9\w9\u那位看我的时候，\w5总是用像艾米莉看食物一样的眼神盯着我。\w9\w9\h\s[1]\n\n是少女恋爱的眼神呢。\w9\w9\u\n\n\s[11]…\w5…\w5…\w5…\w5…\e"
	}
}}END_CHANGE

//-------------------------------------------------------------------------新2005.5.9/改2005.8.10
GCC_RinZen_Name
{
	'凛';'然'
}

OnGhostChangeCall_凛然
{{START_CHANGE
	when EMS_GC_CHANGING {
		"\u\s[10]\h\s[4]唔～。\w9\n这道题解不出来～。\w9\w9\u得再像凛桑那样，\w5多懂点东西才行呢。\w9\w9\h\s[9]\n\n但是体育我可是有自信的！\w9\w9\u\s[11]\n\n那完全没什么可自豪的。\w9\w9\h\s[4]\n\n%(charname(1))真坏。"
	}
	when EMS_GC_CHANGED {
		if '縫いぐるみのような御仁' _in_ change_plain_talk {
			"\u\s[10]\h\s[27]把%(charname(1))做成玩偶的话，\w5能卖钱吗？\w9\w9\u\s[11]%(charname(0))的话首先会在制作阶段就放弃，\w5不知道呢。\w9\w9\h\s[9]\n\n什么意思啊！！\e"
		}
		elseif '猫耳の姉弟' _in_ change_plain_talk {
			"\h\s[1]\u\s[10]…\w5…\w5哪里色情了呢。\w9\w9\h喉咙下面摸摸play什么的\w5…\w5…\w9\w9\u\s[11]\n\n那个想象各种意义上都错了吧。\e"
		}
		elseif 'エミリオ君って何歳' _in_ change_plain_talk {
			"\u\s[10]\h\s[0]\p2\s[205]10岁哦。\w5凛姐姐。\w9\w9\h\s[5]最活泼的年纪呢。\w9\w9\u也可以说是最叛逆的年纪就是了。\w9\w9\p2\n\n…\w5…\w5\s[217]那，\w5是什么意思啊。\e"
		}
	}
	when EMS_GC_CALLING {
		"\u\s[10]\p2\s[200]\h\s[5]%(GCC_RinZen_Name)酱呀吼～。\w9\w9\n\s[1]那个啊，\w5要想胸部变大，\w5多吃红薯就好了哦。\w9\w9\p2\s[204]…\w5…\w5她是从哪儿听来的，\w5这种奇怪的话。\w9\w9\u\s[11]…\w5…\w5嘛，\w5失败案例现在就在这里这只猫呢。\w9\w9\h\s[9]\n\n真失礼！！"
	}
	when EMS_GC_CALLED {
		if '芋ほりのゲーム' _in_ change_plain_talk && 'バナナ' _in_ change_plain_talk {
			"\u\s[10]\p2\s[200]\h\s[3]地里有香蕉？\w9\n果然还是得红薯才行啊～。\w9\w9\p2\s[214]嘛，\w5确实想象地里埋满香蕉的话是有点奇怪\w5…\w5…\w9\w9\u\s[11]其实啊，\w5红薯全被%(charname(0))吃掉了，\w5鼹鼠只好收集香蕉，\w5是个充满悲哀的游戏哦。\w9\w9\h\s[9]\n\n才不会那样呢！"
		}
	}
	when EMS_GC_CLOSED {
		if RE_SEARCH(reference[1],'\\s\[10\d\d\]') { //然人化 必须用ref1
			"\u\s[10]\h\s[5]凛酱，\w5然酱，\w5辛苦了～。\w9\n…\w5…\w5\s[1]然酱，\w5那件衣服对男性吸引力很强呢。\w9\w9\u\s[11]…\w5…\w5我觉得那件衣服的结构本身才更成问题。\w9\w9\h\s[4]\n\n%(charname(1))真冷静呢～。"
		}
		else {
			"\u\s[10]\h\s[5]凛酱辛苦了～。\w9\w9\u为什么是素描本呢。\w9\w9\h\s[8]\n\n谁，\w5谁知道呢。"
		}
	}
}}END_CHANGE

