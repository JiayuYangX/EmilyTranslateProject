OnGhostChangeCall_砂霧
{{START_CHANGE
	//砂雾＆Tama
	when EMS_GC_CHANGING {
		"\u\s[10]\p2\s[200]\h\s[27]砂雾桑，\w5好像很懂灵异之类的事情呢。\w9\w9\u其实，\w5我最近也搞到了一条这样的消息。\w9\w9\p2\s[205]什么什么%(charname(1))，\w5想知道想知道。\w9\w9\u\n\n虽然美国的51区已经非常出名了。\w9\n\s[11]但其实，\w5事到如今因为其实是%(GCC_Sagiri_Area51_False)而说不出口好像很困扰的样子。\w9\w9\h\s[2]\p2\s[202]\_s[0,2]\n\n你，\w5你，\w5你，\w5你说什么─────！！！"
	}
	when EMS_GC_CHANGED {
		if 'おいしそう' _in_ change_plain_talk {
			"\u\s[10]\h\s[3]就算你夸好吃，\w5我做的烤红薯是不会给你的哦？\w9\w9\u\s[11]…\w5…\w5我觉得不是那个意思。"
		}
		elseif '波動パワーで美味しい焼き芋' _in_ change_plain_talk {
			"\u\s[10]\p2\s[200]\h\s[27]波动力量\w5…\w5…\w5原来如此。\w9\n\s[5]好买下了～！\w9\w9\p2\s[204]老姐又在乱花钱了。\w9\w9\u\s[11]100万日元什么的，\w5我们家可没有哦？\w9\w9\h\s[5]\n\n那，\w5用一年的烤红薯来物物交换怎么样？\w9\w9\p2\s[214]\n\n这么乱来。\w9\w9\u\n\n嘛，\w5对%(charname(0))来说大概值100万日元吧\w5…\w5…"
		}
	}
	when EMS_GC_CALLING {
		"\u\s[10]\h\s[5]砂雾桑%(GetGreeting)。\w9\w9\u要是目击到总是精神又开朗的砂雾桑的话，\w5那马上就会变成灵异故事了呢。\w9\w9\h\s[4]\n\n%(charname(1))，\w5别说那种话啦～。"
	}
	when EMS_GC_CLOSED {
		"\u\s[10]\h\s[8]呃～，\w5砂雾桑辛苦了\w5…\w5…\w5这么说可以吗？\w9\w9\u感觉整年都在辛苦的样子呢。"
	}
}}END_CHANGE

//-------------------------------------------------------------------------新2005.7.5/改2005.7.12
OnGhostChangeCall_－_澪_－_The_Illegal_Edge
{{START_CHANGE
	//－ 澪 － The Illegal Edge
	//注意澪会和「冒险者」撞名
	//几乎同龄(16<18)，但是带点尊敬所以用「桑」
