			"\u\s[10]\h\s[27]听说ヒュール桑，\w5有一点点像蝙蝠呢。\w9\n感觉很厉害呢。\w9\w9\u\s[11]…\w5…\w5哪里只是一点点，\w5明显是猫的%(charname(0))来说完全没有说服力啊。\w9\w9\h\s[4]\n\n诶～。\e"
		}
	}
	when EMS_GC_CHANGED {
		if '健胃薬' _in_ change_plain_talk {
			"\u\s[10]\h\s[5]哇～伊，\w5真的买了健胃药回来。\w9\n这样就能吃好多红薯精神百倍啦！\w9\w9\u\s[11]然后得意忘形搞坏胃躺倒的结局已经看见了。\w9\w9\h\s[4]\n\n唔。\e"
			EMGoodsAdd('健胃薬',1)
		}
		elseif 'トーラ' _in_ change_plain_talk {
			"\u\s[10]\h\s[27]Tora是什么呢。\w9\w9\u听说是，\w5阪神老虎队，\w5就是打棒球的人聚集的地方的狂热粉丝的意思。\w9\w9\h\s[5]\n\n原来如此～。\w9\w9\n…\w5…\w5\s[3]真的？\w9\w9\u\n\n谁知道呢。\e"
		}
		elseif 'デフォルト' _in_ change_plain_talk {
			"\u\s[10]\h\s[27]说起来，\w5Default是什么意思来着。\w9\w9\u\s[11]债务不履行。\w9\w9\h\s[4]\n\n呃，\w5那要怎么传达猫的出色之处啊。\w9\w9\u\s[11]\n\n啊～，\w5那个，\w5开玩笑的。\e"
			
			"\u\s[10]\h\s[27]杖桑好像想变成Default，\w5那是什么意思呢。\w9\w9\u也就是说，\w5是想当SSP的导航员吧。\w9\w9\h\s[5]\n\n原来如此！\w5那，\w5我去问问能不能当\_a[GHOST_所長たん]所长\_a！\w9\w9\u\s[11]\n\n…\w5…\w5等一下。\w9\w9\h\s[4]\n\n诶～。\e"
		}
	}
	when EMS_GC_CALLING {
		//魔术师共通反应
		GhostCall_Magic('ヒュールさん')
	}
}}END_CHANGE

