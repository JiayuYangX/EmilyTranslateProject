OnDive
{
	if reference[0] == 'インターネット' {
		"\u\s[10]\h\s[4]咦、\w5我刚在想明天的菜单做什么好、\w5不知不觉就\_a[http://ja.wikipedia.org/wiki/%E3%82%B5%E3%83%84%E3%83%9E%E3%82%A4%E3%83%A2]打开了维基百科的红薯页面\_a\w5…\w5…\w9\w9\u\s[11]…\w5…\w5真是的、\w5简直是扑通一声跳进了互联网的大海呢。\w9\n还游得很欢。"
	}
	else {
		"\u\s[10]\h\s[5]扑通一声跳进%(reference[0])！\w9\n啪嗒啪嗒。\w5啪嗒啪嗒。\w9\w9\u\s[11]…\w5…\w5白开心一场。\w9\w9\h\s[3]\n\n不过、\w5这水好脏啊——。\w9\w9\u\n\n…\w5…\w5猫不是怕水的吗？"
	}
}

OnBeerShower
{
	"\u\s[10]\p2\s[200]\h\s[3]唔——、\w5我不太喜欢啤酒呢。\w9\w9\u用来泼太浪费了。\w9\n我全喝掉算了。\w9\w9\p2\s[218]\h\s[28]\n\n\_s[0,2]%(charname(1))、\w5酒鬼——。\_s\w9\w9\u\s[17]\n\n…\w5…\w5真吵啊。"
}

//**** 属性 *****************************************************************

OnRequestProperty
{
	_text = ''
	if TOINT(reference[1]) < 0 { //负数时返回角色数的虚构规格
		_text = '3'
	}
	else {
		_text = EVAL('プロパティ' + reference[1] + "('" + reference[2] + "')")
	}
	
	if STRLEN(_text) {
		"\C\![raiseother,%(reference[0]),OnGetProperty,Emily,%(reference[1]),%(reference[2]),%(_text)]"
	}
}

プロパティ0 {
	case _argv[0] {
		when 'name','キャラクター名' {
			'艾米莉'
		}
		when '年齢層','世代' {
			'年轻人'
		}
		when '性別' {
			'女性'
		}
		when '種族' {
			'猫'
		}
		when '種族タイプ' {
			'人型'
		}
		when 'プロフィール' {
			'「艾米莉」\n自称SSP导航员。\n火属性。但无法控制。\n特别喜欢红薯料理。'
		}
		//CyberSphere
		//忠实遵循预览版数据。
		//UP30% AT30% AB0% AV10% 6GB
		//Skill 「魔法[炎]魔术+1」 「料理[家庭+1]」 「装傻」
		//Ability 「支援 常时发动 自身服务器上的其他角色判定时、判定+1
		//TECHNIQUE 拳2/长剑-/短剑-/枪-/斧-/杖-/弓-/鞭-/枪-/投-/防1/饰3
		when '行動タイプ' { //物理攻击 or 精神攻击
			'精神攻击' //魔法使。
		}
		when 'LIFE' { //体力
			12
		}
		when 'STR' { //筋力
			13
		}
		when 'DEX' { //灵巧
			6
		}
		when 'AGL' { //敏捷
			6
		}
		when 'MIN' { //精神
			12
		}
		when 'INT' { //智力
			7
		}
		when 'SEN' { //感性
			13
		}
	}
}

