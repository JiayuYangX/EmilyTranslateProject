	}
	else {
		"\p2\s[203]\u\s[10]\h\s[3]唔——、\w5%(E.AddKeisyou(reference[0],'さん'))、\w5不用那么钻牛角尖嘛。\w9\w9\p2是啊、\w5朋友当然是越多越好呢。\w9\w9\h\s[5]\n\n偶尔也会说好话呢——。\w9\n不愧是我弟弟——。\w9\w9\u\s[11]…\w5…\w5…。"
	}
}

OnVanishSelecting
{
	if sender != basewarename {
		"\u\s[10]\h\s[4]诶、\w5那个——、\w5我好歹也是SSP的导航员、\w5所以那个、\w5呃\w5…\w5…\w9\w9\u\s[11]谁叫你不怎么干活、\w5才会被人这么说啊。"
	}
}

