//****　对时　*********************************************************************

//----　对时开始 ------------------------------------------------------------------
OnSNTPBegin
{
	SHIORI3FW.RegisterTempVar('sntpflag')
	sntpflag = ""
	
	E.Title('对时')
	--
	"\u\s[10]\h\s[5]那、\w5我过去看看那边的钟。\w9\w9\u…\w5…\w5不、\w5这不是手动调啦。\e"
	"\u\s[10]\h\s[7]没想到！\w9我居然会对时！\w9\w9\u\s[11]…\w5…\w5现在要找不会这功能的才难呢。\e"
}

//----　获取成功、开始比较 ----------------------------------------------------------
SNTPCompare_StrForm
{
	_txt = _argv[0]
	SETDELIM(_txt,",")
	STRFORM("$04d/$02d/$02d $02d:$02d:$02d",TOINT(_txt[0]),TOINT(_txt[1]),TOINT(_txt[2]),TOINT(_txt[3]),TOINT(_txt[4]),TOINT(_txt[5]))
}

SNTPCompare_AboutTime
{
	_txt = _argv[0]
	SETDELIM(_txt,",")
	
	if TOINT(_txt[4]) > 45 {
		TOINT(_txt[3]) + 1
	}
	else {
		_txt[3]
	}
}

OnSNTPCompare
{
	SHIORI3FW.RegisterTempVar('sntpflag')
	sntpflag = "execute"
	
	E.Title('对时成功')
	--
	"\h\s[0]\_q/
	那边 %(SNTPCompare_StrForm(reference[1]))\n/
	这边 %(SNTPCompare_StrForm(reference[2]))\n/
	\n\_q\w9"
	
	"\h\s[0]比较强的钟是%(SNTPCompare_StrForm(reference[1]))。\w9\s[6]\n本地较弱的钟是%(SNTPCompare_StrForm(reference[2]))。\w9\w9\u好懂又不太好懂。\n\n\w9\w9\h\n\n"
	
	"\h\s[6]原子钟是%(SNTPCompare_StrForm(reference[1]))。\w9\n原始钟是%(SNTPCompare_StrForm(reference[2]))。\w9\w9\u…\w5…\w5\s[11]PC的是原始的吗。\n\n\h\n\n\w9\w9"
	
	"\h\s[6]那边的钟大概是%(SNTPCompare_AboutTime(reference[1]))点。\w9\n这边的钟大概是%(SNTPCompare_AboutTime(reference[2]))点。\w9\w9\u\s[11]大概、\w5是指\w5…\w5…\n\n\h\n\n\w9\w9"
	
	"\h\s[6]精工舍的报时为%(hour)点%(minute)分。\w9\w9\u\s[11]…\w5…\w5那是哪啊。\w9\w9\h\s[0]\n\n1951年9月1日、\w5日本首家民营广播电台——中部日本放送的报时哦。\w9\u\s[12]\n\n要对着几点调啊？！\n\n\h\n\n\w9\w9"
	
	--
	if TOINT(reference[3]) == 0
	{
		"\h\s[5]完全一致呢。\w9\w9\u\s[10]真是一丝不苟的人呢。\e"
		
		"\h\s[2]诶？\w9完全一致？\w9\w9\u哎呀哎呀。\w9\s[10]看来没我艾米莉的出场机会了呢。\w9\w9\p2\s[218]交给姐姐不放心、\w5我搞定了。\w9\w9\h\s[9]\n\n这是干嘛——。\e"
	}
	else
	{
		"\h\s[5]\6差了%(reference[3])秒、\w5我对好了。\e"
		
		"\h\s[6]\6差了%(reference[3])秒呢——。\w9\s[5]\n帮你调一下也行啦、\w5能给我买红薯吗？\w9\w9\u\s[11]…\w5…\w5说什么梦话呢。\w9\n对个时而已谁会给你买东西啊。\w9\w9\h\s[3]\n\n真没办法啊——。\w9我免费帮你调吧。\w9\w9\p2\s[205]\w9好、\w5修正——。\w9\s[-1]\w9\w9\h\s[7]\n\n我的工作被抢了——。\w9\w9\u\s[12]\n\n等等混蛋冷静点！\e"
	}
}

OnSNTPCorrect
{
	//忽略SNTPCompare的\6
	if sntpflag != "execute"
	{
		E.Title('对时成功')
		--
		"\u\s[10]\h\s[5]钟、\w5我已经对好了哦——。\e"
	}
}

//----　对时失败 ------------------------------------------------------------------
OnSNTPFailure
{
	E.Title('对时失败')
	--
	"\u\s[10]\h\s[4]哎呀。\w9\n钟坏了。\w9\w9\u…\w5…\w5真的假的？\e"
}

//**** 日历 *****************************************************************

//---- 读取 ------------------------------------------------------------------
OnSchedule5MinutesToGo
{
	ScheduleReadProc(1)
}

OnScheduleRead
{
	ScheduleReadProc(0)
}

#define SCHEDULE_TITLELEN 15

ScheduleCutTitle
{
	_n = STRLEN(_argv[0])
	if _n > SCHEDULE_TITLELEN {
		_argv[0] = SUBSTR(_argv[0],0,SCHEDULE_TITLELEN)
		_argv[0] += "..."
	}
	_argv[0]
}

ScheduleTranslateScript
{
	_text = _argv[0]
	_text = REPLACE(_text,"\1","\\1")
	_text = REPLACE(_text,"\4","\\4")
	_text = REPLACE(_text,"\5","\\5")
	_text = REPLACE(_text,"\6","\\6")
	_text = REPLACE(_text,"\7","\\7")
	_text
}

ScheduleReadProc
{
	if _argv[0] {
		E.Title("提前5分钟：%(ScheduleCutTitle(reference[1]))")
	}
	else {
		E.Title("日程：%(ScheduleCutTitle(reference[1]))")
	}
	--
	"\u\s[10]\h\s[0]"
	--
	if _argv[0] {
		"\u\s[10]\0\s[5]各位——！\w9\n%(reference[1])、还有5分钟！\w9\w9\1…\w5…\w5各位什么的、\w5告诉%(username)不就好了吗？\w9\w9\0\s[6]\n\n到时间的时候、\w5后面的人会…\w5…\w5\w9\w9\1\s[12]\n\n后面！？\e"

		"\u\s[10]\0\s[5]啊嗬咕噗！啊嗬咕噗！\w9\n%(reference[1])还有啊嗬咕噗！\w9\w9\1…\w5…\w5看起来很开心呢。\w9\w9\0\n\n这是工作！\w9\w9\1\n\n你以前有这么热心工作吗…\w5…\w5\e"
	}
	else {
		ScheduleTranslateScript(reference[3])
	}
	
	res_securitylevel = "External"
}

//---- 感知开始 ------------------------------------------------------------------
OnSchedulesenseBegin
{
	E.Title("获取日程：%(reference[0])")
	--
	"\u\s[10]\h\s[5]我去问问看有什么事。\e"
}

