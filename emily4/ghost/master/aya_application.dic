//**** Drift ***************************************************************************

//---- OnNekodorifObjectHit事件 -----------------------------------------------------
OnNekodorifObjectHit
{
	if reference[4] == "エミリ"	// 此处指定sakura名
	{
		OnNekodorifObjectHitSakura
	}
	else
	{
		OnNekodorifObjectHitKero
	}
}

//---- 碰到本体侧 -----------------------------------------------------------------
