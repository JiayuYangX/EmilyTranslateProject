OnChoiceSelect_INTRODUCE_EMILY
{
	"\t\![set,choicetimeout,0]"
	--
	"\u\s[10]\p2\s[200]\h\s[5]我，\w5艾米莉。\w9\n\s[1]羞花闭月16岁。\w9\w9\n\s[5]喜欢的东西是红薯♪\w9\n特技是火焰魔法哦♪\w9\w9\w9\n…\w5…\w5\s[4]不过偶尔会失败呢。\w9\w9\p2\s[204]（…\w5…\w5不是偶尔吧）\w9\h\s[7]\n\n（那边闭嘴！）\w9\w9\n\s[5]在做SSP的官方导航员之类的。\w9有什么不懂的尽管问哦♪\w9\w9\s[1]\n三围和体重保密哦。\w9\w9\u\s[11]（不是能说的体型罢了。）\w9\h\s[7]\n\n（吵死了！）\w9\w9\w9\n\s[5]那就，\w5先这样啦。\w9\w9\u\n\n…\w5…\w5%(RAND(20) + 10)分。\w9\w9\p2\s[218]\n\n…\w5…\w5不合适。\w9\w9\h\n\n\s[7]你们——！？\w9\w9\u\s[12]\p2\s[202]\_s[1,2]\n\n哎哟！\_s\w9\_s[1,2]\s[-1]\_s"
	--
	DispReturnCommand('INTRODUCE_RETURN')
	
	magic_flag = 1
}

OnChoiceSelect_INTRODUCE_TEDDY
{
	"\t\![set,choicetimeout,0]"
	--
	"\h\s[4]\p2\s[200]\u\s[10]（嘎吱嘎吱）\w9\w9\n嗯？\w5我？\w9\n名字是泰迪，\w5姑且是这家伙的监督者。\w9\w9\n因为不知道会干出什么事来。\w9\w9\h…\w5…\w5…。\w9\w9\u\n\n总之请多关照。\w9\w9\p2\s[204]你要么吃要么说选一个吧。\w9\w9\h\n\n\s[21]…\w5…\w5…\w5…。\w9\n（好好吃\w5…\w5…。）\w9\w9\u\s[11]\n\n哼。"
	--
	DispReturnCommand('INTRODUCE_RETURN')
}

OnChoiceSelect_INTRODUCE_EMILIO
{
	"\t\![set,choicetimeout,0]"
	--
	"\u\s[10]\h\s[0]\p2\s[200]\w9诶，\w5轮到我了？\w9\n我叫艾米利欧。\w9\w9\u…\w5…\w5这就完了？\w9\w9\p2\s[204]\n\n还能让我说什么啊。\w9\w9\h\s[3]艾米利欧，\w5态度再不好一点可是会被丢掉的哦？\w9\w9\p2\s[207]\n\n烦死了——。\w9\s[204]\n被笨蛋姐姐折腾个不停的悲剧弟弟啦。\w9\w9\s[200]\n喜欢吃的东西是…\w5…\w5\s[203]\w9\w9\w9\w9\h\s[0]\n\n忘了？\w9布丁吧。\w9\w9\p2\s[217]\n\n唔，\w5闭嘴啦。\w9别说出来啊。\w9\w9\h\s[4]\n\n又没什么好害羞的。\w9\w9\p2\s[205]\n\n嘛，\w5比起老姐那样吃着红薯连放屁要好多了吧。\w9\w9\h\s[7]\n\n喂，\w5胡说八道什么！"
	--
	DispReturnCommand('INTRODUCE_RETURN')
}

OnChoiceSelect_INTRODUCE_NAZO
{
	<<"
	\u\s[-1]\0\s[4]呼——，扔完垃圾了…\w5…\w5\w9\n为什么垃圾这么多啊。\w9\s[3]\n嘛，基本都是红薯皮啊、布丁杯啊、零食袋之类的…\w5…\w5\w9\s[4]\n得稍微忍忍才行啊。\w9\n最近有点在意体型…\w5…\w5\w9\w9\p[3]\s[500]Pya。\w9\w9\0\s[2]\n\n哇啊，吓了一跳！\w9\w9\p[3]\n\nPya。Pya。\w9\w9\0\s[8]\n\n…\w5…\w5嗯——。\w9\w9\p[3]\n\nPyapya。\w9\w9\0\n\n那个，你是从哪个星球来的…\w5…\w5\w9\w9\p[3]\n\nPya？\w9\w9\0\s[4]\n\n…\w5…\w5果然行不通啊。\w9\s[0]\n那，你是谁？\w9\w9\p[3]\n\n…\w5…\w5Pya——。\s[-1]\w9\w9\0\s[4]\n\n啊，走掉了…\w5…\w5\w9\s[1]\n虽然感觉它想说什么…\w5…\w5\e
	==========
	\u\s[10]\0\s[0]…\w5…\w5就是这么回事，刚才有个奇怪的孩子。\w9\w9\1…\w5…\w5奇怪的孩子啊。\w9\w9\p[2]\s[201]是不是野狗什么的？\w9\w9\0\s[4]\n\n不，是狗的话应该叫「汪！」吧？\w9\w9\1\n\n也是。\w9\w9\0\s[3]\n\n泰迪，跟我一起来一下好不好？\w9\n总觉得有点在意。\w9\w9\1\n\n…\w5…\w5那个——，我又不是翻译。\w9\w9\0\s[7]\n\n我请你吃蟹肉罐头！！\w9\w9\1\s[11]\n\n来，你干嘛呢。快点走吧？\w9\w9\p[2]\s[208]\n\n…\w5…\w5啊啊，被零食钓到了…\w5…\w5\e
	==========
	\u\s[10]\0\s[0]…\w5…\w5就是这儿。\w9\w9\1垃圾场？\w9\w9\0\n\n多半是肚子饿了来翻垃圾的吧…\w5…\w5\w9\w9\1\s[11]\n\n今天不是不可燃垃圾吗？怎么想也…\w5…\w5\w9\w9\0\s[3]\n\n不过，动物又不懂这些…\w5…\w5\w9\w9\1\s[10]\n\n也是啊。\w9\w9\p[3]\s[500]…\w5…\w5Pya。\w9\w9\0\s[2]\n\n啊，在那儿！\w9\w9\1\n\n…\w5…\w5白白又毛茸茸…\w5…\w5\w9\n这难道是。\w9\w9\0\n\n知，知道就告我一声！\w9\w9\1\n\n谁啊。\w9\w9\p[3]\n\nPya——。Pya——。\w9\w9\1\n\n…\w5…\w5\w9\n棉花糖！\w9\w9\p[3]\s[-1]\n\n（咕噜转）\w9\w9\0\s[8]\n\n…\w5…\w5好厉害，卷起来就像棉花糖一样。\w9\n不过这个，玩了没问题吗。\w9\w9\1\n\n别在意。\w9\w9\p[3]\s[500]\n\nPya！Pya——！\w9\w9\0\n\n看生气了。\w9\w9\1\n\n嗯——。\w9\n那…\w5…\w5拖把！\w9\w9\p[3]\s[-1]\n\n（嗖——，嗖——）\w9\w9\0\s[2]\n\n哦哦，好厉害！假装在铺装路面拖地呢！\w9\w9\1\n\n…\w5…\w5嗯，白色的毛全糟蹋了呢。\w9\w9\p[3]\s[500]\n\nPya——！！\w9\w9\0\s[8]\n\n看，又生气了。\e
	==========
	\p[3]\s[500]\0\s[3]所以，结果这孩子到底是什么？\w9\w9\1\s[10]谁知道？\w9\w9\0\s[4]\n\n话说，你不是能听懂它的话吗？\w9\w9\1\n\n大致能懂啦。\w9\n说很了解艾米莉的事。\w9\w9\p[3]Pya。\w9\w9\0\s[27]\n\n可是，我不认识你啊？\w9\w9\p[3]\n\nPya——。Pya——。\w9\w9\1\n\n说是有个漂亮的姐姐桑，总在这附近开心地走来走去，所以很在意。\w9\w9\0\s[1]\n\n那，那该不会是…\w5…\w5我？\w9\w9\p[3]\n\nPya。\w9\w9\1\n\n…\w5…\w5大概吧。\w9\w9\0\s[4]\n\n啊真是。\w9\w9\p[3]\n\nPyapya。Pya——。\w9\w9\1\n\n…\w5…\w5说会永远在姐姐桑的身边。\p[3]\s[-1]\n\n\w9\w9\0\s[0]\n\n…\w5…\w5在身边？\s[4]话说，已经不在了啊。\w9\w9\1\n\n…\w5…\w5…\w5\e
	==========
	\p[2]\s[200]\0\s[0]所以，到底是怎么回事呢。\w9\w9\1\s[10]…\w5…\w5…\w5呢。\w9\w9\p[2]\s[214]结果泰迪也没搞懂啊。\w9\w9\0\s[27]\n\n不过，怎么说呢？总觉得好像在哪儿见过…\w5…\w5\w9\w9\p[2]\s[203]\n\n说一直在一起，是什么意思呢？\w9\w9\1\n\n（…\w5…\w5难道说，是红薯的精灵什么的…\w5…\w5\w9\n　有点难以置信呢。\w9\n　可是，说跟艾米莉在一起…\w5…\w5\w9\n　只能想到这个了啊。）\w9\w9\0\s[5]\n\n嘛，总之先吃饭吧！肚子饿了。\w9\w9\p[2]\s[208]\n\n哈哈哈哈…\w5…\w5\w9\w9\1\n\n那，今天的饭呢？\w9\w9\0\n\n红薯饭哦！\w9\w9\p[2]\s[204]\n\n又是红薯啊。\w9\w9\0\s[7]\n\n有意见的话，自己做！\w9\w9\p[2]\n\n对不起。\e
	==========
	\p[2]\s[200]\0\s[5]呼——，吃饱啦～！\w9\w9\1\s[10]肚子好饱呢。\w9\w9\p[2]\s[204]啊——，偶尔想出去吃啊。\w9\w9\0\s[4]\n\n不——行，得省点钱…\w5…\w5\w9\n（Pyah）\w9\w9\1\n\n…\w5…\w5嗯？那个孩子？\w9\w9\p[2]\s[202]\n\n诶，在哪在哪？\w9\w9\0\s[8]\n\n诶？不，不在吧？\w9\w9\1\n\n刚才，确实有声音…\w5…\w5\w9\w9\p[2]\s[203]\n\n对吧？\w9\w9\0\n\n是，是错觉吧…\w5…\w5\w9\w9\1\n\n不——，绝对是。那个声音嘛。\w9\w9\0\s[9]\n\n不\w9在\w9！！真的！！\w9\w9\1\n\n…\w5…\w5你在较什么劲啊。\w9\n一会儿说见到，一会儿说不在…\w5…\w5\w9\w9\p[2]\s[218]\n\n…\w5…\w5我说姐姐，你放了屁吧？\w9\w9\0\n\n才，才没有呢！\w9\w9\1\n\n…\w5…\w5…\w5…\w5那种慌张的样子才可疑呢。\w9\w9\0\n\n才～～～没～～～有～～～！！\w9\w9\p[2]\s[204]\n\n嘛，算了。反正也不是第一次了。\w9\w9\1\n\n也是。\w9\n（…\w5…\w5难道，不是红薯…\w5…\w5）\w9\w9\0\s[-1]\n\n呜，呜哇哇哇哇！！\w9\w9\1\n\n…\w5…\w5啊。\w9\w9\p[2]\n\n是不是说过了点。\w9\w9\1\n\n…\w5…\w5嘛，随时都能见的啦。大概。\e
	">>
}

//============设定=================================================================================
ToolTip_CONFIG
{
	"仅适用于艾米莉的设置菜单。"
}

OnChoiceSelect_CONFIG
{
	E.Title('菜单：设置')
	--
	"\u\s[10]\h\s[4]总觉得不太懂这些设置诶。\n[50]\w9\w9\u\s[11]…\w5…\w5…\w9"
	--
	Config_Menu
}

Config_Disp
{
	E.Title('菜单：设置')
	--
	if _argc {
		REPLACE(_argv[0],'\e','')
	}
	else {
		"\u\s[10]\h\s[5]修改完成～。"
	}
	--
	Config_Menu
}

Config_AITalk_Interval_Disp
{
	if aitalkinterval {
		if aitalkinterval >= 60 {
			if aitalkinterval % 60 == 0 {
				'　' + HAN2ZEN(STRFORM('$2d',aitalkinterval / 60),'number,symbol') + '分'
			}
			else {
				"%(STRFORM('$2d',aitalkinterval / 60))分%(STRFORM('$2d',aitalkinterval % 60))秒"
			}
		}
		else {
			'　' + HAN2ZEN(STRFORM('$2d',aitalkinterval),'number,symbol') + '秒'
		}
	}
	else {
		'　ＯＦＦ'
	}
}

Config_Menu
{
	"\h\_q\b[2]\t"
	--

	//////////////////////////////////////////////////////////////////
	'\n\_l[4]' + E.CheckMark(aitalkinterval) + '\q['
	--
	MenuItem("［%(Config_AITalk_Interval_Disp)］自主聊天频率") + ',CONFIG_TALKINTERVAL]'
	--

	//////////////////////////////////////////////////////////////////
	'\n\_l[4]' + E.CheckMark(config_disp_emilio) + '\q['
	--
	if config_disp_emilio {
		"%(MenuItem('［　　ＯＮ］总是显示艾米利欧')),CONFIG_EMILIO]"
	}
	else {
		"%(MenuItem('［　ＯＦＦ］总是显示艾米利欧')),CONFIG_EMILIO]"
	}
	--
	
	//////////////////////////////////////////////////////////////////
	if 'Phase4' _in_ SHIORI3FW.ShellName { //Phase4 Phase4.5
		'\n\_l[4]' + E.CheckMark(! config_newbies_info_disable) + '\q['
		--
		if ! config_newbies_info_disable {
			"%(MenuItem('［　　ＯＮ］显示「新手指导」')),CONFIG_NEWBIES]"
		}
		else {
			"%(MenuItem('［　ＯＦＦ］显示「新手指导」')),CONFIG_NEWBIES]"
		}
	}
	--

	//////////////////////////////////////////////////////////////////
	'\n\_l[4]' + E.CheckMark(! config_ghostclose_event_disable) + '\q['
	--
	if ! config_ghostclose_event_disable {
		"%(MenuItem('［　　ＯＮ］关闭其他人格时做出反应')),CONFIG_GHOSTCLOSE]"
	}
	else {
		"%(MenuItem('［　ＯＦＦ］关闭其他人格时做出反应')),CONFIG_GHOSTCLOSE]"
	}
	--
	
	//////////////////////////////////////////////////////////////////
	'\n\_l[4]' + E.CheckMark(! disable_battery_notify) + '\q['
	--
	if ! disable_battery_notify {
		"%(MenuItem('［　　ＯＮ］显示电池状态')),CONFIG_BATTERY]"
	}
	else {
		"%(MenuItem('［　ＯＦＦ］显示电池状态')),CONFIG_BATTERY]"
	}
	--
	
	//////////////////////////////////////////////////////////////////
	'\n\_l[4]' + E.CheckMark(! disable_surface_restore) + '\q['
	--
	if ! disable_surface_restore {
		"%(MenuItem('［　　ＯＮ］允许对话时重置表情')),CONFIG_SURFACERESTORE]"
	}
	else {
		"%(MenuItem('［　ＯＦＦ］允许对话时重置表情')),CONFIG_SURFACERESTORE]"
	}
	--
	
	//////////////////////////////////////////////////////////////////
	_menutext = '［' + HAN2ZEN(STRFORM('$4d',TOINT(news_talk_flag)),'number,symbol') + '］时事桥段计数器重置'
	
	'\n\_l[4]' + E.CheckMark(news_talk_flag) + '\q[' + MenuItem(_menutext) + ',CONFIG_RESET_NEWS]'
	--
	
	//////////////////////////////////////////////////////////////////
	_menutext = '［' + HAN2ZEN(STRFORM('$4d',ARRAYSIZE(lasttalksummary)),'number,symbol') + '］脚本日志重置'

	'\n\_l[4]' + E.CheckMark(ARRAYSIZE(lasttalksummary)) + '\q[' + MenuItem(_menutext) + ',CONFIG_RESET_LOG]'
	--
	DispReturnCommand('MAINMENU')
	--
	'\_q'
}

//============黑板============================================================================
ToolTip_CONFIG_NEWBIES
{
	'「新人」的操作说明黑板的显示设置。'
}

OnChoiceSelect_CONFIG_NEWBIES
{
	config_newbies_info_disable = ! config_newbies_info_disable
	
	ShowHideNewbiesInfo(!config_newbies_info_disable)
	--
	Config_Disp
}

ShowHideNewbiesInfo
{
	if _argv[0] {
		'\p[4]\s[700]'
		--
		if ! newbies_pos_not_inited {
			'\w1\![move,0,0,0,0,center.top,center.bottom]'
			newbies_pos_not_inited = 1
		}
	}
	else {
		'\p[4]\s[-1]'
	}
}

//============说话频率============================================================================
ConfigTalkInterval
{
	E.Title("菜单：设置-对话频率［%(Config_AITalk_Interval_Disp)］")
	--
	//---- 对话频率的调整
	"%(_argv[0])\_q\h\n[50]"
	--
	"\n\_l[4]\![*]\q[%(MenuItem('机关枪(15秒间隔)')),CONFIG_TALKMAXHEART]"
	--
	"\n\_l[4]\![*]\q[%(MenuItem('很吵(1分间隔)')),CONFIG_TALKMAX]"
	--
	"\n\_l[4]\![*]\q[%(MenuItem('正常(2分间隔)')),CONFIG_TALKNORMAL]"
	--
	"\n\_l[4]\![*]\q[%(MenuItem('安静(5分间隔)')),CONFIG_TALKPOOR]"
	--
	"\n\_l[4]\![*]\q[%(MenuItem('不许说话')),CONFIG_TALKNONE]"
	--
	if basewarename == 'SSP' {
		"\n\_l[4]\![*]\q[%(MenuItem('偏好设置')),CONFIG_TALKCUSTOM]"
	}
	--
	DispReturnCommand('CONFIG')
}

ToolTip_CONFIG_TALKINTERVAL
{
	'艾米莉自动聊天的频率设置。'
}

OnChoiceSelect_CONFIG_TALKINTERVAL
{
	ConfigTalkInterval("\0\s[0]大概要少才合适呢？")
}

OnChoiceSelect_CONFIG_TALKMAXHEART
{
	//---- 机关枪(15秒间隔)
	aitalkinterval = 15
	ConfigTalkInterval("\u\s[10]\h\s[7]我一般不是这样说话的啊！！\w9\w9\u…\w5…\w5嗯，\w5是啊。")
}

OnChoiceSelect_CONFIG_TALKMAX
{
	//---- 吵闹地说话(1分间隔)
	aitalkinterval = 60
	ConfigTalkInterval("\u\s[10]\h\s[7]我一般不是这样说话的啊！！\w9\w9\u…\w5…\w5嗯，\w5是啊。")
}

OnChoiceSelect_CONFIG_TALKNORMAL
{
	//---- 正常说话(2分间隔)
	aitalkinterval = 120
	ConfigTalkInterval("\u\s[10]\h\s[4]一般而言，这是最难的。\w9\w9\u嘛，\w5我想以平时的对话品频率就好。")
}

OnChoiceSelect_CONFIG_TALKPOOR
{
	//---- 安静地说话(5分间隔)
	aitalkinterval = 300
	ConfigTalkInterval("\u\s[10]\h\s[21]稍微有点太吵了呢。\w9\w9\u偶尔说说话就够了。")
}

OnChoiceSelect_CONFIG_TALKNONE
{
	//---- 不说话
	aitalkinterval = 0
	ConfigTalkInterval("\u\s[11]\h\s[4]\_s…\w5…\w5…\w5…。\_s")
}

OnChoiceSelect_CONFIG_TALKCUSTOM
{
	//---- 自定义
	"\![open,sliderinput,OnChoiceSelect_CONFIG_TALKCUSTOM_DONE,0,%(aitalkinterval),10,900]"
	--
	"\u\s[10]\h\s[0]最右侧是15分钟，\w5最左侧是10秒。\w9\w9\u想不保存设置直接退出的话，按Esc键。"
}

OnChoiceSelect_CONFIG_TALKCUSTOM_DONE
{
	//---- 自定义完成
	aitalkinterval = TOINT(ZEN2HAN(reference[0]))
	ConfigTalkInterval("\u\s[10]\h\s[5]设置完成。")
}

