//*********连接(1)***************************************************************
HELP_network_network_protocol : array
{
	//内容(脚本)
	"\u\s[10]\h\s[27]泰迪，\w5IPv6是什么？\w9\w9\u是新网络通信方式。\w9\n不过很多情况下旧的也能用。\w9\w9\h\s[5]\n\n原来如此～。\w9\w9\u\n\n一般选Auto就行，\w5有什么不对劲的时候，\w5可以只选旧的IPv4，\w5或者选IPv4 => IPv6有时能修好。"

	//标题(不需要时可为空)
	"使用的网络协议"
}
HELP_network_proxy : array
{
	//内容(脚本)
	"\u\s[10]\h\s[4]P，\w5Proxy\w5…\w5…\w5差点咬舌头。\w9\w9\u\s[10]是代理服务器设置呢。\w9\n不设这个的话，\w5有时会连不上网，\w5请留意。"

	//标题(不需要时可为空)
	"代理服务器(Proxy)设置"
}
HELP_network_proxy_use_system_setting : array
{
	//内容(脚本)
	"\h\s[0]\u\s[10]下面的代理服务器设置不太懂的人，\w5先在这里打勾。\w9\w9\h\s[5]系统会自动查设置！\w9\n我好厉害！\w9\w9\u\s[11]\n\n在查的不是艾米莉吧。"

	//标题(不需要时可为空)
	"" //自动使用Proxy->Windows设置
}
HELP_network_timesync : array
{
	//内容(脚本)
	"\u\s[10]\h\s[5]连时间同步什么的也能做！\w9\w9\u可以通过网络同步时间哦。\w9\nWindows XP以后是标准功能所以可能不太用到了。\w9\w9\h\s[27]\n\n不过这，\w5HTTP和SNTP是什么？\w9\w9\u\n\n详细讲起来太长就不说了，\w5一般用SNTP就行。"

	//标题(不需要时可为空)
	"时间同步"
}
HELP_network_auto_timesync : array
{
	//内容(脚本)
	"\h\s[0]\u\s[10]时间同步的自动执行呢。\w9\n隔几小时自动设置一次。\w9\w9\h\s[5]懒人专用设置——。\w9\w9\u\s[11]\n\n…\w5…\w5嘛，\w5倒也没错。\w9\w9\n\s[10]几小时，\w5里，\w5也包含SSP没有启动的时间。"

	//标题(不需要时可为空)
	"自动执行时间同步"
}
HELP_network_connection_limit : array
{
	//内容(脚本)
	"\u\s[10]\h\s[4]说是禁止上网的设置。\w9\n对我们来说就像惩罚游戏一样呢。\w9\w9\u很久以前，\w5有个叫深夜定额上网的东西，\w5在到时间之前都得忍着\w5…\w5…\w9\w9\h\s[8]\n\n喂，\w5泰迪？"

	//标题(不需要时可为空)
	"网络连接询问"
}
HELP_network_ssl_verify : array
{
	//内容(脚本)
	"\u\s[10]\h\s[4]SSL？\w5TLS？\w9\w9\u是加密通信时是否好好验证\w5「证书」\w5的设置。\w9\n一般是ON\w5…\w5…\w5不如说，\w5OFF了才危险呢。\w9\w9\h\s[27]\n\n到底什么意思啊。\w9\w9\u\n\n就相当于浏览器里出现那个钥匙标记的同类检查是否要做，\w5这样的意思。\w9\w9\h\s[5]\n\n原来如此～。"

	//标题(不需要时可为空)
	"" //在SSL/TLS通信中验证服务器证书
}

