///////// 帮助！

OnConfigurationDialogHelp
{
	//reference[0]-对话框ID
	//reference[1]-对话框标题
	//reference[2]-项目类型:项目名
	//reference[3]-项目内容文本
	
	_a = SPLIT(reference[2],':',2)
	_name = _a[1]
	_type = _a[0]
	
	"\0\v"
	--
	E.Title("帮助")
	--
	_v = EVAL("HELP_%(reference[0])_%(_name)")
	
	_title = _v[1]
	if _title == '' {
		_title = reference[3]
	}
	_title = SHIORI3FW.MakeShortText(_title,40)
	_name = SPLIT(reference[1],' : ')[0]
	
	"\_q\f[height,10]\_?%(_name) > %(_title)\_?\f[height,default]\n\n[half]\_q"
	--
	_v[0]
}

