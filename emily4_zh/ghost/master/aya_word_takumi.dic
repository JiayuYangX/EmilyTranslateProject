///////// 匠单词词典
///////// 调用用户函数takumi时触发

takumi
{
	_n = RAND(89)
	if _n >= 66 {
		_th1 = takumi_s
		_th2 = takumi_s
		if _th1 == _th2 {
			_th1 + "的" + takumi_f
		} else {
		_th1 + "和" + _th2 + "的" + takumi_f
		}
	} else {
		takumi_l + takumi_f
	}
}

takumi_l
{
	//普通风格系
	"自然素材的";"沉醉日本建筑的";"浪速的";"多功能的";"对比的";"现代主义的";"温情的";"三次元的";"节约翻新的";"境界线的";"隔断的";"功能美的";"祥和的";"安逸的";"体感面积的";"生活的";"温柔功能的";"森林之木的";"安逸的";"古老优良住宅的";"游玩的";"居住的";"穿堂风的";"休闲的";"居住的";"快节奏的"
	//空间系
	"治愈空间的";"功能空间的";"空间演出的";"狭小空间的";"安居空间的";"住空间的";"时空间的";"住空间的";"四季彩空间的";"雅空间的";"住空间的";"住空间的";"未来空间的";"居住空间的";"空间构造的";"空间构造的";"空间构造的";"立体空间的";"居住空间的";"空间方程式的";"立体空间的";"空间构成的";"温柔空间的"
	//住宅系·住○○系
	"混凝土住宅的";"寒冷住宅的";"怀古住宅的";"感动住宅的";"个性派住宅的";"元气住宅的";"宽裕住宅的";"触感住宅的";"健康住宅的";"住构造的";"住功能的";"住环境的";"住风景的"
	{
		//庭院系是稀有设定
		"废料的";"健康庭园的"
	}
}

takumi_s
{
	//用于「○○与●●的」模式的元素
	"光";"收纳";"空间";"流动";"宽裕";"时";"空间";"动线";"和风";"现代";"风";"光";"风";"光";"心";"空间";"人";"空间";"宽裕";"天空";"家";"心";"空间";"宽裕";"安心";"滋润";"水";"灯火";"和风";"光";"光";"风";"光";"影"
	{
		//庭院系即便如此仍是稀有设定
		"花";"木"
	}
}

