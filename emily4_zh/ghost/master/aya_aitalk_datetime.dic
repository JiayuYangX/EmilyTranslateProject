RandomTalkSub_fall : array
{
	'\u\s[10]\h\s[5]秋天了呢——。\w9\w9\u是呢——。\w9\w9\h\n\n好想去看红叶啊。\w9\w9\u\n\n嗯？\w5想看红叶？\w9\n那，\w5\\![call,ghost,红…\w9\h\s[4]\n\n不是，不是那个意思。\e'
	
	'\h\s[0]\p2\s[200]\u\s[10]…\w5…\w5天高艾米莉肥之秋。\w9\w9\h\s[7]吵死了！！\w9\w9\p2\s[206]…\w5…\w5噗——，放屁也是一个人。\w9\w9\h\s[4]\n\n真是，\w5饶了我吧。'
	
	'\h\s[-1]\p2\s[205]\u\s[10]泰迪的烹饪笔记——。\w9\w9\p[2]嗯？\w5今天是什么呢？\w9\w9\u\n\n秋天了来做红薯泥吧。\w9\w9\p[2]\n\n啊，\w5好啊。\w9\n材料呢？\w9\w9\u\n\n红薯・\w5砂糖・\w5蛋・\w5鲜奶油・\w5牛奶・\w5炼乳。\w9\w9\p[2]\s[206]\n\n嗯，\w5这里是笔记呢。\w9\w9\u\n\n首先把红薯切成合适大小浸水去涩。\w9\w9\p[2]\s[200]\n\n皮怎么处理？\w9\w9\u\n\n稍微削厚一点哦。\w9\w9\n适当时间后把红薯用热水蒸熟。\w9\n然后\w5…\w5…\w9\w9\h\s[5]啊——♪\w9\n是红薯君呀——♪\w9\w9\n（抓）\w9\w9\w9\s[-1]\w9\w9\u\s[11]…\w5…\w5被艾米莉拿走了。\w9\w9\p[2]\s[204]\n\n…\w5…。'
	
	'\u\s[10]\p2\s[200]\h\s[5]秋天！！\w9是秋天哦！！\w9\w9\p2\s[202]姐姐在燃烧。\w9\w9\u毕竟是秋天嘛。\w9\w9\h\n\n好，\w5有红薯的农产品直销所已全部确认完毕！！\w9\n走了你们两个！！\w9\w9\u\s[11]\p2\s[214]\_s[1,2]\n\n（…\w5…\w5地狱直销所巡礼再次\w5…\w5…）\_s'
	
	'\u\s[-1]\p2\s[-1]\h\s[21]（悄悄）\w9\w9\u\s[11]%(charname(0))，\w5去哪？\w9\w9\h\s[8]\n\n啊哈哈，\w5去一下朋友家\w5…\w5…\w9\w9\u\s[17]\n\n不行！\w9\w9\p2\s[221]（悄悄）\w9\w9\u\n\n%(charname(2))也别跑！！\w9\w9\p2\s[203]\n\n诶——，\w5果然非弄不可吗？\w9\w9\h\s[4]\n\n剥栗子皮好麻烦啊——。\w9\w9\u\n\n你们两个不做谁来做！？\w9\n这样怎么做出好吃的栗子饭嘛！！\w9\w9\p2\s[214]\n\n就因为拿不了刀，\w5只有%(charname(1))休息太狡猾了。\w9\w9\u\n\n这也是为了好吃的栗子饭！！\w9\n别抱怨！！\w9\w9\_s[0,2]\n\n嘿噗——。\_s'
	
	'\u\s[10]\h\s[20]\i[61]\w9\w9\s[5]我回来啦——。\w9\w9\u欢迎回来。\w9\n买东西辛苦了。\w9\w9\h\n\n听我说！\w9\n买了新米回来！！\w9\w9\u\n\n啊，\w5不错呢。\w9\w9\h\n\n那，\w5准备做饭了呢。\w9\w9\u\n\n好，\w5拜托啦——。\w9\w9\h\s[-1]\u\s[-1]\w9\w9\w9\h\s[55]\u\s[10]\n\n我开动了。\w9\n…\w5…\w5嗯，果然新米好吃呢。\w9\w9\h\s[8]\n\n…\w5…\w5那个，\w5不是新米是旧米？\w9\w9\u\s[11]\n\n…\w5…\w5…。'
	
	{
		'\u\s[10]\p2\s[200]\h\s[20]\i[61]\w9\w9\s[5]我回来啦——。\w9\w9\u欢迎回来。\w9\w9\p2\s[205]买东西辛苦了。\w9\w9\h\n\n今天是秋刀鱼！\w9\w9\p2\n\n啊，\w5不错呢。\w9\w9\u\n\n盐烤秋刀鱼配萝卜泥是秋天标配嘛。\w9\w9\h\s[8]\n\n…\w5…\w5啊，忘买萝卜了。'
		--
		'\w9\w9\u\s[12]\p2\s[202]\_s[1,2]\n\n…\w5…\w5…。\_s\u\s[17]\p2\s[207]\_s[1,2]\w9\n诶——。\w9没有萝卜泥吗——？\_s\w9\w9\h\s[4]\n\n嘿噗——。'
		
		'\w9\w9\u\s[11]\n\n诶——。\w9没有萝卜泥吗——？\w9\w9\p2\s[205]\n\n啊，\w5有姐姐的萝卜腿嘛算了。\w9\w9\h\s[9]\n\n谁是萝卜腿啊！\w9\w9\p2\s[217]\n\n还什么也没说吧！'
	}
	
	'\h\s[0]\p2\s[-1]\u\s[-1]\w9\w9\s[10]我回来了。\w9\w9\h嗯，\w5欢迎回来。\w9\w9\u\n\n刚才，\w5碰见对门的邻居，\w5给了我松茸。\w9\n说是去采松茸带回来的分享。\w9\w9\h\s[5]\n\n太好了——。\w9高级食材啊——。\w9\w9\p2\s[205]我回来啦——。\w9\n刚才，\w5碰见隔壁的阿姨，\w5给了我红薯。\w9\w9\n说是去挖红薯带回来的分享。\w9\w9\h\s[2]\n\n诶！？\w9\n红薯！？\w5红薯！？\w9\w9\n\s[5]太好了——♪\w5烤红薯——♪\w9\w9\u\s[11]\n\n…\w5…\w5比起松茸还是红薯啊。'
	
	'\u\s[10]\h\s[0]\p2\s[205]姐姐——，\w5给你礼物哦。\w9\w9\h\s[2]哇，\w5这么多红薯！\w9怎么了，\w5这是。\w9\w9\u忘了吗？\w9\n今天不是%(charname(2))学校去挖红薯了嘛。\w9\w9\h\s[4]\n\n怎么这么失策——。\w9\w9\u\s[11]\n\n不，\w5也不是什么了不起的事啦。\w9\w9\p2\s[200]\n\n想着要给姐姐，\w5在学校忍住没吃带回来的。\w9\w9\s[205]感谢我吧。\w9\w9\h\s[31]\n\n啊啊，\w5我这是有了多好的弟弟啊——。\w9\w9\u\n\n…\w5…\w5真是便宜的姐姐\w5…\w5…\w9\w9\h\s[9]\n\n你说谁！！'
	
	'\h\s[0]\p2\s[200]\u\s[10]%(charname(0))——，\w5%(charname(2))——。\w9\n隔壁的阿姨说，\w5下个周日，\w5要不要一起去赏红叶？。\w9\w9\p[2]\s[205]啊，\w5天气好就好了呢。\w9\n得准备便当。\w9\w9\h\s[27]呃——，\w5有篮子就好了，\w5垃圾袋也行吗？\w9\w9\u\s[11]\n\n诶？\w9\w9\h\s[3]\n\n所以是赏红叶对吧？\w9\w9\p[2]\s[203]\n\n为什么赏红叶要篮子和垃圾袋？\w9\w9\h\s[6]\n\n抓兔子是什么？\w9\w9\u\s[10]\p2\s[206]\_s[1,2]\n\n打兔子。\_s\w9\w9\h\n\n采蘑菇是什么？\w9\w9\_s[1,2]\n\n采蘑菇。\_s\w9\w9\h\n\n采红叶是什么？\w9\w9\u\s[11]\p2\s[208]\_s[1,2]\n\n…\w5…\w5赏红叶？\_s\w9\w9\h\s[5]\n\n你看，\w5装采下来的红叶垃圾袋很方便对吧？\w9\w9\u\s[11]\p2\s[204]\_s[1,2]\n\n…\w5…\w5…。\_s'
	
	'\u\s[-1]\p2\s[200]\h\s[5]%(charname(2))——，\w5能不能帮我去一下邮局跑个腿——？\w9\w9\p[2]\s[203]诶——，\w5那边臭死了不要啦。\w9\w9\s[-1]\w9\w9\h\s[3]\n\n…\w5…\w5麻烦了啊。\w9\n邮局前面，\w5现在，\w5银杏果臭得要命讨厌得很，\w5还是忍忍去一趟吧。\w9\w9\u\s[10]啊，\w5要不由我替你去？\w9\w9\h\s[5]\n\n太好了——。\w9\n那，\w5拜托啦——♪\w9\w9\s[-1]\w9\w9\u\n\n呵呵呵。\w9\n顺便捡点银杏回来，\w5炒一炒做下酒菜。\w9\w9\h\s[5]\n\n绝对不许捡银杏回来哦——♪\w9\w9\s[-1]\w9\w9\u\s[11]\n\n…\w5…\w5…。'
	
	'\u\s[-1]\p[2]\s[-1]\h\s[5]烤红薯，\w5烤红薯——♪\w9\n来烤红薯了哦——♪\w9\w9\n…\w5…\w5\s[27]咦？引火用的报纸没啦。\w9\w9\u\s[10]哼，\w5哼，\w5哼——♪\w9\w9\h\s[5]\n\n啊，\w5%(charname(1))，\w5能帮我拿一下报纸来吗？\w9\w9\u\n\n报纸？\w5OK。\w9\w9\h\s[-1]\u\n呃——，\w5报纸，\w5报纸，\w5…放哪去了？\w9\w9\p[2]\s[203]？？\w9\n报纸？\w9\w9\u\n\n对，\w5报纸。\w9\n报纸，\w5报纸\w5…\w5…。\w9\w9\p[2]\s[205]\n\n啄木鸟。\w9\n啄木鸟，\w5啄木鸟。\w9\u\s[12]\n\n！！\w9\w9\n\s[17]番茄，\w5番茄！！\w9\p[2]\s[202]\n\n！？！？\w9\w9\n\s[207]绘马前！绘马前！！\w9\u\s[12]\n\n！？！？！？\w9\w9\n\s[17]牛奶和核桃！牛奶和核桃！！\w9\w9\p[2]\s[208]\n\n%(charname(1))，\w5挺能干的嘛。\w9\w9\u\s[10]\n\n%(charname(2))也挺行啊。\w9\w9\h\s[7]\n\n别玩了赶紧把报纸拿来————！！\w9\w9\u\s[12]\p[2]\s[202]\_s[1,2]\n\n哇哇！！\_s\w9\w9\u\s[-1]\p[2]\s[-1]'
	
	'\h\s[27]\p2\s[205]\u\s[10]啊，\w5有野鸭在飞。\w9\n是候鸟的季节了呢。\w9\w9\h…\w5…\w5…。\w9\w9\u\n\n怎么了？\w9\w9\p2\s[218]姐姐，\w5你在想什么？\w9\n鸭肉火锅？\w5鸭肉乌冬？\w5还是烤鸭？\w9\w9\h\s[5]\n\n鸭肉火锅♪\w9\n放了好多葱热腾腾的那种。\w9\w9\u\s[11]\p2\s[214]\_s[1,2]\n\n…\w5…\w5…。\_s\w9\w9\h\n\n…\w5…\w5\s[2]哈！？'
	
	'\h\s[-1]\u\s[10]\p[2]\s[205]啊，\w5鸟排成\w5「く」\w5字形在飞。\w9\w9\u是候鸟呢。\w9\w9\h\s[2]不，\w5不，\w5不，\w5不得了！！\w9\n刚，\w5刚，\w5刚，\w5刚才，\w5有只像隼一样的鸟以惊人的速度飞过来，\w5猛撞到二楼窗玻璃上！！！！\w9\w9\u\n\n是撞鸟呢。\w9\w9\p[2]\s[204]\n\n…\w5…\w5…。'
	
	'\p2\s[-1]\u\s[10]\h\s[5]泰迪——，\w5邻居说想让人帮忙收柿子。\w9\w9\u哦——，\w5去帮不就好了。\w9\w9\h\n\n嗯，\w5说是作为答谢会给柿子哦——。\w9\w9\u\n\n哦——，\w5不错呢。\w9\w9\h\n\n那，\w5泰迪，\w5拜托啦——。\w9\w9\u\s[11]\n\n哈？\w5为什么是我？\w9\w9\h\n\n你看你看，\w5啪嗒啪嗒——，\w5地飞——，\w5啪啪啪——，\w5地干就好了——。\w9\w9\u\n\n真是，\w5没办法啊。\w9\w9\n\s[-1]（啪嗒啪嗒啪嗒）\w9\w9\p[2]\s[200]咦？\w5在做什么？\w9\w9\h\n\n\s[0]嗯——，\w5在看泰迪收成。\w9\w9\p[2]\s[202]\n\n泰迪收成！？\w9\n泰迪是长在树上的吗！？\w9\w9\h\s[4]\n\n…\w5…\w5又不是树上的果实。'
	
	'\p2\s[200]\u\s[10]\h\s[5]来——大家，\w5烤红薯了哦——♪\w9\w9\u落叶OK。\w9\w9\p2\s[205]红薯也包好锡纸了。\w9\w9\h\n\n好——，\w5落叶点火啦——。\w9\w9\n\n[half]（喂——————！！！）\w9\w9\n\n[half]\s[2]哇哇哇哇哇，\w5什什什么什么——！？\w9\w9\u\s[11]\n\n…\w5…\w5说是不能在这生火的。\w9\w9\p2\s[208]\n\n好好确认一下吧。\w9\w9\h\s[3]\n\n唔——，\w5知道——啦。'

	'\p2\s[200]\u\s[10]\h\s[5]来——大家，\w5红薯烤好了哦——♪\w9\w9\p2\s[205]\_s[1,2]我开动\_s\p2了——\_s[1,2]。\_s\w9\w9\h\n\n嗯嗯，\w5好好吃——。\w9\w9\u\s[11]\n\n…\w5…\w5%(charname(0))，\w5这个红薯是什么。\w9\w9\h\s[27]\n\n嗯——，\w5大概是山药。\w9\w9\p2\s[204]\n\n姐姐那这边的是什么？\w9\w9\h\n\n嗯，\w5那是芋头吧？\w9\w9\u\s[11]\n\n暗烤薯？\w9\w9\h\n\n\s[7]但都是红薯君！\w5就是的！！\w9\w9\p2\s[214]\n\n确实是薯类没错啦\w5…\w5…。'
	
	'\h\s[-1]\p2\s[200]\u\s[10]栅栏的栅栏的拐弯转角——\w9\n篝火呀篝火呀落叶篝火——♪\w9\w9\p2\s[205]在扫院子？\w5唱得好嗨呢。\w9\w9\u\s[11]\n\n不唱唱歌什么的怎么做的下去啊，\w5这种东西。\w9\w9\p2\s[208]\n\n啊哈哈哈哈哈。\w9\w9\h\s[5]\w9啊——！\w5好多叶子♪\w9\n落叶篝火烤红薯啦。\w9\w9\u\s[11]\n\n…\w5…\w5不愧是红薯狂。\w9\w9\h\s[9]\n\n真没礼貌！！\w9\w9\p2\s[214]\n\n…\w5…\w5刚才起那边就在冒烟的秋刀鱼怎么办。\w9\w9\h\s[2]\n\n啊啊！？\w5焦了！！\w9\w9\u\s[11]\n\n…\w5…\w5现在肯定已经变成碳了吧。\w9\n真可惜。'
	
	'\u\s[10]\h\s[5]栅栏的栅栏的拐弯转角——♪\w9\w9\u…\w5…\w5心情真好呢。\w9\w9\h\n\n烤红薯烤红薯好好吃——♪\w9\w9\p[2]\s[204]果然？\w9\w9\u\s[11]\n\n嘛，\w5也算是秋天的风情吧……\w5…\w5。\e'
	
	'\u\s[10]\h\s[0]\p[2]\s[203]…\w5…\w5姐姐。\w9我，\w5裤子尺寸不合穿不下了\h\s[7]是挖苦我吗——————————！！\w9\w9\u\s[11]…\w5…\w5胖了？\w9\w9\h\s[4]\n\n嗯。\w9一点点。\w9\w9\p[2]\s[208]\n\n…\w5…\w5因为是秋天嘛——。\e'
}

